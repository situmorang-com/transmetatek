---
const navLinks = [
  { label: 'Services', href: '/#services' },
  { label: 'About', href: '/#about' },
  { label: 'Technology', href: '/#tech' },
  { label: 'Careers', href: '/careers' },
  { label: 'Contact', href: '/#contact' },
];
---

<nav id="navbar">
  <div class="container nav-inner">
    <a href="/" class="logo" aria-label="Trans Meta Teknologi Home">
      <img
        src="/TransMetaTek-logo-color.png"
        alt="Trans Meta Teknologi"
        class="logo-img"
        width="120"
        height="48"
      />
    </a>

    <button class="menu-toggle" id="menuToggle" aria-label="Toggle navigation">
      <span></span><span></span><span></span>
    </button>

    <ul class="nav-links" id="navLinks">
      {navLinks.map((link) => (
        <li><a href={link.href} class="nav-link">{link.label}</a></li>
      ))}
    </ul>

    <a href="#contact" class="btn-outline nav-cta">
      <span>Get Started</span>
    </a>
  </div>
</nav>

<style>
  #navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 1rem 0;
    background: rgba(15, 2, 2, 0.55);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    border-bottom: 1px solid rgba(232, 25, 44, 0.1);
    transition: background 0.3s ease, box-shadow 0.3s ease, padding 0.3s ease, border-color 0.3s ease;
  }

  #navbar.scrolled {
    background: rgba(15, 2, 2, 0.82);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    box-shadow: 0 1px 0 var(--border), 0 4px 30px rgba(0,0,0,0.5);
    border-bottom-color: rgba(232, 25, 44, 0.2);
    padding: 0.65rem 0;
  }

  .nav-inner {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .logo {
    display: flex;
    align-items: center;
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo-img {
    height: 40px;
    width: auto;
    object-fit: contain;
    /* Slightly brighten on dark background so red pops */
    filter: drop-shadow(0 0 8px rgba(220, 38, 38, 0.25));
    transition: filter 0.2s ease, transform 0.2s ease;
  }

  .logo:hover .logo-img {
    filter: drop-shadow(0 0 14px rgba(220, 38, 38, 0.45));
    transform: scale(1.03);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    list-style: none;
    margin-left: auto;
  }

  .nav-link {
    display: block;
    padding: 0.4rem 0.85rem;
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
    border-radius: 6px;
    transition: color 0.2s ease, background 0.2s ease;
  }

  .nav-link:hover {
    color: var(--text-primary);
    background: rgba(255,255,255,0.05);
  }

  .nav-cta {
    flex-shrink: 0;
    font-size: 0.875rem;
    padding: 0.5rem 1.25rem;
  }

  .menu-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    margin-left: auto;
  }

  .menu-toggle span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--text-secondary);
    border-radius: 2px;
    transition: all 0.3s ease;
  }

  @media (max-width: 768px) {
    .menu-toggle { display: flex; }
    .nav-cta { display: none; }

    .nav-links {
      position: fixed;
      top: 65px;
      left: 0;
      right: 0;
      background: rgba(3, 7, 15, 0.97);
      backdrop-filter: blur(20px);
      flex-direction: column;
      gap: 0;
      padding: 1rem 0 1.5rem;
      margin-left: 0;
      border-bottom: 1px solid var(--border);
      transform: translateY(-110%);
      opacity: 0;
      pointer-events: none;
      transition: transform 0.3s ease, opacity 0.3s ease;
    }

    .nav-links.open {
      transform: translateY(0);
      opacity: 1;
      pointer-events: all;
    }

    .nav-link { padding: 0.8rem 2rem; font-size: 1rem; border-radius: 0; }
  }
</style>

<script>
  const navbar = document.getElementById('navbar')!;
  const toggle = document.getElementById('menuToggle')!;
  const links = document.getElementById('navLinks')!;

  window.addEventListener('scroll', () => {
    navbar.classList.toggle('scrolled', window.scrollY > 40);
  });

  toggle.addEventListener('click', () => {
    links.classList.toggle('open');
  });

  links.querySelectorAll('a').forEach((a) => {
    a.addEventListener('click', () => links.classList.remove('open'));
  });
</script>
