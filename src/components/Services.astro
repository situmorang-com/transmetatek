---
const services = [
  {
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><circle cx="14" cy="14" r="10" stroke="url(#g1)" stroke-width="1.5"/><path d="M9 14l3 3 7-7" stroke="url(#g1)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><defs><linearGradient id="g1" x1="4" y1="4" x2="24" y2="24"><stop stop-color="#00d4ff"/><stop offset="1" stop-color="#a855f7"/></linearGradient></defs></svg>`,
    title: 'AI Strategy & Roadmap',
    desc: 'We identify where AI can impact your business most and build a comprehensive roadmap aligned to your long-term vision, data infrastructure, and ethical considerations.',
    tags: ['Strategy', 'Roadmap', 'Ethics'],
    color: 'cyan',
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><rect x="4" y="4" width="8" height="8" rx="2" stroke="url(#g2)" stroke-width="1.5"/><rect x="16" y="4" width="8" height="8" rx="2" stroke="url(#g2)" stroke-width="1.5"/><rect x="4" y="16" width="8" height="8" rx="2" stroke="url(#g2)" stroke-width="1.5"/><rect x="16" y="16" width="8" height="8" rx="2" stroke="url(#g2)" stroke-width="1.5"/><defs><linearGradient id="g2" x1="4" y1="4" x2="24" y2="24"><stop stop-color="#00d4ff"/><stop offset="1" stop-color="#a855f7"/></linearGradient></defs></svg>`,
    title: 'Machine Learning Models',
    desc: 'Custom ML models built for your specific data and objectives — from regression and classification to deep learning architectures optimized for production.',
    tags: ['Deep Learning', 'PyTorch', 'TensorFlow'],
    color: 'purple',
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M5 14h4l3-8 4 16 3-8h4" stroke="url(#g3)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><defs><linearGradient id="g3" x1="5" y1="14" x2="23" y2="14"><stop stop-color="#00d4ff"/><stop offset="1" stop-color="#a855f7"/></linearGradient></defs></svg>`,
    title: 'Natural Language Processing',
    desc: 'Unlock the power of language — sentiment analysis, document classification, chatbots, semantic search, and LLM fine-tuning for your domain.',
    tags: ['LLMs', 'RAG', 'Fine-tuning'],
    color: 'blue',
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><circle cx="14" cy="14" r="4" stroke="url(#g4)" stroke-width="1.5"/><path d="M14 4v3M14 21v3M4 14h3M21 14h3M6.9 6.9l2.1 2.1M19 19l2.1 2.1M19 9l2.1-2.1M6.9 21.1L9 19" stroke="url(#g4)" stroke-width="1.5" stroke-linecap="round"/><defs><linearGradient id="g4" x1="4" y1="4" x2="24" y2="24"><stop stop-color="#a855f7"/><stop offset="1" stop-color="#00d4ff"/></linearGradient></defs></svg>`,
    title: 'Computer Vision',
    desc: 'Object detection, image classification, OCR, video analytics, and quality inspection systems — designed for real-world deployment at scale.',
    tags: ['Detection', 'OCR', 'Video AI'],
    color: 'purple',
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M4 20l6-6 4 4 4-5 6 7" stroke="url(#g5)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M4 4h20v20H4z" stroke="url(#g5)" stroke-width="1.5" rx="2"/><defs><linearGradient id="g5" x1="4" y1="4" x2="24" y2="24"><stop stop-color="#00d4ff"/><stop offset="1" stop-color="#10b981"/></linearGradient></defs></svg>`,
    title: 'Data Science & Analytics',
    desc: 'Transform raw data into actionable intelligence. We build data pipelines, dashboards, and predictive analytics systems that drive decisions.',
    tags: ['Analytics', 'BI', 'Pipelines'],
    color: 'green',
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M14 4l8 4v8l-8 4-8-4V8l8-4z" stroke="url(#g6)" stroke-width="1.5" stroke-linejoin="round"/><path d="M14 16v8M6 8l8 8M22 8l-8 8" stroke="url(#g6)" stroke-width="1.5" stroke-linecap="round"/><defs><linearGradient id="g6" x1="4" y1="4" x2="24" y2="24"><stop stop-color="#3b82f6"/><stop offset="1" stop-color="#a855f7"/></linearGradient></defs></svg>`,
    title: 'AI Integration & Training',
    desc: 'Seamlessly integrate AI solutions into your existing tech stack. We also upskill your team through tailored training programs and workshops.',
    tags: ['Integration', 'Training', 'Upskilling'],
    color: 'blue',
  },
];
---

<section id="services">
  <div class="container">
    <div class="section-header reveal">
      <div class="tag">// What We Do</div>
      <h2 class="section-heading" style="margin-top: 1rem;">
        AI Services That<br /><span>Move the Needle</span>
      </h2>
      <p class="section-sub" style="margin-top: 1rem;">
        From strategy to deployment — we cover the full spectrum of artificial intelligence
        to deliver measurable business outcomes.
      </p>
    </div>

    <div class="services-grid">
      {services.map((s, i) => (
        <div class={`glass-card service-card reveal reveal-delay-${(i % 3) + 1}`}>
          <div class={`service-icon icon-${s.color}`}>
            <Fragment set:html={s.icon} />
          </div>
          <h3 class="service-title">{s.title}</h3>
          <p class="service-desc">{s.desc}</p>
          <div class="service-tags">
            {s.tags.map((t) => <span class="service-tag">{t}</span>)}
          </div>
          <div class={`card-glow glow-${s.color}`}></div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  #services {
    padding: 7rem 0;
  }

  .section-header {
    text-align: center;
    margin-bottom: 4rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .service-card {
    padding: 2rem;
    position: relative;
    overflow: hidden;
    cursor: default;
  }

  .service-icon {
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 14px;
    margin-bottom: 1.25rem;
  }

  .icon-cyan { background: rgba(0, 212, 255, 0.1); border: 1px solid rgba(0, 212, 255, 0.2); }
  .icon-purple { background: rgba(168, 85, 247, 0.1); border: 1px solid rgba(168, 85, 247, 0.2); }
  .icon-blue { background: rgba(59, 130, 246, 0.1); border: 1px solid rgba(59, 130, 246, 0.2); }
  .icon-green { background: rgba(16, 185, 129, 0.1); border: 1px solid rgba(16, 185, 129, 0.2); }

  .service-title {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.75rem;
    letter-spacing: -0.01em;
  }

  .service-desc {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.65;
    margin-bottom: 1.25rem;
  }

  .service-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .service-tag {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--text-muted);
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.07);
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    letter-spacing: 0.05em;
  }

  .card-glow {
    position: absolute;
    bottom: -60px;
    right: -60px;
    width: 160px;
    height: 160px;
    border-radius: 50%;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .glow-cyan { background: radial-gradient(circle, rgba(0, 212, 255, 0.12) 0%, transparent 70%); }
  .glow-purple { background: radial-gradient(circle, rgba(168, 85, 247, 0.12) 0%, transparent 70%); }
  .glow-blue { background: radial-gradient(circle, rgba(59, 130, 246, 0.12) 0%, transparent 70%); }
  .glow-green { background: radial-gradient(circle, rgba(16, 185, 129, 0.12) 0%, transparent 70%); }

  .service-card:hover .card-glow { opacity: 1; }

  @media (max-width: 1024px) {
    .services-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .services-grid { grid-template-columns: 1fr; }
  }
</style>
