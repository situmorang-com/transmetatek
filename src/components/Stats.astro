---
const stats = [
  { value: '50', suffix: '+', label: 'AI Projects Delivered', icon: '🚀' },
  { value: '10', suffix: '+', label: 'Industries Served', icon: '🌐' },
  { value: '98', suffix: '%', label: 'Client Satisfaction', icon: '⭐' },
  { value: '3', suffix: 'x', label: 'Average ROI Uplift', icon: '📈' },
];
---

<section id="stats">
  <div class="stats-line"></div>
  <div class="container">
    <div class="stats-grid">
      {stats.map((s, i) => (
        <div class={`stat-item reveal reveal-delay-${i + 1}`}>
          <span class="stat-icon">{s.icon}</span>
          <div class="stat-value-row">
            <span class="stat-value" data-target={s.value}>0</span>
            <span class="stat-suffix">{s.suffix}</span>
          </div>
          <div class="stat-label">{s.label}</div>
        </div>
      ))}
    </div>
  </div>
  <div class="stats-line"></div>
</section>

<style>
  #stats {
    padding: 1rem 0;
  }

  .stats-line {
    height: 1px;
    background: linear-gradient(90deg, transparent 0%, var(--border) 30%, var(--cyan-glow) 50%, var(--border) 70%, transparent 100%);
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    padding: 3.5rem 0;
    position: relative;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 1.5rem;
    position: relative;
  }

  .stat-item + .stat-item::before {
    content: '';
    position: absolute;
    left: 0;
    top: 20%;
    height: 60%;
    width: 1px;
    background: var(--border);
  }

  .stat-icon {
    font-size: 1.75rem;
    margin-bottom: 0.75rem;
    display: block;
  }

  .stat-value-row {
    display: flex;
    align-items: baseline;
    gap: 0.1rem;
    margin-bottom: 0.4rem;
  }

  .stat-value {
    font-size: 2.75rem;
    font-weight: 700;
    font-family: var(--font-mono);
    background: linear-gradient(135deg, var(--cyan) 0%, var(--purple) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1;
  }

  .stat-suffix {
    font-size: 1.75rem;
    font-weight: 700;
    font-family: var(--font-mono);
    color: var(--cyan);
    line-height: 1;
  }

  .stat-label {
    font-size: 0.82rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-family: var(--font-mono);
  }

  @media (max-width: 768px) {
    .stats-grid { grid-template-columns: repeat(2, 1fr); }
    .stat-item:nth-child(3)::before { display: none; }
    .stat-item:nth-child(odd)::before { display: none; }
    .stat-item:nth-child(even)::before { display: block; }
  }

  @media (max-width: 400px) {
    .stats-grid { grid-template-columns: 1fr; }
    .stat-item::before { display: none !important; }
  }
</style>

<script>
  function animateCounter(el: Element) {
    const target = parseInt(el.getAttribute('data-target') || '0', 10);
    const duration = 2000;
    const start = performance.now();
    function step(now: number) {
      const p = Math.min((now - start) / duration, 1);
      const ease = 1 - Math.pow(1 - p, 4);
      el.textContent = String(Math.floor(ease * target));
      if (p < 1) requestAnimationFrame(step);
    }
    requestAnimationFrame(step);
  }

  const obs = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          e.target.querySelectorAll('[data-target]').forEach(animateCounter);
          obs.unobserve(e.target);
        }
      });
    },
    { threshold: 0.4 }
  );

  const grid = document.querySelector('.stats-grid');
  if (grid) obs.observe(grid);
</script>
