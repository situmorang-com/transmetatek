<script is:inline define:vars={{ C, areas, drivers, sjt, traits, workSample }}>
  // ── State ──────────────────────────────────────────────────────────────
  let currentStep = 1;
  let lang = 'en';
  const totalSteps = 4;
  const sjtPicks = {};
  sjt.forEach(s => sjtPicks[s.key] = { best: null, worst: null });
  const sjtKey = {};
  sjt.forEach(s => sjtKey[s.key] = { best: s.best, worst: s.worst });
  const driverPicks = { most: null, least: null };  // ipsative driver pick (keys)
  let builderScore = 0;
  let loyaltyScore = 0;       // 0–100 (admin)
  let moneyOrientation = 50;  // 0–100, higher = more money-driven (admin flag)
  let photoDataUrl = null;
  const traitScores = {};
  traits.forEach(t => traitScores[t.key] = 0);

  // ── Gauge gradient ──────────────────────────────────────────────────────
  const gaugeSvg = document.querySelector('.gauge-svg');
  const defs = document.createElementNS('http://www.w3.org/2000/svg', 'defs');
  const grad = document.createElementNS('http://www.w3.org/2000/svg', 'linearGradient');
  grad.setAttribute('id', 'gaugeGrad');
  grad.setAttribute('x1','0%'); grad.setAttribute('y1','0%'); grad.setAttribute('x2','100%'); grad.setAttribute('y2','100%');
  const gs1 = document.createElementNS('http://www.w3.org/2000/svg', 'stop'); gs1.setAttribute('offset','0%'); gs1.setAttribute('stop-color','#E8192C');
  const gs2 = document.createElementNS('http://www.w3.org/2000/svg', 'stop'); gs2.setAttribute('offset','100%'); gs2.setAttribute('stop-color','#FF5252');
  grad.appendChild(gs1); grad.appendChild(gs2); defs.appendChild(grad);
  gaugeSvg.insertBefore(defs, gaugeSvg.firstChild);

  // ── i18n ─────────────────────────────────────────────────────────────────
  const dict = (k) => (C[lang] && C[lang][k] != null) ? C[lang][k] : C.en[k];

  function wordUnit(n) { return n === 1 ? dict('word.unit1') : dict('word.unit'); }

  function applyLanguage(next) {
    lang = next;
    document.documentElement.lang = next;
    // static text
    document.querySelectorAll('[data-i18n]').forEach(el => {
      const k = el.dataset.i18n;
      if (k === '__ws_scenario') { el.textContent = workSample[lang] ?? workSample.en; return; }
      const v = dict(k); if (v != null) el.textContent = v;
    });
    document.querySelectorAll('[data-i18n-html]').forEach(el => {
      const v = dict(el.dataset.i18nHtml); if (v != null) el.innerHTML = v;
    });
    document.querySelectorAll('[data-i18n-ph]').forEach(el => {
      const v = dict(el.dataset.i18nPh); if (v != null) el.placeholder = v;
    });
    // dynamic lists
    areas.forEach(a => {
      const opt = document.querySelector(`option[data-area="${a.value}"]`);
      if (opt) opt.textContent = a[lang] ?? a.en;
    });
    drivers.forEach(d => {
      const el = document.querySelector(`[data-driver="${d.key}"] .driver-text`);
      if (el) el.textContent = d[lang] ?? d.en;
    });
    sjt.forEach(s => {
      const card = document.querySelector(`[data-sjt="${s.key}"]`);
      if (!card) return;
      const content = s[lang] ?? s.en;
      card.querySelector('.sjt-scen-text').textContent = content.scenario;
      card.querySelectorAll('.sjt-option').forEach(o => {
        const i = parseInt(o.dataset.opt);
        o.querySelector('.sjt-opt-text').textContent = content.options[i];
      });
    });
    traits.forEach(t => {
      const el = document.querySelector(`[data-trait="${t.key}"] .trait-name`);
      if (el) el.textContent = t[lang] ?? t.en;
    });
    // word counters
    document.querySelectorAll('.word-count').forEach(c => {
      const n = parseInt(c.dataset.count || '0');
      c.textContent = n + ' ' + wordUnit(n);
    });
    // toggle UI
    document.querySelectorAll('.lang-btn').forEach(b => b.classList.toggle('active', b.dataset.lang === next));
  }

  // ── Helpers ───────────────────────────────────────────────────────────
  const countWords = (str) => str.trim().split(/\s+/).filter(w => w.length > 0).length;
  const clamp = (n) => Math.max(0, Math.min(100, n));
  const depth = (wc, target) => clamp((wc / target) * 100);
  const txt = (id) => (document.getElementById(id)?.value ?? '').trim();

  function sjtTrait(id) {
    const pick = sjtPicks[id], key = sjtKey[id];
    let hits = 0;
    if (pick.best  != null) hits += (pick.best  === key.best)  ? 1 : 0;
    if (pick.worst != null) hits += (pick.worst === key.worst) ? 1 : 0;
    return (hits / 2) * 100;
  }

  // ── Scoring ───────────────────────────────────────────────────────────────
  // No self-report: every trait is driven by situational best/worst picks
  // (scored against a hidden key the candidate can't see) and by the depth of
  // the written answers the founder reads by hand. Nothing here can be gamed by
  // just "picking the good-looking answer".
  function computeScores() {
    const wsDepth = depth(countWords(txt('work-sample')), 80);
    const slDepth = depth(countWords(txt('story-learning')), 70);
    const viDepth = depth(countWords(txt('vision')), 55);
    const nmDepth = depth(countWords(txt('no-money-story')), 60);

    traitScores.ownership = clamp(0.32*sjtTrait('s1') + 0.30*sjtTrait('s4') + 0.25*sjtTrait('s11') + 0.13*wsDepth);
    traitScores.tolerance = clamp(0.55*sjtTrait('s2') + 0.30*sjtTrait('s1') + 0.15*wsDepth);
    traitScores.ego       = clamp(0.40*sjtTrait('s3') + 0.35*sjtTrait('s5') + 0.25*sjtTrait('s10'));
    traitScores.growth    = clamp(0.40*sjtTrait('s10') + 0.30*sjtTrait('s12') + 0.30*slDepth);
    traitScores.drive     = clamp(0.45*sjtTrait('s8') + 0.30*viDepth + 0.25*nmDepth);
    traitScores.ambition  = clamp(0.55*sjtTrait('s9') + 0.30*viDepth + 0.15*sjtTrait('s10'));

    // ── Loyalty & money orientation (admin signal; never shown live) ──────────
    // Driver pick is a soft secondary signal; the real money read comes from the
    // loyalty scenarios (hidden key) which a candidate can't easily fake.
    const mostBuild  = ['build','own','learn'].includes(driverPicks.most);
    const mostMoney  = driverPicks.most  === 'money';
    const leastMoney = driverPicks.least === 'money';
    const driverLoyalty = mostBuild ? 100 : mostMoney ? 0 : 55;
    const sjtLoyalty = (sjtTrait('s6') + sjtTrait('s7')) / 2;

    traitScores.loyalty = clamp(0.40*sjtTrait('s6') + 0.40*sjtTrait('s7') + 0.10*driverLoyalty + 0.10*nmDepth);
    loyaltyScore = Math.round(traitScores.loyalty);

    // Higher = more money-driven. SJT money-first picks dominate; the driver pick
    // nudges it; a real "worked hard for no money" story lowers it.
    let money = 50;
    money += (100 - sjtLoyalty) * 0.35;
    if (mostMoney)  money += 22;
    if (leastMoney) money -= 22;
    if (driverPicks.most === 'comfort') money += 8;
    if (driverPicks.most === 'status')  money += 6;
    money -= nmDepth * 0.12;
    moneyOrientation = Math.round(clamp(money));

    let bs =
      0.18*traitScores.ownership + 0.17*traitScores.tolerance + 0.15*traitScores.ego +
      0.14*traitScores.growth    + 0.11*traitScores.drive     + 0.11*traitScores.ambition +
      0.14*traitScores.loyalty;
    // Penalise strongly money-primary profiles (the founder wants to screen these out).
    if (moneyOrientation >= 75) bs -= (moneyOrientation - 75) * 0.4;
    builderScore = Math.round(clamp(bs));
  }

  function render() {
    computeScores();
    const circ = 314.16;
    const fill = document.getElementById('gauge-fill');
    if (fill) fill.style.strokeDashoffset = circ - (builderScore / 100) * circ;
    const pct = document.getElementById('gauge-pct-text');
    if (pct) pct.textContent = builderScore + '%';
    traits.forEach(tr => {
      const v = Math.round(traitScores[tr.key]);
      const bar = document.querySelector(`[data-trait-fill="${tr.key}"]`);
      const lbl = document.querySelector(`[data-trait-pct="${tr.key}"]`);
      if (bar) bar.style.width = v + '%';
      if (lbl) lbl.textContent = v + '%';
    });
  }

  // ── Navigation ────────────────────────────────────────────────────────────
  function goToStep(n) {
    document.getElementById(`step-${currentStep}`)?.classList.add('hidden');
    document.getElementById(`step-${n}`)?.classList.remove('hidden');
    currentStep = n;
    const stepFill = document.getElementById('step-fill');
    if (stepFill) stepFill.style.width = (n / totalSteps) * 100 + '%';
    document.querySelectorAll('.step-label').forEach(el => {
      const s = parseInt(el.dataset.step);
      el.classList.toggle('active', s === n);
      el.classList.toggle('completed', s < n);
    });
    document.getElementById('builder-form-section')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  function shake(el) {
    if (!el) return;
    el.classList.add('invalid');
    el.style.animation = 'shake 0.4s ease';
    setTimeout(() => { el.style.animation = ''; }, 400);
    setTimeout(() => el.classList.remove('invalid'), 2500);
    el.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }

  function validateStep(n) {
    if (n === 1) {
      for (const id of ['fname','lname','email','city','phone','area','linkedin']) {
        const el = document.getElementById(id);
        if (!el.value.trim() || (id === 'email' && !el.value.includes('@'))) { shake(el); return false; }
      }
      if (!photoDataUrl) { shake(document.getElementById('photo-upload')); return false; }
      return true;
    }
    if (n === 2) {
      if (driverPicks.most == null || driverPicks.least == null) {
        shake(document.getElementById('drivers-list')); return false;
      }
      return true;
    }
    if (n === 3) {
      for (const s of sjt) {
        const p = sjtPicks[s.key];
        if (p.best == null || p.worst == null) { shake(document.querySelector(`[data-sjt="${s.key}"]`)); return false; }
      }
      return true;
    }
    if (n === 4) {
      if (countWords(txt('work-sample'))    < 60) { shake(document.getElementById('work-sample')); return false; }
      if (countWords(txt('story-learning')) < 50) { shake(document.getElementById('story-learning')); return false; }
      if (countWords(txt('vision'))         < 40) { shake(document.getElementById('vision')); return false; }
      if (countWords(txt('no-money-story')) < 50) { shake(document.getElementById('no-money-story')); return false; }
      if (!document.getElementById('ack').checked) { shake(document.getElementById('ack-box')); return false; }
      return true;
    }
    return true;
  }

  // ── Wiring ──────────────────────────────────────────────────────────────
  document.querySelectorAll('.lang-btn').forEach(btn =>
    btn.addEventListener('click', () => applyLanguage(btn.dataset.lang)));

  document.querySelectorAll('.step-next').forEach(btn =>
    btn.addEventListener('click', () => { if (validateStep(currentStep)) goToStep(parseInt(btn.dataset.next)); }));
  document.querySelectorAll('.step-prev').forEach(btn =>
    btn.addEventListener('click', () => goToStep(parseInt(btn.dataset.prev))));

  ['fname','email','city','area','linkedin'].forEach(id =>
    document.getElementById(id)?.addEventListener('input', render));

  document.querySelectorAll('.sjt-card').forEach(card => {
    const id = card.dataset.sjt;
    card.querySelectorAll('.sjt-option').forEach(optEl => {
      const oi = parseInt(optEl.dataset.opt);
      optEl.querySelectorAll('.sjt-pick').forEach(btn => {
        const kind = btn.dataset.kind;
        btn.addEventListener('click', () => {
          const other = kind === 'best' ? 'worst' : 'best';
          if (sjtPicks[id][kind] === oi) {
            sjtPicks[id][kind] = null;
          } else {
            sjtPicks[id][kind] = oi;
            if (sjtPicks[id][other] === oi) sjtPicks[id][other] = null;
          }
          card.querySelectorAll('.sjt-option').forEach(o => {
            const i = parseInt(o.dataset.opt);
            o.querySelector('.sjt-best').classList.toggle('on', sjtPicks[id].best === i);
            o.querySelector('.sjt-worst').classList.toggle('on', sjtPicks[id].worst === i);
          });
          card.classList.toggle('complete', sjtPicks[id].best != null && sjtPicks[id].worst != null);
          render();
        });
      });
    });
  });

  // ── Drivers (ipsative): one MOST + one LEAST across the whole list ─────────
  function refreshDrivers() {
    document.querySelectorAll('.driver-row').forEach(row => {
      const k = row.dataset.driver;
      row.querySelector('.driver-most').classList.toggle('on', driverPicks.most === k);
      row.querySelector('.driver-least').classList.toggle('on', driverPicks.least === k);
    });
  }
  document.querySelectorAll('.driver-row').forEach(row => {
    const k = row.dataset.driver;
    row.querySelectorAll('.driver-pick').forEach(btn => {
      const kind = btn.dataset.kind;                       // 'most' | 'least'
      const other = kind === 'most' ? 'least' : 'most';
      btn.addEventListener('click', () => {
        if (driverPicks[kind] === k) {
          driverPicks[kind] = null;                        // toggle off
        } else {
          driverPicks[kind] = k;
          if (driverPicks[other] === k) driverPicks[other] = null;  // can't be both
        }
        refreshDrivers();
        render();
      });
    });
  });

  function wireTextarea(id, countId, sentId, target) {
    const ta = document.getElementById(id);
    const counter = document.getElementById(countId);
    const fill = document.getElementById(sentId)?.querySelector('.sentiment-fill');
    ta?.addEventListener('input', () => {
      const w = countWords(ta.value);
      if (counter) { counter.dataset.count = w; counter.textContent = w + ' ' + wordUnit(w); }
      if (fill) fill.style.width = depth(w, target) + '%';
      render();
    });
  }
  wireTextarea('work-sample',    'ws-count', 'ws-sent', 80);
  wireTextarea('story-learning', 'sl-count', 'sl-sent', 70);
  wireTextarea('vision',         'vi-count', 'vi-sent', 55);
  wireTextarea('no-money-story', 'nm-count', 'nm-sent', 60);

  document.getElementById('ack')?.addEventListener('change', () =>
    document.getElementById('ack-box')?.classList.remove('invalid'));

  // ── Profile photo (downscaled, then encoded to keep files small) ───────────
  // WebP keeps storage tiny; fall back to JPEG only if the browser can't encode
  // WebP (e.g. older Safari) so the upload still works everywhere.
  function encodePhoto(canvas, quality) {
    const webp = canvas.toDataURL('image/webp', quality);
    if (webp.startsWith('data:image/webp')) return webp;
    return canvas.toDataURL('image/jpeg', quality);
  }

  function drawToDataUrl(source, w0, h0, maxSize, quality) {
    const scale = Math.min(1, maxSize / Math.max(w0, h0));
    const w = Math.max(1, Math.round(w0 * scale));
    const h = Math.max(1, Math.round(h0 * scale));
    const canvas = document.createElement('canvas');
    canvas.width = w; canvas.height = h;
    canvas.getContext('2d').drawImage(source, 0, 0, w, h);
    const url = encodePhoto(canvas, quality);
    if (!url || !url.startsWith('data:image/')) throw new Error('encode produced no image');
    return url;
  }

  function fileToDataUrl(file, maxSize = 512, quality = 0.82) {
    return new Promise((resolve, reject) => {
      if (!file || !(file.type || '').startsWith('image/')) { reject(new Error('not an image file')); return; }
      const timer = setTimeout(() => reject(new Error('photo decode timed out')), 20000);
      const ok = (url) => { clearTimeout(timer); resolve(url); };
      const fail = (err) => { clearTimeout(timer); reject(err); };

      // Fallback path: FileReader → <img>. Works on every browser.
      const viaImg = () => {
        const reader = new FileReader();
        reader.onload = e => {
          const img = new Image();
          img.onload = () => { try { ok(drawToDataUrl(img, img.naturalWidth || img.width, img.naturalHeight || img.height, maxSize, quality)); } catch (err) { fail(err); } };
          img.onerror = () => fail(new Error('image could not be decoded'));
          img.src = e.target.result;
        };
        reader.onerror = () => fail(new Error('file could not be read'));
        reader.readAsDataURL(file);
      };

      // Preferred path: createImageBitmap decodes the Blob directly (faster, honors orientation).
      if (typeof createImageBitmap === 'function') {
        createImageBitmap(file)
          .then(bmp => { try { ok(drawToDataUrl(bmp, bmp.width, bmp.height, maxSize, quality)); } catch (err) { fail(err); } })
          .catch(viaImg);
      } else {
        viaImg();
      }
    });
  }

  function setPhotoHint(key, isError) {
    const hint = document.querySelector('.photo-hint');
    if (!hint) return;
    hint.dataset.i18n = key;                 // keep it translatable on language switch
    hint.textContent = dict(key);
    hint.classList.toggle('photo-hint-error', !!isError);
  }

  function readAsDataUrl(file) {
    return new Promise((resolve, reject) => {
      const reader = new FileReader();
      reader.onload = e => resolve(e.target.result);
      reader.onerror = () => reject(new Error('file could not be read'));
      reader.readAsDataURL(file);
    });
  }

  function showPhotoPreview(url) {
    const preview = document.getElementById('photo-preview');
    if (preview) { preview.innerHTML = `<img src="${url}" alt="" style="width:100%;height:100%;object-fit:cover;display:block;" />`; preview.classList.add('filled'); }
    const btn = document.getElementById('photo-btn-label');
    if (btn) { btn.dataset.i18n = 'photo.change'; btn.textContent = dict('photo.change'); }
  }

  document.getElementById('photo-input')?.addEventListener('change', async (e) => {
    const file = e.target.files && e.target.files[0];
    e.target.value = '';                      // allow re-picking the same file later
    if (!file) return;
    const upload = document.getElementById('photo-upload');
    setPhotoHint('photo.reading', false);

    // Step 1 — show the photo immediately from the raw file. This works for any
    // viewable image and does NOT depend on canvas/WebP, so the preview always
    // appears the moment a valid image is chosen.
    let rawUrl = null;
    try { rawUrl = await readAsDataUrl(file); } catch (err) { console.error('[builder] read error:', err); }
    if (rawUrl && rawUrl.startsWith('data:image/')) {
      photoDataUrl = rawUrl;                  // usable fallback even if optimisation fails
      showPhotoPreview(rawUrl);
      upload?.classList.remove('invalid');
      setPhotoHint('photo.hint', false);
    } else {
      photoDataUrl = null;
      upload?.classList.add('invalid');
      setPhotoHint('photo.error', true);
      return;
    }

    // Step 2 — optimise to a small WebP in the background; keep the raw image if
    // the browser can't encode (older Safari, canvas blocked, etc.).
    try {
      const optimised = await fileToDataUrl(file);
      if (optimised && optimised.startsWith('data:image/')) {
        photoDataUrl = optimised;
        showPhotoPreview(optimised);
      }
    } catch (err) {
      console.warn('[builder] photo optimise skipped, keeping original:', err);
    }
  });

  // ── Submit ──────────────────────────────────────────────────────────────
  function collect() {
    let sjtScore = 0;
    sjt.forEach(s => {
      const p = sjtPicks[s.key], k = sjtKey[s.key];
      if (p.best === k.best)   sjtScore++;
      if (p.worst === k.worst) sjtScore++;
    });
    sjtScore = Math.round((sjtScore / (sjt.length * 2)) * 100);
    return {
      firstName: txt('fname'), lastName: txt('lname'), email: txt('email'),
      city: txt('city'), phone: txt('phone'), photo: photoDataUrl,
      area: document.getElementById('area').value, interviewLanguage: lang,
      linkedin: txt('linkedin'), portfolio: txt('portfolio') || null,
      drivers: driverPicks,
      sjt: sjtPicks, sjtScore,
      workSample: txt('work-sample'), storyLearning: txt('story-learning'), vision: txt('vision'),
      noMoneyStory: txt('no-money-story'),
      acknowledged: document.getElementById('ack').checked,
      traitScores, builderScore, loyaltyScore, moneyOrientation,
    };
  }

  document.getElementById('submit-btn')?.addEventListener('click', () => {
    if (!validateStep(4)) return;
    render();
    const data = collect();
    fetch('/api/builder', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data),
    }).catch(err => console.error('[builder] submit error:', err));

    document.getElementById('final-score').textContent = builderScore + '%';
    document.getElementById('final-lang').textContent = lang === 'id' ? 'Bahasa Indonesia' : 'English';

    // Populate traits grid on success screen with growth tips
    const traitsGrid = document.getElementById('success-traits-grid');
    const traitLongNames = {
      ownership: lang === 'id' ? 'Kepemilikan & Kerja Keras' : 'Ownership & Hard Work',
      tolerance: lang === 'id' ? 'Toleransi Startup' : 'Startup Tolerance',
      ego: lang === 'id' ? 'Ego Rendah, Standar Tinggi' : 'Low Ego, High Standard',
      growth: lang === 'id' ? 'Pertumbuhan & Pembelajaran' : 'Growth & Learning',
      drive: lang === 'id' ? 'Dorongan & Motivasi' : 'Drive & Motivation',
      ambition: lang === 'id' ? 'Ambisi Jangka Panjang' : 'Long-term Ambition',
      loyalty: lang === 'id' ? 'Loyalitas & Komitmen' : 'Loyalty & Commitment',
    };
    const traitGrowthTips = {
      ownership: lang === 'id'
        ? 'Tumbuh: Mulai dengan satu masalah di luar peranmu minggu ini. Jangan laporkan—selesaikan, lalu beri tahu bosmu.'
        : 'Grow: Start with one problem outside your role this week. Don\'t report it—solve it, then tell your boss.',
      tolerance: lang === 'id'
        ? 'Tumbuh: Latih "rencana B". Ketika prioritas berubah, jangan frustrasi—tanya "apa yang kami tahu sekarang, dan apa yang bisa kami kirim dalam 24 jam?"'
        : 'Grow: Practice "Plan B" thinking. When priorities shift, don\'t resist—ask "what do we know now, and what can we ship in 24 hours?"',
      ego: lang === 'id'
        ? 'Tumbuh: Minta umpan balik yang keras. Mulai pertemuan dengan "apa yang saya lewatkan?" bukan "inilah hasilnya."'
        : 'Grow: Ask for hard feedback. Start meetings with "what did I miss?" not "here\'s what I did."',
      growth: lang === 'id'
        ? 'Tumbuh: Pilih satu alat/keterampilan yang tidak bisa kamu gunakan. Batas waktu satu minggu. Kapal sesuatu dengan itu.'
        : 'Grow: Pick one tool/skill you can\'t use. One-week deadline. Ship something with it.',
      drive: lang === 'id'
        ? 'Tumbuh: Lakukan satu proyek tanpa hadiah eksternal—tidak ada uang, tidak ada kredit publik, hanya karena masalahnya nyata.'
        : 'Grow: Do one project with no external reward—no pay, no public credit, just because the problem is real.',
      ambition: lang === 'id'
        ? 'Tumbuh: Tuliskan visi lima tahun yang spesifik. Bukan "tumbuh," tetapi "memimpin produk retail AI untuk Indonesia pada tahun 2030."'
        : 'Grow: Write a specific five-year vision. Not "grow," but "lead retail AI product for Indonesia by 2030."',
      loyalty: lang === 'id'
        ? 'Tumbuh: Tanyakan pada diri sendiri: "Apa yang akan membuat saya tinggal jika gaji berhenti?" Jika hanya uang, itu informasi penting.'
        : 'Grow: Ask yourself: "What would make me stay if the money stopped?" If only money, that\'s important info.',
    };
    traitsGrid.innerHTML = Object.entries(traitScores).map(([key, val]) => `
      <div class="trait-card">
        <div class="trait-card-name">${traitLongNames[key]}</div>
        <div class="trait-card-score">${Math.round(val)}%</div>
        <div class="trait-card-desc">${traitGrowthTips[key]}</div>
      </div>
    `).join('');

    // Update score bracket hint based on score
    const bracketHint = document.getElementById('score-bracket-hint');
    let bracketText = '';
    if (builderScore >= 80) {
      bracketText = lang === 'id' ? '🎯 80–100: Sinyal builder yang kuat di semua area.' : '🎯 80–100: Strong builder signals across the board.';
    } else if (builderScore >= 60) {
      bracketText = lang === 'id' ? '📈 60–79: Solid di kebanyakan area, ada ruang untuk tumbuh di satu tempat.' : '📈 60–79: Solid on most traits, room to grow in one area.';
    } else if (builderScore >= 40) {
      bracketText = lang === 'id' ? '🔄 40–59: Sinyal campur. Kuat di satu area, lebih lemah di area lain.' : '🔄 40–59: Mixed signals. Strong in one area, weaker in another.';
    } else {
      bracketText = lang === 'id' ? '❓ 0–39: Profil yang berbeda. Mungkin kamu lebih kuat di jalur karir lain.' : '❓ 0–39: Different profile. You might be stronger in a different path.';
    }
    bracketHint.innerHTML = bracketText;

    document.getElementById('success-screen')?.classList.remove('hidden');
    // Reveal the Builder Profile summary now that the assessment is complete.
    document.getElementById('profile-panel')?.classList.remove('meter-hidden');
    const stepFill = document.getElementById('step-fill');
    if (stepFill) stepFill.style.width = '100%';
  });

  // ── Shake keyframe ────────────────────────────────────────────────────────
  const style = document.createElement('style');
  style.textContent = `@keyframes shake { 0%,100%{transform:translateX(0)} 20%{transform:translateX(-6px)} 40%{transform:translateX(6px)} 60%{transform:translateX(-4px)} 80%{transform:translateX(4px)} }`;
  document.head.appendChild(style);

  // ── Founder-only meter toggle (hidden from candidates) ──────────────────────
  // The Builder Profile stays hidden through the whole form. The founder can
  // reveal it to watch live scoring while testing scenarios — via the tiny
  // bottom-right dot, Ctrl/Cmd+Shift+M, or ?meter=1. Choice is remembered.
  const profilePanel = document.getElementById('profile-panel');
  const meterBtn = document.getElementById('meter-toggle');
  const meterOn = () => !profilePanel?.classList.contains('meter-hidden');
  function setMeter(show, persist) {
    profilePanel?.classList.toggle('meter-hidden', !show);
    meterBtn?.classList.toggle('on', show);
    if (persist) { try { localStorage.setItem('builderMeter', show ? '1' : '0'); } catch (e) {} }
  }
  let savedMeter = null;
  try { savedMeter = localStorage.getItem('builderMeter'); } catch (e) {}
  const urlMeter = new URLSearchParams(window.location.search).get('meter');
  if (urlMeter === '1' || savedMeter === '1') setMeter(true, false);
  meterBtn?.addEventListener('click', () => setMeter(!meterOn(), true));
  document.addEventListener('keydown', (e) => {
    if ((e.ctrlKey || e.metaKey) && e.shiftKey && (e.key === 'M' || e.key === 'm')) {
      e.preventDefault();
      setMeter(!meterOn(), true);
    }
  });

  // ── Init: honor ?lang=id ──────────────────────────────────────────────────
  const urlLang = new URLSearchParams(window.location.search).get('lang');
  if (urlLang === 'id' || urlLang === 'en') applyLanguage(urlLang);
  render();
</script>
