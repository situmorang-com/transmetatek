    'step2.eyebrow': 'Langkah 2 dari 4', 'step2.title': 'Apa yang sebenarnya mendorongmu', 'step2.desc': "Tidak ada pilihan yang 'benar' untuk dikejar di sini — semua pilihan tidak masalah. Jujur saja pada dirimu sendiri.",
    'drivers.q': 'Jujur pada dirimu sendiri — saat ini, mana yang <strong>paling</strong> penting bagimu, dan mana yang <strong>paling tidak</strong> penting?',
    'drivers.most': 'Paling', 'drivers.least': 'Paling tidak',
    'btn.back': 'Kembali', 'btn.next2': 'Lanjut: Situasi nyata',
    'step3.eyebrow': 'Langkah 3 dari 4', 'step3.title': 'Situasi nyata',
    'step3.desc': 'Untuk tiap situasi, tandai respons <strong>terbaik</strong> dan <strong>terburuk</strong>. Ada perbedaan nyata di antaranya.',
    'sjt.best': 'Terbaik', 'sjt.worst': 'Terburuk', 'btn.next3': 'Lanjut: Bukti',
    'step4.eyebrow': 'Langkah 4 dari 4', 'step4.title': 'Tunjukkan cara berpikirmu', 'step4.desc': 'Dua jawaban singkat. Kami baca semuanya — yang spesifik lebih bernilai daripada yang sekadar rapi.',
    'ws.label': '72 jam pertamamu', 'ws.hint': ' (min. 60 kata)',
    'ws.ph': 'Apa yang benar-benar kamu lakukan dalam 72 jam pertama? Spesifik — apa yang kamu telaah, siapa yang kamu ajak bicara, apa yang kamu rilis duluan.',
    'sl.label': 'Belajar di bawah tekanan', 'sl.hint': ' (min. 50 kata)',
    'sl.ph': 'Ceritakan saat kamu harus belajar hal sulit dengan cepat karena keadaan menuntut. Apa yang kamu lakukan, dan bagaimana kamu tahu itu berhasil?',
    'vi.label': 'Ke mana arahmu', 'vi.hint': ' (min. 40 kata)',
    'vi.ph': 'Di mana kamu ingin berada dalam 3–5 tahun, dan kenapa ini pekerjaan yang ingin kamu lakukan sekarang?',
    'nm.label': 'Kerja keras, tanpa imbalan', 'nm.hint': ' (min. 50 kata)',
    'nm.ph': 'Ceritakan saat kamu bekerja sangat keras untuk sesuatu padahal hampir tidak ada uang atau imbalannya. Apa itu, dan kenapa kamu terus bertahan?',
    'ack.text': 'Saya paham bahwa ini perjalanan pertumbuhan yang menuntut dan penuh tanggung jawab — dengan ketidakpastian, prioritas yang berubah, dan sumber daya terbatas — dan justru itulah yang saya mau. <span class="req">*</span>',
    'btn.submit': 'Kirim Profil Builder',
    'success.title': 'Profil Builder diterima',
    'success.sub': 'Terima kasih — kami membaca setiap profil builder secara langsung. Jika cocok, kami akan menghubungi untuk menjadwalkan wawancara dalam bahasa pilihanmu, biasanya dalam <strong>3–5 hari kerja</strong>.',
    'success.scoreLabel': 'Builder Score', 'success.langLabel': 'Bahasa Wawancara', 'success.back': 'Kembali ke Careers',
    'success.whatMeans': 'Apa arti skormu',
    'success.scoreBracket': '80–100: Sinyal builder kuat. 60–79: Solid secara keseluruhan, ruang untuk berkembang di satu area. 40–59: Sinyal campur — mungkin cocok dengan konteks lebih. 0–39: Profil berbeda.',
    'success.yourTraits': 'Trait builder-mu',
    'success.note': 'Ini pengamatan kami dari jawabanmu. Skor adalah satu lensa; tim kami membaca jawabanmu secara langsung untuk membuat keputusan nyata. Lihat <a href="/doc/builder-profile-applicant-guide.md" target="_blank" style="color:var(--cyan);text-decoration:underline;">panduan Builder Profile</a> untuk memahami apa arti setiap trait dan cara mengembangkannya.',
    'panel.title': 'PROFIL BUILDER', 'panel.traitTitle': 'SINYAL TRAIT',
    'panel.note': 'Ini penilaian diri tentang cara kamu membangun — tidak ada jawaban jebakan. Kami memberi bobot terbesar pada bagian situasional dan tertulis, dan membaca semuanya secara manual.',
    'word.unit': 'kata', 'word.unit1': 'kata',
  },
};
const en = C.en;  // default server render
---

<Layout
  title="Startup Builder Application | Trans Meta Teknologi"
  description="Not a job application — a builder assessment. Available in English and Bahasa Indonesia. We look for drive, ownership, startup tolerance, low ego, high standards, and long-term ambition."
>
  <Nav />

  <main id="builder-main">

    <!-- ── Hero ── -->
    <section id="builder-hero">
      <div class="hero-ambient-left"></div>
      <div class="hero-ambient-right"></div>
      <div class="container hero-content">
        <div class="tag reveal" data-i18n="hero.tag">{en['hero.tag']}</div>
        <h1 class="hero-title reveal reveal-delay-1" data-i18n-html="hero.title" set:html={en['hero.title']}></h1>
        <p class="hero-sub reveal reveal-delay-2" data-i18n-html="hero.sub" set:html={en['hero.sub']}></p>
        <div class="ai-badge reveal reveal-delay-3">
          <div class="ai-badge-dot"></div>
          <span class="ai-badge-text" data-i18n="hero.badge">{en['hero.badge']}</span>
        </div>
      </div>
    </section>

    <!-- ── Form Section ── -->
    <section id="builder-form-section">
      <div class="container form-layout">

        <!-- ─── Multi-step Form ─── -->
        <div class="form-container glass-card">

          <!-- Language toggle -->
          <div class="lang-toggle-wrap">
            <span class="lang-toggle-label" data-i18n="lang.label">{en['lang.label']}</span>
            <div class="lang-toggle" id="lang-toggle" role="group" aria-label="Language">
              <button type="button" class="lang-btn active" data-lang="en">English</button>
              <button type="button" class="lang-btn" data-lang="id">Bahasa Indonesia</button>
            </div>
          </div>

          <!-- Step Progress Bar -->
          <div class="step-progress">
            <div class="step-track"><div class="step-fill" id="step-fill"></div></div>
            <div class="steps-labels">
              {[
                { n: 1, key: 'step.you' },
                { n: 2, key: 'step.operate' },
                { n: 3, key: 'step.situations' },
                { n: 4, key: 'step.proof' },
              ].map(s => (
                <div class="step-label" data-step={s.n}>
                  <div class="step-dot">
                    <span class="step-num">{s.n}</span>
                    <svg class="step-check" width="12" height="12" viewBox="0 0 12 12" fill="none">
                      <path d="M2 6l3 3 5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </div>
                  <span class="step-name" data-i18n={s.key}>{en[s.key]}</span>
                </div>
              ))}
            </div>
          </div>

          <!-- ── Step 1: Identity ── -->
          <div class="form-step" id="step-1">
            <div class="step-header">
              <div class="step-eyebrow" data-i18n="step1.eyebrow">{en['step1.eyebrow']}</div>
              <h2 class="step-title" data-i18n="step1.title">{en['step1.title']}</h2>
              <p class="step-desc" data-i18n="step1.desc">{en['step1.desc']}</p>
            </div>

            <div class="form-fields">
              <div class="field-row">
                <div class="field-group">
                  <label class="field-label" for="fname"><span data-i18n="f.fname">{en['f.fname']}</span> <span class="req">*</span></label>
                  <input type="text" id="fname" class="field-input" data-i18n-ph="ph.fname" placeholder={en['ph.fname']} required autocomplete="given-name" />
                </div>
                <div class="field-group">
                  <label class="field-label" for="lname"><span data-i18n="f.lname">{en['f.lname']}</span> <span class="req">*</span></label>
                  <input type="text" id="lname" class="field-input" data-i18n-ph="ph.lname" placeholder={en['ph.lname']} required autocomplete="family-name" />
                </div>
              </div>

              <div class="field-group">
                <label class="field-label" for="email"><span data-i18n="f.email">{en['f.email']}</span> <span class="req">*</span></label>
                <input type="email" id="email" class="field-input" data-i18n-ph="ph.email" placeholder={en['ph.email']} required autocomplete="email" />
              </div>

              <div class="field-row">
                <div class="field-group">
                  <label class="field-label" for="city"><span data-i18n="f.city">{en['f.city']}</span> <span class="req">*</span></label>
                  <input type="text" id="city" class="field-input" data-i18n-ph="ph.city" placeholder={en['ph.city']} required />
                </div>
                <div class="field-group">
                  <label class="field-label" for="phone"><span data-i18n="f.phone">{en['f.phone']}</span> <span class="req">*</span></label>
                  <input type="tel" id="phone" class="field-input" data-i18n-ph="ph.phone" placeholder={en['ph.phone']} required autocomplete="tel" />
                </div>
              </div>

              <div class="field-group">
                <label class="field-label" for="area"><span data-i18n="f.area">{en['f.area']}</span> <span class="req">*</span></label>
                <div class="field-select-wrap">
                  <select id="area" class="field-select" required>
                    <option value="" data-i18n="f.areaPlaceholder">{en['f.areaPlaceholder']}</option>
                    {areas.map(a => <option value={a.value} data-area={a.value}>{a.en}</option>)}
                  </select>
                  <svg class="select-icon" width="14" height="14" viewBox="0 0 14 14" fill="none">
                    <path d="M3 5l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </div>
              </div>

              <div class="field-group">
                <label class="field-label"><span data-i18n="f.photo">{en['f.photo']}</span> <span class="req">*</span></label>
                <div class="photo-upload" id="photo-upload">
                  <div class="photo-preview" id="photo-preview">
                    <svg width="34" height="34" viewBox="0 0 24 24" fill="none">
                      <circle cx="12" cy="8" r="4" stroke="currentColor" stroke-width="1.5"/>
                      <path d="M4 20c0-3.3 3.6-6 8-6s8 2.7 8 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                    </svg>
                  </div>
                  <div class="photo-actions">
                    <label class="photo-btn" for="photo-input" id="photo-btn-label" data-i18n="photo.btn">{en['photo.btn']}</label>
                    <input type="file" id="photo-input" accept="image/*" hidden />
                    <span class="photo-hint" data-i18n="photo.hint">{en['photo.hint']}</span>
                  </div>
                </div>
              </div>

              <div class="field-row">
                <div class="field-group">
                  <label class="field-label" for="linkedin"><span data-i18n="f.linkedin">{en['f.linkedin']}</span> <span class="req">*</span></label>
                  <input type="url" id="linkedin" class="field-input" data-i18n-ph="ph.linkedin" placeholder={en['ph.linkedin']} required />
                </div>
                <div class="field-group">
                  <label class="field-label" for="portfolio"><span data-i18n="f.portfolio">{en['f.portfolio']}</span></label>
                  <input type="url" id="portfolio" class="field-input" data-i18n-ph="ph.portfolio" placeholder={en['ph.portfolio']} />
                </div>
              </div>
            </div>

            <div class="step-actions">
              <div></div>
              <button type="button" class="btn-primary step-next" data-next="2">
                <span data-i18n="btn.next1">{en['btn.next1']}</span>
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </button>
            </div>
          </div>

          <!-- ── Step 2: How you operate ── -->
          <div class="form-step hidden" id="step-2">
            <div class="step-header">
              <div class="step-eyebrow" data-i18n="step2.eyebrow">{en['step2.eyebrow']}</div>
              <h2 class="step-title" data-i18n="step2.title">{en['step2.title']}</h2>
              <p class="step-desc" data-i18n="step2.desc">{en['step2.desc']}</p>
            </div>

            <div class="form-fields">
              <div class="field-group">
                <label class="field-label" data-i18n-html="drivers.q" set:html={en['drivers.q']}></label>
                <div class="drivers-head">
                  <span></span>
                  <span class="drivers-col-label" data-i18n="drivers.most">{en['drivers.most']}</span>
                  <span class="drivers-col-label" data-i18n="drivers.least">{en['drivers.least']}</span>
                </div>
                <div class="drivers-list" id="drivers-list">
                  {drivers.map(d => (
                    <div class="driver-row" data-driver={d.key}>
                      <span class="driver-text">{d.en}</span>
                      <button type="button" class="driver-pick driver-most" data-kind="most" aria-label="Most"></button>
                      <button type="button" class="driver-pick driver-least" data-kind="least" aria-label="Least"></button>
                    </div>
                  ))}
                </div>
              </div>
            </div>

            <div class="step-actions">
              <button type="button" class="btn-outline step-prev" data-prev="1">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M13 8H3M7 4L3 8l4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                <span data-i18n="btn.back">{en['btn.back']}</span>
              </button>
              <button type="button" class="btn-primary step-next" data-next="3">
                <span data-i18n="btn.next2">{en['btn.next2']}</span>
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </button>
            </div>
          </div>

          <!-- ── Step 3: SJT ── -->
          <div class="form-step hidden" id="step-3">
            <div class="step-header">
              <div class="step-eyebrow" data-i18n="step3.eyebrow">{en['step3.eyebrow']}</div>
              <h2 class="step-title" data-i18n="step3.title">{en['step3.title']}</h2>
              <p class="step-desc" data-i18n-html="step3.desc" set:html={en['step3.desc']}></p>
            </div>

            <div class="form-fields">
              <div class="sjt-list" id="sjt-list">
                {sjt.map((s, si) => (
                  <div class="sjt-card" data-sjt={s.key} data-idx={si}>
                    <div class="sjt-scenario"><span class="sjt-num">{si + 1}</span><span class="sjt-scen-text">{s.en.scenario}</span></div>
                    <div class="sjt-head">
                      <span></span>
                      <span class="sjt-col-label" data-i18n="sjt.best">{en['sjt.best']}</span>
                      <span class="sjt-col-label" data-i18n="sjt.worst">{en['sjt.worst']}</span>
                    </div>
                    {s.en.options.map((opt, oi) => (
                      <div class="sjt-option" data-opt={oi}>
                        <span class="sjt-opt-text">{opt}</span>
                        <button type="button" class="sjt-pick sjt-best" data-kind="best" aria-label="Best"></button>
                        <button type="button" class="sjt-pick sjt-worst" data-kind="worst" aria-label="Worst"></button>
                      </div>
                    ))}
                  </div>
                ))}
              </div>
            </div>

            <div class="step-actions">
              <button type="button" class="btn-outline step-prev" data-prev="2">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M13 8H3M7 4L3 8l4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                <span data-i18n="btn.back">{en['btn.back']}</span>
              </button>
              <button type="button" class="btn-primary step-next" data-next="4">
                <span data-i18n="btn.next3">{en['btn.next3']}</span>
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </button>
            </div>
          </div>

          <!-- ── Step 4: Proof + commitment ── -->
          <div class="form-step hidden" id="step-4">
            <div class="step-header">
              <div class="step-eyebrow" data-i18n="step4.eyebrow">{en['step4.eyebrow']}</div>
              <h2 class="step-title" data-i18n="step4.title">{en['step4.title']}</h2>
              <p class="step-desc" data-i18n="step4.desc">{en['step4.desc']}</p>
            </div>

            <div class="form-fields">
              <div class="field-group">
                <label class="field-label" for="work-sample">
                  <span data-i18n="ws.label">{en['ws.label']}</span> <span class="req">*</span>
                  <span class="field-label-hint" data-i18n="ws.hint">{en['ws.hint']}</span>
                </label>
                <div class="scenario-box" data-i18n="__ws_scenario">{workSample.en}</div>
                <div class="textarea-wrap">
                  <textarea id="work-sample" class="field-textarea" rows="5" data-i18n-ph="ws.ph" placeholder={en['ws.ph']} required></textarea>
                  <div class="textarea-meta">
                    <span class="word-count" id="ws-count" data-count="0">0 words</span>
                    <div class="sentiment-bar" id="ws-sent"><div class="sentiment-fill"></div></div>
                  </div>
                </div>
              </div>

              <div class="field-group">
                <label class="field-label" for="story-learning">
                  <span data-i18n="sl.label">{en['sl.label']}</span> <span class="req">*</span>
                  <span class="field-label-hint" data-i18n="sl.hint">{en['sl.hint']}</span>
                </label>
                <div class="textarea-wrap">
                  <textarea id="story-learning" class="field-textarea" rows="4" data-i18n-ph="sl.ph" placeholder={en['sl.ph']} required></textarea>
                  <div class="textarea-meta">
                    <span class="word-count" id="sl-count" data-count="0">0 words</span>
                    <div class="sentiment-bar" id="sl-sent"><div class="sentiment-fill"></div></div>
                  </div>
                </div>
              </div>

              <div class="field-group">
                <label class="field-label" for="vision">
                  <span data-i18n="vi.label">{en['vi.label']}</span> <span class="req">*</span>
                  <span class="field-label-hint" data-i18n="vi.hint">{en['vi.hint']}</span>
                </label>
                <div class="textarea-wrap">
                  <textarea id="vision" class="field-textarea" rows="3" data-i18n-ph="vi.ph" placeholder={en['vi.ph']} required></textarea>
                  <div class="textarea-meta">
                    <span class="word-count" id="vi-count" data-count="0">0 words</span>
                    <div class="sentiment-bar" id="vi-sent"><div class="sentiment-fill"></div></div>
                  </div>
                </div>
              </div>

              <div class="field-group">
                <label class="field-label" for="no-money-story">
                  <span data-i18n="nm.label">{en['nm.label']}</span> <span class="req">*</span>
                  <span class="field-label-hint" data-i18n="nm.hint">{en['nm.hint']}</span>
                </label>
                <div class="textarea-wrap">
                  <textarea id="no-money-story" class="field-textarea" rows="4" data-i18n-ph="nm.ph" placeholder={en['nm.ph']} required></textarea>
                  <div class="textarea-meta">
                    <span class="word-count" id="nm-count" data-count="0">0 words</span>
                    <div class="sentiment-bar" id="nm-sent"><div class="sentiment-fill"></div></div>
                  </div>
                </div>
              </div>

              <label class="ack-box" id="ack-box">
                <input type="checkbox" id="ack" />
                <span class="ack-check">
                  <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6l3 3 5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </span>
                <span class="ack-text" data-i18n-html="ack.text" set:html={en['ack.text']}></span>
              </label>
            </div>

            <div class="step-actions">
              <button type="button" class="btn-outline step-prev" data-prev="3">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M13 8H3M7 4L3 8l4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                <span data-i18n="btn.back">{en['btn.back']}</span>
              </button>
              <button type="button" id="submit-btn" class="btn-primary">
                <span data-i18n="btn.submit">{en['btn.submit']}</span>
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M2 8l5 5 7-9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </button>
            </div>
          </div>

          <!-- ── Success Screen ── -->
          <div class="success-screen hidden" id="success-screen">
            <div class="success-icon">
              <div class="success-ring"></div>
              <svg width="36" height="36" viewBox="0 0 36 36" fill="none"><path d="M8 18l7 7 13-14" stroke="var(--cyan)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <h2 class="success-title" data-i18n="success.title">{en['success.title']}</h2>
            <p class="success-sub" data-i18n-html="success.sub" set:html={en['success.sub']}></p>
            <div class="success-stats">
              <div class="success-stat">
                <span class="success-stat-val" id="final-score">—</span>
                <span class="success-stat-label" data-i18n="success.scoreLabel">{en['success.scoreLabel']}</span>
              </div>
              <div class="success-stat-div"></div>
              <div class="success-stat">
                <span class="success-stat-val" id="final-lang">—</span>
                <span class="success-stat-label" data-i18n="success.langLabel">{en['success.langLabel']}</span>
              </div>
            </div>

            <!-- ── Score meaning + trait breakdown ── -->
            <div class="success-meaning">
              <div class="meaning-block">
                <h3 data-i18n="success.whatMeans">{en['success.whatMeans']}</h3>
                <div class="score-brackets">
                  <div class="bracket" id="score-bracket-hint">
                    <span data-i18n="success.scoreBracket" id="bracket-text">{en['success.scoreBracket']}</span>
                  </div>
                </div>
              </div>

              <div class="meaning-block">
                <h3 data-i18n="success.yourTraits">{en['success.yourTraits']}</h3>
                <div class="traits-grid" id="success-traits-grid">
                  <!-- populated from computeScores() live trait data -->
                </div>
              </div>

              <div class="meaning-block">
                <p style="font-size:0.9rem;color:var(--text-muted);" data-i18n="success.note">{en['success.note']}</p>
              </div>
            </div>

            <a href="/careers" class="btn-outline" style="margin-top:1rem;"><span data-i18n="success.back">{en['success.back']}</span></a>
          </div>

        </div><!-- /form-container -->

        <!-- ─── Builder Profile Panel (hidden from candidates until the success screen) ─── -->
        <aside class="profile-panel glass-card meter-hidden" id="profile-panel">
          <div class="profile-header">
            <div class="profile-dot"></div>
            <span class="profile-title" data-i18n="panel.title">{en['panel.title']}</span>
          </div>

