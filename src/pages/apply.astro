</style>

<script is:inline define:vars={{ roles, SKILL_CATEGORIES, SKILL_LEVELS }}>
  // ── State ──────────────────────────────────────────────────────────────
  let currentStep = 1;
  let criteriaState = { role: false, identity: false, experience: false, skills: false, portfolio: false, story: false };
  // skill name -> { skill, category, yearStarted, proficiency }
  let skillEntries = new Map();
  let currentRoleSkills = [];
  let aiMsgInterval = null;
  let photoDataUrl = null;
  let matchScore = 0;
  let pendingSkill = null; // { skill, category, checkboxEl } awaiting modal save/cancel

  const roleSkillsMap = {};
  roles.forEach(r => { roleSkillsMap[r.value] = r.skills; });

  const skillLevelWeight = {};
  SKILL_LEVELS.forEach(l => { skillLevelWeight[l.value] = l.weight; });

  const roleQuestions = {
    'senior-ml-engineer':           'Describe a time you scaled an ML model from prototype to production. What bottlenecks did you encounter?',
    'nlp-llm-specialist':           'How would you approach fine-tuning an LLM for a low-resource language like Bahasa Indonesia with limited labelled data?',
    'ai-strategy-consultant':       'Describe how you would build an AI transformation roadmap for an Indonesian bank that has zero ML infrastructure today.',
    'data-scientist':               'Walk us through how you\'d design an A/B experiment to validate a new ML-based recommendation system for an e-commerce client.',
    'computer-vision-engineer':     'How would you approach building a real-time OCR system for handwritten Bahasa Indonesia documents with inconsistent formatting?',
    'business-development-manager': 'How would you identify and close your first enterprise AI deal with an Indonesian manufacturing company that is sceptical of AI?',
    'open-application':             'What\'s the most ambitious AI project you can imagine building for Indonesia in the next 3 years? Walk us through your vision.',
  };

  const aiMessages = [
    'Waiting for application data...',
    'Parsing candidate profile...',
    'Organising skills and experience...',
    'Structuring work history...',
    'Compiling written responses...',
    'Linking portfolio and contact details...',
    'Building candidate profile graph...',
    'Formatting application for reviewer...',
    'Checking required fields...',
    'Packaging submission...',
    'Queuing for human review...',
  ];

  // ── DOM refs ────────────────────────────────────────────────────────────
  const stepFill       = document.getElementById('step-fill');
  const stepLabels     = document.querySelectorAll('.step-label');
  const gaugeFill      = document.getElementById('gauge-fill');
  const gaugePctText   = document.getElementById('gauge-pct-text');
  const aiMsgText      = document.getElementById('ai-message-text');
  const criteriaItems  = document.querySelectorAll('.criterion');
  const countNum       = document.getElementById('criteria-count-num');
  const roleSelect     = document.getElementById('role');
  const skillsContainer= document.getElementById('skills-container');
  const matchPct       = document.getElementById('skills-match-pct');
  const matchBar       = document.getElementById('skills-bar-fill');
  const roleHint       = document.getElementById('role-hint');
  const emailHint      = document.getElementById('email-hint');
  const whyHint        = document.getElementById('why-hint');

  const skillsCatalog     = document.getElementById('skills-catalog');
  const skillsSelectedCount = document.getElementById('skills-selected-count');
  const customSkillInput  = document.getElementById('custom-skill-input');
  const customSkillAdd    = document.getElementById('custom-skill-add');
  const customSkillsList  = document.getElementById('custom-skills-list');

  const skillModalOverlay = document.getElementById('skill-modal-overlay');
  const skillModalName    = document.getElementById('skill-modal-name');
  const skillModalYear    = document.getElementById('skill-modal-year');
  const skillModalLevel   = document.getElementById('skill-modal-level');
  const skillModalCancel  = document.getElementById('skill-modal-cancel');
  const skillModalSave    = document.getElementById('skill-modal-save');

  const workHistoryList     = document.getElementById('work-history-list');
  const workHistoryAdd      = document.getElementById('work-history-add');
  const workHistoryTemplate = document.getElementById('work-history-row-template');

  // ── Gauge SVG gradient ──────────────────────────────────────────────────
  const gaugeSvg = document.querySelector('.gauge-svg');
  const defs = document.createElementNS('http://www.w3.org/2000/svg', 'defs');
  const grad = document.createElementNS('http://www.w3.org/2000/svg', 'linearGradient');
  grad.setAttribute('id', 'gaugeGrad');
  grad.setAttribute('x1', '0%'); grad.setAttribute('y1', '0%');
  grad.setAttribute('x2', '100%'); grad.setAttribute('y2', '100%');
  const stop1 = document.createElementNS('http://www.w3.org/2000/svg', 'stop');
  stop1.setAttribute('offset', '0%'); stop1.setAttribute('stop-color', '#E8192C');
  const stop2 = document.createElementNS('http://www.w3.org/2000/svg', 'stop');
  stop2.setAttribute('offset', '100%'); stop2.setAttribute('stop-color', '#FF5252');
  grad.appendChild(stop1); grad.appendChild(stop2); defs.appendChild(grad);
  gaugeSvg.insertBefore(defs, gaugeSvg.firstChild);

  // ── AI message rotation ─────────────────────────────────────────────────
  function startAIMessages() {
    let idx = 0;
    aiMsgInterval && clearInterval(aiMsgInterval);
    aiMsgInterval = setInterval(() => {
      idx = (idx + 1) % aiMessages.length;
      typeMessage(aiMessages[idx]);
    }, 3200);
  }

  function typeMessage(msg) {
    if (!aiMsgText) return;
    aiMsgText.textContent = '';
    let i = 0;
    const interval = setInterval(() => {
      if (i < msg.length) {
        aiMsgText.textContent += msg[i++];
      } else {
        clearInterval(interval);
      }
    }, 28);
  }

  startAIMessages();

  // ── Step navigation ──────────────────────────────────────────────────────
  function goToStep(n) {
    const from = document.getElementById(`step-${currentStep}`);
    const to   = document.getElementById(`step-${n}`);
    if (!to) return;
    from.classList.add('hidden');
    to.classList.remove('hidden');
    currentStep = n;
    updateStepUI();
    updateScore();
  }

  function updateStepUI() {
    const pct = ((currentStep - 1) / 2) * 100 + 16.67;
    if (stepFill) stepFill.style.width = Math.min(pct, 100) + '%';

    stepLabels.forEach(el => {
      const n = parseInt(el.dataset.step);
      el.classList.remove('active', 'completed');
      if (n === currentStep) el.classList.add('active');
      if (n < currentStep)   el.classList.add('completed');
    });
  }

  updateStepUI();

  // ── Validate step ─────────────────────────────────────────────────────────
  function validateStep(n) {
    if (n === 1) {
      const role  = document.getElementById('role').value;
      const fname = document.getElementById('fname').value.trim();
      const lname = document.getElementById('lname').value.trim();
      const email = document.getElementById('email').value.trim();
      const city  = document.getElementById('city').value.trim();
      if (!role)  { shakeField('role');  return false; }
      if (!fname) { shakeField('fname'); return false; }
      if (!lname) { shakeField('lname'); return false; }
      if (!email || !email.includes('@')) { shakeField('email'); return false; }
      if (!city)  { shakeField('city');  return false; }
      if (!photoDataUrl) { shakeField('photo-upload'); return false; }
      return true;
    }
    if (n === 2) {
      const exp  = document.querySelector('input[name="experience"]:checked');
      const linkedin = document.getElementById('linkedin').value.trim();
      if (!exp)     { shakeField('exp-options'); return false; }
      if (!linkedin){ shakeField('linkedin');    return false; }
      return true;
    }
    if (n === 3) {
      const why     = document.getElementById('why-tmk').value.trim();
      const project = document.getElementById('ai-project').value.trim();
      const roleQ   = document.getElementById('role-question').value.trim();
      if (countWords(why) < 30)     { shakeField('why-tmk');      return false; }
      if (countWords(project) < 20) { shakeField('ai-project');   return false; }
      if (countWords(roleQ) < 15)   { shakeField('role-question');return false; }
      return true;
    }
    return true;
  }

