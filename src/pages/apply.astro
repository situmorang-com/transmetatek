  document.getElementById('photo-input')?.addEventListener('change', async (e) => {
    const file = e.target.files && e.target.files[0];
    e.target.value = '';
    if (!file) return;
    const upload = document.getElementById('photo-upload');
    setPhotoHint('Reading your photo…', false);

    let rawUrl = null;
    try { rawUrl = await readAsDataUrl(file); } catch (err) { console.error('[apply] photo read error:', err); }
    if (rawUrl && rawUrl.startsWith('data:image/')) {
      photoDataUrl = rawUrl;
      showPhotoPreview(rawUrl);
      upload?.classList.remove('invalid');
      setPhotoHint('A clear, recent photo of your face. JPG, PNG, or WebP.', false);
    } else {
      photoDataUrl = null;
      upload?.classList.add('invalid');
      setPhotoHint("Couldn't read that image — please try a different photo.", true);
      return;
    }

    try {
      const optimised = await fileToDataUrl(file);
      if (optimised && optimised.startsWith('data:image/')) {
        photoDataUrl = optimised;
        showPhotoPreview(optimised);
      }
    } catch (err) {
      console.warn('[apply] photo optimise skipped, keeping original:', err);
