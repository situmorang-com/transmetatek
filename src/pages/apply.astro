  function runAnalysis() {
    const overlay   = document.getElementById('analysis-overlay');
    const progressEl= document.getElementById('analysis-progress');
    const pctEl     = document.getElementById('analysis-pct');
    const msgEl     = document.getElementById('analysis-message');
    const logEl     = document.getElementById('analysis-log');
    if (!overlay) return;

    overlay.classList.remove('hidden');
    initAnalysisCanvas();
    aiMsgInterval && clearInterval(aiMsgInterval);

    // POST data to API in the background while animation plays. The candidate's
    // identity/profile is already captured here — once submitted, route them
    // straight into the shared character assessment (Stage 2) instead of a
    // terminal success screen, so the whole funnel is one continuous workflow.
    let submittedId = null;
    const submitPromise = collectFormData()
      .then(data => fetch('/api/apply', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      }))
      .then(res => res.json())
      .then(json => { if (json && json.ok && json.id) submittedId = json.id; })
      .catch(err => console.error('[apply] submit error:', err));

    let i = 0;
    function next() {
      if (i >= analysisSteps.length) {
        setTimeout(() => {
          submitPromise.finally(() => {
            if (submittedId) {
              const roleVal = document.getElementById('role').value;
              window.location.href = `/startup-builder?track=job&id=${submittedId}&role=${encodeURIComponent(roleVal)}`;
            } else {
              showSuccess();
            }
          });
        }, 600);
        return;
      }
      const s = analysisSteps[i++];
      if (progressEl) progressEl.style.width = s.pct + '%';
      if (pctEl)      pctEl.textContent = s.pct + '%';
      if (msgEl)      msgEl.textContent = s.msg;

      if (logEl && i > 1) {
        const item = document.createElement('div');
        item.className = 'analysis-log-item';
        item.textContent = analysisSteps[i - 2].msg;
        logEl.appendChild(item);
        logEl.scrollTop = logEl.scrollHeight;
      }
      setTimeout(next, i === analysisSteps.length ? 400 : 550 + Math.random() * 300);
    }
    next();
  }

  function showSuccess() {
    const overlay = document.getElementById('analysis-overlay');
    const success = document.getElementById('success-screen');
    const finalSkills = document.getElementById('final-skills');

    if (overlay) overlay.classList.add('hidden');
    if (success) success.classList.remove('hidden');

    if (finalSkills) finalSkills.textContent = String(skillEntries.size);

    // mark step-fill 100%
    if (stepFill) stepFill.style.width = '100%';
  }

  // ── Canvas neural net for analysis overlay ─────────────────────────────
  function initAnalysisCanvas() {
    const canvas = document.getElementById('analysis-canvas');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    const parent = canvas.parentElement;
    canvas.width  = parent.offsetWidth;
    canvas.height = parent.offsetHeight;
    const W = canvas.width, H = canvas.height;

    const nodes = Array.from({ length: 40 }, () => ({
      x: Math.random() * W,
      y: Math.random() * H,
      vx: (Math.random() - 0.5) * 0.4,
      vy: (Math.random() - 0.5) * 0.4,
    }));

    let running = true;

    function draw() {
      if (!running) return;
      ctx.clearRect(0, 0, W, H);
      nodes.forEach(n => {
        n.x += n.vx; n.y += n.vy;
        if (n.x < 0 || n.x > W) n.vx *= -1;
        if (n.y < 0 || n.y > H) n.vy *= -1;
      });

      for (let a = 0; a < nodes.length; a++) {
        for (let b = a + 1; b < nodes.length; b++) {
          const dx = nodes[a].x - nodes[b].x;
          const dy = nodes[a].y - nodes[b].y;
          const dist = Math.sqrt(dx * dx + dy * dy);
          if (dist < 120) {
            ctx.beginPath();
            ctx.strokeStyle = `rgba(232,25,44,${0.35 * (1 - dist / 120)})`;
            ctx.lineWidth = 0.6;
            ctx.moveTo(nodes[a].x, nodes[a].y);
            ctx.lineTo(nodes[b].x, nodes[b].y);
            ctx.stroke();
          }
        }
        ctx.beginPath();
        ctx.arc(nodes[a].x, nodes[a].y, 2, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(232,25,44,0.6)';
        ctx.fill();
      }
      requestAnimationFrame(draw);
    }

    draw();

    // Stop when success screen appears
    const observer = new MutationObserver(() => {
      const success = document.getElementById('success-screen');
      if (success && !success.classList.contains('hidden')) { running = false; observer.disconnect(); }
    });
    observer.observe(document.getElementById('success-screen'), { attributes: true });
  }

  // ── URL param: pre-select role ─────────────────────────────────────────
  function initFromURL() {
    const params = new URLSearchParams(window.location.search);
    const roleParam = params.get('role');
    if (roleParam && roleSelect) {
      const opt = Array.from(roleSelect.options).find(o => o.value === roleParam);
      if (opt) {
        roleSelect.value = roleParam;
        roleSelect.dispatchEvent(new Event('change'));
      }
    }
  }

  initFromURL();

  // ── Helpers ────────────────────────────────────────────────────────────
  function countWords(str) {
    return str.trim().split(/\s+/).filter(w => w.length > 0).length;
  }

  // ── CSS shake keyframe (injected) ───────────────────────────────────────
  const style = document.createElement('style');
  style.textContent = `
    @keyframes shake {
      0%,100%{ transform:translateX(0) }
      20%{ transform:translateX(-6px) }
      40%{ transform:translateX(6px) }
      60%{ transform:translateX(-4px) }
      80%{ transform:translateX(4px) }
    }
  `;
  document.head.appendChild(style);
</script>
