      </div>
    </section>

  </main>

  <Footer />
</Layout>

<style>
  /* ── Hero ── */
  #apply-hero {
    position: relative;
    padding: 9rem 0 5rem;
    overflow: hidden;
    border-bottom: 1px solid var(--border);
  }

  .hero-ambient-left {
    position: absolute;
    top: -10%;
    left: -5%;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(232,25,44,0.07) 0%, transparent 65%);
    pointer-events: none;
  }

  .hero-ambient-right {
    position: absolute;
    bottom: -20%;
    right: 5%;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(255,82,82,0.05) 0%, transparent 65%);
    pointer-events: none;
  }

  .hero-content { position: relative; z-index: 1; max-width: 680px; }

  .hero-title {
    font-size: clamp(2.4rem, 5vw, 4rem);
    font-weight: 700;
    line-height: 1.08;
    letter-spacing: -0.03em;
    margin: 1rem 0 1.25rem;
  }

  .gradient-text {
    background: linear-gradient(135deg, var(--cyan) 0%, #ff8080 50%, var(--purple) 100%);
    background-size: 200% auto;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: shimmer 4s linear infinite;
  }

  .hero-sub {
    font-size: 1rem;
    color: var(--text-secondary);
    line-height: 1.75;
    max-width: 500px;
    margin-bottom: 1.75rem;
  }

  .ai-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: rgba(232,25,44,0.08);
    border: 1px solid rgba(232,25,44,0.2);
    border-radius: 100px;
    padding: 0.5rem 1rem;
  }

  .ai-badge-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--cyan);
    animation: pulse-dot 1.8s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; transform: scale(1); box-shadow: 0 0 0 0 rgba(232,25,44,0.5); }
    50% { opacity: 0.8; transform: scale(1.2); box-shadow: 0 0 0 5px rgba(232,25,44,0); }
  }

  .ai-badge-text {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--cyan);
    letter-spacing: 0.04em;
  }

  /* ── Form Layout ── */
  #apply-form-section {
    padding: 5rem 0 8rem;
  }

  .form-layout {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 2rem;
    align-items: start;
  }

  /* ── Form Container ── */
  .form-container {
    position: relative;
    padding: 2.5rem 2.5rem 2rem;
    min-height: 540px;
    overflow: hidden;
  }

  /* ── Step Progress ── */
  .step-progress {
    margin-bottom: 2.5rem;
  }

  .step-track {
    height: 2px;
    background: rgba(255,255,255,0.06);
    border-radius: 2px;
    margin-bottom: 1.25rem;
    overflow: hidden;
  }

  .step-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--cyan), var(--purple));
    border-radius: 2px;
    width: 33.33%;
    transition: width 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .steps-labels {
    display: flex;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .step-label {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    cursor: default;
  }

  .step-dot {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 1.5px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg-card);
    transition: all 0.3s ease;
    position: relative;
  }

  .step-num {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-muted);
    transition: opacity 0.2s;
  }

  .step-check {
    position: absolute;
    opacity: 0;
    transition: opacity 0.2s;
    color: var(--bg-primary);
  }

  .step-label.active .step-dot {
    border-color: var(--cyan);
    background: rgba(232,25,44,0.15);
  }

  .step-label.active .step-num { color: var(--cyan); }

  .step-label.completed .step-dot {
    background: var(--cyan);
    border-color: var(--cyan);
  }

  .step-label.completed .step-num { opacity: 0; }
  .step-label.completed .step-check { opacity: 1; }

  .step-name {
    font-size: 0.7rem;
    font-family: var(--font-mono);
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    transition: color 0.3s;
  }

  .step-label.active .step-name { color: var(--text-secondary); }
  .step-label.completed .step-name { color: var(--text-muted); }

  /* ── Form Step ── */
  .form-step { animation: stepIn 0.4s ease both; }
  .form-step.hidden { display: none; }

  @keyframes stepIn {
    from { opacity: 0; transform: translateX(16px); }
    to   { opacity: 1; transform: translateX(0); }
  }

  .step-header { margin-bottom: 2rem; }

  .step-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--cyan);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 0.5rem;
  }

  .step-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: -0.02em;
    margin-bottom: 0.4rem;
  }

  .step-desc {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  /* ── Form Fields ── */
  .form-fields {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .field-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .field-group { display: flex; flex-direction: column; gap: 0.4rem; }

  /* ── Photo upload ── */
  .photo-upload { display: flex; align-items: center; gap: 1.1rem; padding: 1rem; border: 1px solid var(--border); border-radius: 10px; background: rgba(255,255,255,0.02); }
  .photo-upload.invalid { border-color: rgba(232,25,44,0.5); }
  .photo-preview { flex-shrink: 0; width: 64px; height: 64px; border-radius: 50%; overflow: hidden; display: flex; align-items: center; justify-content: center; border: 1.5px solid var(--border); background: rgba(232,25,44,0.06); color: var(--text-muted); }
  .photo-preview.filled { border-color: var(--cyan); box-shadow: 0 0 14px rgba(232,25,44,0.18); }
  .photo-actions { display: flex; flex-direction: column; gap: 0.5rem; align-items: flex-start; }
  .photo-btn { display: inline-flex; align-items: center; gap: 0.4rem; padding: 0.45rem 1rem; border-radius: 8px; border: 1px solid var(--cyan-glow); background: transparent; color: var(--cyan); font-family: var(--font-sans); font-size: 0.82rem; font-weight: 600; cursor: pointer; transition: background 0.2s ease; }
  .photo-btn:hover { background: var(--cyan-dim); }
  .photo-hint { font-size: 0.72rem; color: var(--text-muted); line-height: 1.4; }
  .photo-hint.photo-hint-error { color: #FF6B6B; }

  @media (max-width: 640px) {
    .photo-upload { flex-direction: column; align-items: flex-start; gap: 0.85rem; }
  }

  .field-label {
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--text-secondary);
    letter-spacing: 0.01em;
  }

  .field-label-hint {
    font-weight: 400;
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 0.72rem;
  }

  .req { color: var(--cyan); }

  .field-input,
  .field-select,
  .field-textarea {
    background: rgba(255,255,255,0.03);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.65rem 0.875rem;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    color: var(--text-primary);
    outline: none;
    transition: border-color 0.2s ease, background 0.2s ease, box-shadow 0.2s ease;
    width: 100%;
  }

  .field-input::placeholder,
  .field-textarea::placeholder { color: var(--text-muted); }

  .field-input:focus,
  .field-select:focus,
  .field-textarea:focus {
    border-color: rgba(232,25,44,0.4);
    background: rgba(232,25,44,0.04);
    box-shadow: 0 0 0 3px rgba(232,25,44,0.08);
  }

  .field-input.valid { border-color: rgba(16,185,129,0.4); }
  .field-input.invalid, .field-select.invalid { border-color: rgba(232,25,44,0.5); }

  .field-select-wrap { position: relative; }

  .field-select {
    appearance: none;
    cursor: pointer;
    padding-right: 2.5rem;
  }

  .field-select option { background: #1a0404; color: var(--text-primary); }

  .select-icon {
