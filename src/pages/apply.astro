---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { ROLES, SKILL_CATEGORIES, SKILL_LEVELS } from '../lib/skills';

const roles = ROLES;
const currentYear = new Date().getFullYear();
const skillYears: number[] = [];
for (let y = currentYear; y >= 1990; y--) skillYears.push(y);
---

<Layout
  title="Apply | Trans Meta Teknologi"
  description="Apply to join Indonesia's AI team at Trans Meta Teknologi. Our AI-assisted screening process helps us find the best candidates fast."
>
  <Nav />

  <main id="apply-main">

    <!-- ── Hero ── -->
    <section id="apply-hero">
      <div class="hero-ambient-left"></div>
      <div class="hero-ambient-right"></div>
      <div class="container hero-content">
        <div class="tag reveal">// AI-Assisted Screening</div>
        <h1 class="hero-title reveal reveal-delay-1">
          Apply to <span class="gradient-text">Trans Meta</span><br />Teknologi
        </h1>
        <p class="hero-sub reveal reveal-delay-2">
          Our AI screening system reviews every application in real-time,
          matching your skills and experience against what we need most.
          No black boxes — you'll see exactly how you score.
        </p>
        <div class="ai-badge reveal reveal-delay-3">
          <div class="ai-badge-dot"></div>
          <span class="ai-badge-text">AI Screening Active — Analysing candidates now</span>
        </div>
      </div>
    </section>

    <!-- ── Form Section ── -->
    <section id="apply-form-section">
      <div class="container form-layout">

        <!-- ─── Multi-step Form ─── -->
        <div class="form-container glass-card">

          <!-- Step Progress Bar -->
          <div class="step-progress">
            <div class="step-track">
              <div class="step-fill" id="step-fill"></div>
            </div>
            <div class="steps-labels">
              {[
                { n: 1, label: 'Identity' },
                { n: 2, label: 'Experience' },
                { n: 3, label: 'Your Story' },
              ].map(s => (
                <div class={`step-label`} data-step={s.n}>
                  <div class="step-dot">
                    <span class="step-num">{s.n}</span>
                    <svg class="step-check" width="12" height="12" viewBox="0 0 12 12" fill="none">
                      <path d="M2 6l3 3 5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </div>
                  <span class="step-name">{s.label}</span>
                </div>
              ))}
            </div>
          </div>

          <!-- ── Step 1: Identity ── -->
          <div class="form-step" id="step-1">
            <div class="step-header">
              <div class="step-eyebrow">Step 1 of 3</div>
              <h2 class="step-title">Tell us who you are</h2>
              <p class="step-desc">The AI will start building your candidate profile as you fill this in.</p>
            </div>

            <div class="form-fields">
              <div class="field-group">
                <label class="field-label" for="role">Role you're applying for <span class="req">*</span></label>
                <div class="field-select-wrap">
                  <select id="role" name="role" class="field-select" required>
                    <option value="">— Select a role —</option>
                    {roles.map(r => (
                      <option value={r.value} data-dept={r.dept}>{r.label}</option>
                    ))}
                  </select>
                  <svg class="select-icon" width="14" height="14" viewBox="0 0 14 14" fill="none">
                    <path d="M3 5l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </div>
                <div class="field-ai-hint" id="role-hint"></div>
              </div>

              <div class="field-row">
                <div class="field-group">
                  <label class="field-label" for="fname">First name <span class="req">*</span></label>
                  <input type="text" id="fname" name="fname" class="field-input" placeholder="Budi" required autocomplete="given-name" />
                </div>
                <div class="field-group">
                  <label class="field-label" for="lname">Last name <span class="req">*</span></label>
                  <input type="text" id="lname" name="lname" class="field-input" placeholder="Santoso" required autocomplete="family-name" />
                </div>
              </div>

              <div class="field-group">
                <label class="field-label" for="email">Email address <span class="req">*</span></label>
                <input type="email" id="email" name="email" class="field-input" placeholder="budi@example.com" required autocomplete="email" />
                <div class="field-ai-hint" id="email-hint"></div>
              </div>

              <div class="field-row">
                <div class="field-group">
                  <label class="field-label" for="city">City / Location <span class="req">*</span></label>
                  <input type="text" id="city" name="city" class="field-input" placeholder="Jakarta" required />
                </div>
                <div class="field-group">
                  <label class="field-label" for="phone">Phone</label>
                  <input type="tel" id="phone" name="phone" class="field-input" placeholder="0812 345 6789" autocomplete="tel" inputmode="numeric" />
                </div>
              </div>

              <div class="field-group">
                <label class="field-label">Profile picture <span class="req">*</span></label>
                <div class="photo-upload" id="photo-upload">
                  <div class="photo-preview" id="photo-preview">
                    <svg width="34" height="34" viewBox="0 0 24 24" fill="none">
                      <circle cx="12" cy="8" r="4" stroke="currentColor" stroke-width="1.5"/>
                      <path d="M4 20c0-3.3 3.6-6 8-6s8 2.7 8 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                    </svg>
                  </div>
                  <div class="photo-actions">
                    <label class="photo-btn" for="photo-input" id="photo-btn-label">Upload photo</label>
                    <input type="file" id="photo-input" accept="image/*" hidden />
                    <span class="photo-hint" id="photo-hint">A clear, recent photo of your face. JPG, PNG, or WebP.</span>
                  </div>
                </div>
              </div>
            </div>

            <div class="step-actions">
              <div></div>
              <button type="button" class="btn-primary step-next" data-next="2">
                <span>Next: Your Experience</span>
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                  <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
            </div>
          </div>

          <!-- ── Step 2: Experience ── -->
          <div class="form-step hidden" id="step-2">
            <div class="step-header">
              <div class="step-eyebrow">Step 2 of 3</div>
              <h2 class="step-title">Your background</h2>
              <p class="step-desc">The AI matches your skills against the role requirements in real-time.</p>
            </div>

            <div class="form-fields">
              <div class="field-group">
                <label class="field-label">Years of relevant experience <span class="req">*</span></label>
                <div class="exp-options" id="exp-options">
                  {[
                    { value: '0-2',  label: '0–2 yrs',  sub: 'Early career' },
                    { value: '3-5',  label: '3–5 yrs',  sub: 'Mid-level' },
                    { value: '5-10', label: '5–10 yrs', sub: 'Senior' },
                    { value: '10+',  label: '10+ yrs',  sub: 'Lead / Principal' },
                  ].map(e => (
                    <label class="exp-option">
                      <input type="radio" name="experience" value={e.value} />
                      <div class="exp-card">
                        <span class="exp-val">{e.label}</span>
                        <span class="exp-sub">{e.sub}</span>
                      </div>
                    </label>
                  ))}
                </div>
              </div>

              <div class="field-group">
                <label class="field-label">
                  Skills &amp; technologies
                  <span class="field-label-hint"> — select all that apply</span>
                </label>
                <div class="skills-container" id="skills-container">
                  <p class="skills-placeholder">← Select a role first to see relevant skills</p>
                </div>
                <div class="skills-match-bar">
                  <div class="skills-match-label">
                    <span>Role match</span>
                    <span id="skills-match-pct">0%</span>
                  </div>
                  <div class="skills-bar-track">
                    <div class="skills-bar-fill" id="skills-bar-fill"></div>
                  </div>
                </div>

                <div class="skills-tip" id="skills-tip">
                  💡 <strong>Tip:</strong> pick the skills above, or check more from the full catalog below. For each
                  skill you'll be asked when you started using it and how proficient you are — this helps us understand
                  your technical background beyond a yes/no checklist.
                </div>

                <div class="skills-selected-status" id="skills-selected-status">
                  ✓ Skills selected: <strong id="skills-selected-count">0</strong> skill(s) selected
                </div>

                <div class="skills-catalog" id="skills-catalog">
                  {Object.entries(SKILL_CATEGORIES).map(([category, catSkills]) => (
                    <div class="skill-category">
                      <div class="skill-category-title">{category}</div>
                      <div class="skill-category-grid" data-category={category}>
                        {catSkills.map(skill => (
                          <label class="skill-check">
                            <input type="checkbox" class="skill-checkbox" data-skill={skill} data-category={category} />
                            <span class="skill-check-box"></span>
                            <span class="skill-check-dot"></span>
                            <span class="skill-check-label">{skill}</span>
                            <span class="skill-check-years"></span>
                          </label>
                        ))}
                      </div>
                    </div>
                  ))}

                  <div class="custom-skill-row">
                    <input type="text" id="custom-skill-input" class="field-input" placeholder="Don't see your skill? Type it here..." />
                    <button type="button" class="btn-outline" id="custom-skill-add">Add skill</button>
                  </div>
                  <div class="custom-skills-list" id="custom-skills-list"></div>
                </div>
              </div>

              <div class="field-row">
                <div class="field-group">
                  <label class="field-label" for="linkedin">LinkedIn profile <span class="req">*</span></label>
                  <input type="url" id="linkedin" name="linkedin" class="field-input" placeholder="linkedin.com/in/yourname" required />
                </div>
                <div class="field-group">
                  <label class="field-label" for="portfolio">Portfolio / GitHub</label>
                  <input type="url" id="portfolio" name="portfolio" class="field-input" placeholder="github.com/yourname" />
                </div>
              </div>

              <div class="field-group">
                <label class="field-label">Current or most recent organisation</label>
                <div class="field-row">
                  <div class="field-group">
                    <label class="field-label" for="current-org-company">Company</label>
                    <input type="text" id="current-org-company" class="field-input" placeholder="e.g. Gojek, Tokopedia, Telkom" />
                  </div>
                  <div class="field-group">
                    <label class="field-label" for="current-org-position">Position</label>
                    <input type="text" id="current-org-position" class="field-input" placeholder="e.g. Data Analyst" />
                  </div>
                </div>
                <div class="field-row">
                  <div class="field-group">
                    <label class="field-label" for="current-org-start">Start date</label>
                    <input type="month" id="current-org-start" class="field-input" />
                  </div>
                  <div class="field-group">
                    <label class="field-label" for="current-org-end">End date</label>
                    <input type="month" id="current-org-end" class="field-input" />
                  </div>
                </div>
                <label class="wh-current-check">
                  <input type="checkbox" id="current-org-current" />
                  <span>I currently work here</span>
                </label>
              </div>

              <div class="field-row">
                <div class="field-group">
                  <label class="field-label" for="current-salary">Current salary</label>
                  <div class="money-input-wrap">
                    <span class="money-prefix">Rp.</span>
                    <input type="text" id="current-salary" name="current-salary" class="field-input money-input" placeholder="15,000,000" inputmode="numeric" />
                  </div>
                </div>
                <div class="field-group">
                  <label class="field-label" for="expected-salary">Expected salary</label>
                  <div class="money-input-wrap">
                    <span class="money-prefix">Rp.</span>
                    <input type="text" id="expected-salary" name="expected-salary" class="field-input money-input" placeholder="20,000,000" inputmode="numeric" />
                  </div>
                </div>
              </div>

              <div class="field-group">
                <div class="work-history-header">
                  <label class="field-label">Work history <span class="field-label-hint">— add as many as you like</span></label>
                  <button type="button" class="btn-outline btn-sm" id="work-history-add">+ Add role</button>
                </div>
                <div id="work-history-list"></div>
              </div>
            </div>

            <div class="step-actions">
              <button type="button" class="btn-outline step-prev" data-prev="1">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                  <path d="M13 8H3M7 4L3 8l4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span>Back</span>
              </button>
              <button type="button" class="btn-primary step-next" data-next="3">
                <span>Next: Your Story</span>
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                  <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
            </div>
          </div>

          <!-- ── Step 3: Story ── -->
          <div class="form-step hidden" id="step-3">
            <div class="step-header">
              <div class="step-eyebrow">Step 3 of 3</div>
              <h2 class="step-title">Your story</h2>
              <p class="step-desc">Our AI analyses response clarity, depth, and alignment with our mission. Write naturally.</p>
            </div>

            <div class="form-fields">
              <div class="field-group">
                <label class="field-label" for="why-tmk">
                  Why do you want to build AI for Indonesia? <span class="req">*</span>
                  <span class="field-label-hint"> (min 80 words)</span>
                </label>
                <div class="textarea-wrap">
                  <textarea id="why-tmk" name="why-tmk" class="field-textarea" rows="4"
                    placeholder="Tell us what drives you about Indonesia's AI opportunity and why Trans Meta Teknologi is where you want to build it..."
                    required></textarea>
                  <div class="textarea-meta">
                    <span class="word-count" id="why-count">0 words</span>
                    <div class="sentiment-bar" id="why-sentiment">
                      <div class="sentiment-fill"></div>
                    </div>
                  </div>
                </div>
                <div class="field-ai-hint" id="why-hint"></div>
              </div>

              <div class="field-group">
                <label class="field-label" for="ai-project">
                  Describe an AI project you're most proud of <span class="req">*</span>
                  <span class="field-label-hint"> (min 60 words)</span>
                </label>
                <div class="textarea-wrap">
                  <textarea id="ai-project" name="ai-project" class="field-textarea" rows="4"
                    placeholder="What did you build, what was the impact, and what did you learn?"
                    required></textarea>
                  <div class="textarea-meta">
                    <span class="word-count" id="project-count">0 words</span>
                    <div class="sentiment-bar" id="project-sentiment">
                      <div class="sentiment-fill"></div>
                    </div>
                  </div>
                </div>
              </div>

              <div class="field-group">
                <label class="field-label" for="role-question" id="role-question-label">
                  Role-specific question <span class="req">*</span>
                </label>
                <div class="textarea-wrap">
                  <textarea id="role-question" name="role-question" class="field-textarea" rows="3"
                    placeholder="Loading role-specific question..."
                    required></textarea>
                  <div class="textarea-meta">
                    <span class="word-count" id="role-q-count">0 words</span>
                    <div class="sentiment-bar" id="role-q-sentiment">
                      <div class="sentiment-fill"></div>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <div class="step-actions">
              <button type="button" class="btn-outline step-prev" data-prev="2">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                  <path d="M13 8H3M7 4L3 8l4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span>Back</span>
              </button>
              <button type="button" id="submit-btn" class="btn-primary btn-submit">
                <span>Submit Application</span>
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                  <path d="M2 8l5 5 7-9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
            </div>
          </div>

          <!-- ── Analysis Overlay ── -->
          <div class="analysis-overlay hidden" id="analysis-overlay">
            <canvas id="analysis-canvas"></canvas>
            <div class="analysis-content">
              <div class="analysis-logo">
                <div class="analysis-ring ring-1"></div>
                <div class="analysis-ring ring-2"></div>
                <div class="analysis-ring ring-3"></div>
                <div class="analysis-core">
                  <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
                    <circle cx="14" cy="14" r="5" fill="var(--cyan)" opacity="0.9"/>
                    <path d="M14 2v4M14 22v4M2 14h4M22 14h4" stroke="var(--cyan)" stroke-width="2" stroke-linecap="round"/>
                    <path d="M5.5 5.5l2.8 2.8M19.7 19.7l2.8 2.8M5.5 22.5l2.8-2.8M19.7 8.3l2.8-2.8" stroke="var(--cyan)" stroke-width="1.5" stroke-linecap="round" opacity="0.5"/>
                  </svg>
                </div>
              </div>
              <div class="analysis-title">AI Analysis in Progress</div>
              <div class="analysis-message" id="analysis-message">Initialising screening engine...</div>
              <div class="analysis-progress-wrap">
                <div class="analysis-progress-track">
                  <div class="analysis-progress-fill" id="analysis-progress"></div>
                </div>
                <span class="analysis-pct" id="analysis-pct">0%</span>
              </div>
              <div class="analysis-log" id="analysis-log"></div>
            </div>
          </div>

          <!-- ── Success Screen ── -->
          <div class="success-screen hidden" id="success-screen">
            <div class="success-icon">
              <div class="success-ring"></div>
              <svg width="36" height="36" viewBox="0 0 36 36" fill="none">
                <path d="M8 18l7 7 13-14" stroke="var(--cyan)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h2 class="success-title">Application Received</h2>
            <p class="success-sub">
              Your profile is queued for human review. You'll hear from us within
              <strong>3–5 business days</strong> — often sooner.
            </p>
            <div class="success-stats" id="success-stats">
              <div class="success-stat">
                <span class="success-stat-val" id="final-skills">—</span>
                <span class="success-stat-label">Skills Listed</span>
              </div>
              <div class="success-stat-div"></div>
              <div class="success-stat">
                <span class="success-stat-val">✓ Queued</span>
                <span class="success-stat-label">Review Status</span>
              </div>
            </div>
            <a href="/careers" class="btn-outline" style="margin-top:1rem;">
              <span>Back to Careers</span>
            </a>
          </div>

        </div><!-- /form-container -->

        <!-- ── Skill Details Modal ── -->
        <div class="skill-modal-overlay hidden" id="skill-modal-overlay">
          <div class="skill-modal">
            <div class="skill-modal-title">Skill Details: <span id="skill-modal-name"></span></div>
            <div class="field-group">
              <label class="field-label" for="skill-modal-year">Year started using this skill <span class="req">*</span></label>
              <input type="text" id="skill-modal-year" class="field-input" placeholder="YYYY" inputmode="numeric" maxlength="4" list="skill-year-options" autocomplete="off" required />
              <datalist id="skill-year-options">
                {skillYears.map(y => <option value={y}></option>)}
              </datalist>
            </div>
            <div class="field-group">
              <label class="field-label" for="skill-modal-level">Proficiency level <span class="req">*</span></label>
              <div class="field-select-wrap">
                <select id="skill-modal-level" class="field-select">
                  <option value="">— Select level —</option>
                  {SKILL_LEVELS.map(l => <option value={l.value}>{l.label}</option>)}
                </select>
                <svg class="select-icon" width="14" height="14" viewBox="0 0 14 14" fill="none">
                  <path d="M3 5l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
            </div>
            <div class="skill-modal-actions">
              <button type="button" class="btn-outline" id="skill-modal-cancel">Cancel</button>
              <button type="button" class="btn-primary" id="skill-modal-save">Save</button>
            </div>
          </div>
        </div>

        <!-- ── Work History Row Template ── -->
        <template id="work-history-row-template">
          <div class="work-history-row">
            <button type="button" class="work-history-remove" title="Remove">
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 2l8 8M10 2l-8 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            </button>
            <div class="field-row">
              <div class="field-group">
                <label class="field-label">Company</label>
                <input type="text" class="field-input wh-company" placeholder="e.g. Gojek" />
              </div>
              <div class="field-group">
                <label class="field-label">Position</label>
                <input type="text" class="field-input wh-position" placeholder="e.g. Data Analyst" />
              </div>
            </div>
            <div class="field-row">
              <div class="field-group">
                <label class="field-label">Start date</label>
                <input type="month" class="field-input wh-start" />
              </div>
              <div class="field-group">
                <label class="field-label">End date</label>
                <input type="month" class="field-input wh-end" />
              </div>
            </div>
            <label class="wh-current-check">
              <input type="checkbox" class="wh-current" />
              <span class="wh-current-label">I currently work here</span>
            </label>
            <div class="field-group wh-reason-group">
              <label class="field-label">Reason for leaving</label>
              <input type="text" class="field-input wh-reason" placeholder="e.g. Looking for new challenges, company restructuring..." />
            </div>
            <div class="field-group">
              <label class="field-label">Salary at this role</label>
              <div class="money-input-wrap">
                <span class="money-prefix">Rp.</span>
                <input type="text" class="field-input money-input wh-salary" placeholder="15,000,000" inputmode="numeric" />
              </div>
            </div>
            <div class="field-group">
              <label class="field-label">What did you work on?</label>
              <textarea class="field-textarea wh-description" rows="2" placeholder="Brief description of your role and impact..."></textarea>
            </div>
          </div>
        </template>

        <!-- ─── AI Panel ─── -->
        <aside class="ai-panel glass-card">
          <div class="ai-panel-header">
            <div class="ai-status-dot"></div>
            <span class="ai-panel-title">APPLICATION PROGRESS</span>
          </div>

          <!-- Score Gauge -->
          <div class="gauge-wrap">
            <svg class="gauge-svg" viewBox="0 0 120 120">
              <circle class="gauge-track"    cx="60" cy="60" r="50" />
              <circle class="gauge-fill"     cx="60" cy="60" r="50" id="gauge-fill" />
              <text class="gauge-pct"  x="60" y="54" text-anchor="middle" dominant-baseline="middle" id="gauge-pct-text">0%</text>
              <text class="gauge-label" x="60" y="70" text-anchor="middle">Completeness</text>
            </svg>
          </div>

          <!-- Criteria Checklist -->
          <div class="criteria-section">
            <div class="criteria-title">PROFILE CHECKLIST</div>
