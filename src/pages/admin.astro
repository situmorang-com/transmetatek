---
import Layout from '../layouts/Layout.astro';
import { db } from '../db';
import { applications, internships, builderApplications } from '../db/schema';
import { desc } from 'drizzle-orm';

// Labels for the builder tab
const TRAIT_LABELS: Record<string, string> = {
  drive: 'Drive', growth: 'Growth', ownership: 'Ownership',
  tolerance: 'Tolerance', ego: 'Low Ego', ambition: 'Ambition', loyalty: 'Loyalty',
};
const LANG_LABELS: Record<string, string> = { id: '🇮🇩 Indonesian', en: '🇬🇧 English' };
const DRIVER_LABELS: Record<string, string> = {
  build: 'Build something lasting', learn: 'Get better fast', own: 'Own big things',
  money: 'Earn well soon', status: 'Title & recognition', comfort: 'Comfort & stability',
};
const TRAIT_GUIDE: Record<string, string> = {
  drive: '▪ What it is: Keeps grinding on hard, unglamorous work without being chased. Real intrinsic motivation, not just pay/status. ▪ Strong (80+): Chooses boring work, describes "worked hard for no money" with specificity & joy. ▪ Weak (0–40): Avoids unglamorous tasks, vague on why they\'d keep going without reward. ▪ Red flags: "I do it because my boss told me to" or "if pay stopped, I\'d leave." ▪ Interview: Ask "Tell me about the most boring work you\'ve done that actually mattered. Why did you finish it?" ▪ In writing: Look for specificity—what was the task, why did it matter, what did they actually do?',
  growth: '▪ What it is: Learns fast & independently. Doesn\'t wait for training courses; runs toward things they can\'t do yet. ▪ Strong (80+): Digs into docs, ships something fast, measures success concretely. ▪ Weak (0–40): Waited for formal training, or doesn\'t have examples of self-directed learning. ▪ Red flags: "I watched YouTube but didn\'t ship anything" or "I waited for proper training." ▪ Interview: Ask "When have you had to learn something hard, fast, because the deadline was real? What did you actually do?" ▪ In writing: Urgency signals real learning. Look for: problem → tried → shipped → measured.',
  ownership: '▪ What it is: Treats problems as theirs even when "not my job." Finds a way instead of waiting for permission. ▪ Strong (80+): Solves problems proactively, moves forward under ambiguity, doesn\'t wait for clarity. ▪ Weak (0–40): Waits for instruction, reports problems and leaves them, "that\'s not my responsibility." ▪ Red flags: "I told my boss and waited" or "I focused on my own work." ▪ Interview: Ask "Tell me about a time you solved a problem that wasn\'t formally yours. Why did you own it?" ▪ In writing: Real ownership means no excuses, no blame-shifting. "I saw X was broken, I fixed it, I told my boss."',
  tolerance: '▪ What it is: Comfortable with ambiguity, changing priorities, limited resources. Doesn\'t crumble. ▪ Strong (80+): Shifts priorities mid-week without resentment, sees constraints as creative problems, focuses on what matters now. ▪ Weak (0–40): Panics when plans change, gets frustrated, assumes perfect conditions. ▪ Red flags: "I hate changing priorities" or answers that assume stable, clear, well-resourced conditions. ▪ Interview: Ask "What happens when the company changes priorities mid-week and kills your project? How do you feel?" Listen for acceptance, not resentment. ▪ In writing: Do they adapt or resist? Do they focus on sunk costs or on what\'s next?',
  ego: '▪ What it is: Takes hard feedback without defending. Credits others. Refuses to ship junk. ▪ Strong (80+): Actively seeks critical feedback, credits collaborators, owns mistakes directly. ▪ Weak (0–40): Defends when criticized, centers themselves, ships without quality bar. ▪ Red flags: "Everyone else was wrong" or "I\'d ship it and fix it later" (without holding a bar). ▪ Interview: Ask "Tell me about a time a junior or peer pointed out a real flaw in your work. How did you respond?" ▪ In writing: Do they credit others? When they describe a mistake, do they own it directly?',
  ambition: '▪ What it is: Finishes what they start. Builds things that last. Not distracted by shiny. Has a real reason they\'re here *now*. ▪ Strong (80+): Specific vision (not generic), has shipped/completed things, why this work not just any startup. ▪ Weak (0–40): "I jump between interests" or "I want to grow and learn" (everyone says that). ▪ Red flags: No track record of follow-through, generic vision, or jumping every year. ▪ Interview: Ask "Where do you want to be in 5 years? Why is this the work you want to do *now*?" Generic answers = weak ambition. ▪ In writing: Concrete ≠ generic. "Ship AI for Indonesia" beats "work on cool projects."',
  loyalty: '▪ What it is: Stays & digs in through hard times, not poached for small raises. Mission/team invested, not just paycheck. ▪ Strong (80+): Chooses loyalty even when competitor+40%, stays in rough quarters, mission/team talk. ▪ Weak (0–40): Takes competitor offer, leaves in downturns, "salary is the main thing." ▪ Red flags: Money is top driver, loyalty scenarios answered money-first, "I go where the best opportunity is." ▪ Interview: Ask "If a competitor offered you 40% more after we\'ve trained you, what would you do?" and "What would make you stay if things got hard?" ▪ In writing: Do they talk mission/team or just pay/title?',
};

// ── Auth: require ?token=ADMIN_TOKEN or Authorization header ──────────────────
const adminToken = import.meta.env.ADMIN_TOKEN;

if (!adminToken) {
  return new Response('ADMIN_TOKEN env var not set.', { status: 500 });
}

const url   = new URL(Astro.request.url);
const token = url.searchParams.get('token')
           ?? Astro.request.headers.get('x-admin-token');

if (token !== adminToken) {
  return new Response('Unauthorized', { status: 401 });
}

// ── Fetch data ────────────────────────────────────────────────────────────────
const apps   = await db.select().from(applications).orderBy(desc(applications.createdAt));
const interns= await db.select().from(internships) .orderBy(desc(internships.createdAt));
const builders = await db.select().from(builderApplications).orderBy(desc(builderApplications.createdAt));

// Keep token in links so navigation stays authenticated
const t = `?token=${encodeURIComponent(adminToken)}`;
---

<Layout
  title="Admin — Trans Meta Teknologi"
  description="Internal admin dashboard"
>
  <main id="admin-main">
    <div class="admin-container">

      <!-- Header -->
      <div class="admin-header">
        <div class="admin-logo">
          <div class="admin-logo-dot"></div>
          <span>TransMetaTek Admin</span>
        </div>
        <div class="admin-meta">
          <span class="admin-badge">{apps.length} applications</span>
          <span class="admin-badge">{interns.length} internships</span>
          <span class="admin-badge">{builders.length} builders</span>
        </div>
      </div>

      <!-- Tabs -->
      <div class="admin-tabs">
        <button class="admin-tab active" data-tab="applications">
          Job Applications
          <span class="tab-count">{apps.length}</span>
        </button>
        <button class="admin-tab" data-tab="internships">
          Internship Applications
          <span class="tab-count">{interns.length}</span>
        </button>
        <button class="admin-tab" data-tab="builders">
          Startup Builders
          <span class="tab-count">{builders.length}</span>
        </button>
      </div>

      <!-- ── Job Applications Tab ── -->
      <div class="tab-panel" id="tab-applications">
        {apps.length === 0 ? (
          <div class="empty-state">No applications yet.</div>
        ) : (
          <div class="table-scroll">
            <table class="admin-table">
              <thead>
                <tr>
                  <th>#</th>
                  <th>Name</th>
                  <th>Email</th>
                  <th>Role</th>
                  <th>Exp</th>
                  <th>Skills</th>
                  <th>Score</th>
                  <th>LinkedIn</th>
                  <th>Submitted</th>
                  <th></th>
                </tr>
              </thead>
              <tbody>
                {apps.map(a => (
                  <tr class="app-row" data-id={a.id}>
                    <td class="td-id">{a.id}</td>
                    <td class="td-name">
                      <div class="name-cell">
                        <span class="name-initials">{a.firstName[0]}{a.lastName[0]}</span>
                        <span>{a.firstName} {a.lastName}</span>
                      </div>
                    </td>
                    <td><a href={`mailto:${a.email}`} class="td-link">{a.email}</a></td>
                    <td>
                      <span class={`role-badge role-${a.role}`}>
                        {a.role.replace(/-/g, ' ')}
                      </span>
                    </td>
                    <td class="td-mono">{a.experience}</td>
                    <td class="td-skills">
                      {JSON.parse(a.skills ?? '[]').slice(0, 4).map((s: string) => (
                        <span class="skill-tag">{s}</span>
                      ))}
                    </td>
                    <td>
                      <div class={`score-cell score-${Math.round((a.matchScore ?? 0) / 25)}`}>
                        {a.matchScore ?? '—'}
                        {a.matchScore ? '%' : ''}
                      </div>
                    </td>
                    <td>
                      {a.linkedin
                        ? <a href={a.linkedin.startsWith('http') ? a.linkedin : `https://${a.linkedin}`}
                            target="_blank" rel="noopener" class="td-link">View ↗</a>
                        : <span class="td-muted">—</span>
                      }
                    </td>
                    <td class="td-mono td-date">{new Date(a.createdAt).toLocaleDateString('en-GB', { day:'2-digit', month:'short', year:'numeric' })}</td>
                    <td>
                      <button class="btn-expand" data-app-id={a.id}>
                        <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                          <path d="M3 5l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      </button>
                    </td>
                  </tr>
                  <tr class="detail-row hidden" id={`app-detail-${a.id}`}>
                    <td colspan="10">
                      <div class="detail-panel">
                        <div class="detail-grid">
                          <div class="detail-block">
                            <div class="detail-label">City</div>
                            <div class="detail-value">{a.city}</div>
                          </div>
                          {a.currentOrg && (
                            <div class="detail-block">
                              <div class="detail-label">Organisation</div>
                              <div class="detail-value">{a.currentOrg}</div>
                            </div>
                          )}
                          {a.portfolio && (
                            <div class="detail-block">
                              <div class="detail-label">Portfolio</div>
                              <a href={a.portfolio.startsWith('http') ? a.portfolio : `https://${a.portfolio}`}
                                target="_blank" rel="noopener" class="td-link detail-value">{a.portfolio}</a>
                            </div>
                          )}
                        </div>
                        <div class="detail-block full">
                          <div class="detail-label">Why TransMetaTek</div>
                          <div class="detail-value detail-text">{a.whyTmk}</div>
                        </div>
                        <div class="detail-block full">
                          <div class="detail-label">AI Project</div>
                          <div class="detail-value detail-text">{a.aiProject}</div>
                        </div>
                        <div class="detail-block full">
                          <div class="detail-label">Role Question</div>
                          <div class="detail-value detail-text">{a.roleQuestion}</div>
                        </div>
                      </div>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
        {apps.length > 0 && (
          <div class="table-footer">
            <button class="btn-export" id="export-apps">Export CSV</button>
          </div>
        )}
      </div>

      <!-- ── Internship Applications Tab ── -->
      <div class="tab-panel hidden" id="tab-internships">
        {interns.length === 0 ? (
          <div class="empty-state">No internship applications yet.</div>
        ) : (
          <div class="table-scroll">
            <table class="admin-table">
              <thead>
                <tr>
                  <th>#</th>
                  <th>Name</th>
                  <th>Email</th>
                  <th>University</th>
                  <th>Year</th>
                  <th>Area</th>
                  <th>Duration</th>
                  <th>Start</th>
                  <th>Submitted</th>
                  <th></th>
                </tr>
              </thead>
              <tbody>
                {interns.map(i => (
                  <tr class="app-row" data-id={i.id}>
                    <td class="td-id">{i.id}</td>
                    <td class="td-name">
                      <div class="name-cell">
                        <span class="name-initials">{i.firstName[0]}{i.lastName[0]}</span>
                        <span>{i.firstName} {i.lastName}</span>
                      </div>
                    </td>
                    <td><a href={`mailto:${i.email}`} class="td-link">{i.email}</a></td>
                    <td>{i.university}</td>
                    <td class="td-mono">{i.yearOfStudy}</td>
                    <td>
                      <span class="role-badge">
                        {i.area.replace(/-/g, ' ')}
                      </span>
                    </td>
                    <td class="td-mono">{i.duration}</td>
                    <td class="td-mono">{i.availability}</td>
                    <td class="td-mono td-date">{new Date(i.createdAt).toLocaleDateString('en-GB', { day:'2-digit', month:'short', year:'numeric' })}</td>
                    <td>
                      <button class="btn-expand" data-intern-id={i.id}>
                        <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                          <path d="M3 5l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      </button>
                    </td>
                  </tr>
                  <tr class="detail-row hidden" id={`intern-detail-${i.id}`}>
                    <td colspan="10">
                      <div class="detail-panel">
                        <div class="detail-grid">
                          <div class="detail-block">
                            <div class="detail-label">Course</div>
                            <div class="detail-value">{i.course}</div>
                          </div>
                          <div class="detail-block">
                            <div class="detail-label">Skills</div>
                            <div class="detail-value">
                              {JSON.parse(i.skills ?? '[]').map((s: string) => (
                                <span class="skill-tag">{s}</span>
                              ))}
                            </div>
                          </div>
                          {i.github && (
                            <div class="detail-block">
                              <div class="detail-label">GitHub / Portfolio</div>
                              <a href={i.github.startsWith('http') ? i.github : `https://${i.github}`}
                                target="_blank" rel="noopener" class="td-link detail-value">{i.github}</a>
                            </div>
                          )}
                          {i.linkedin && (
                            <div class="detail-block">
                              <div class="detail-label">LinkedIn</div>
                              <a href={i.linkedin.startsWith('http') ? i.linkedin : `https://${i.linkedin}`}
                                target="_blank" rel="noopener" class="td-link detail-value">{i.linkedin}</a>
                            </div>
                          )}
                        </div>
                        <div class="detail-block full">
                          <div class="detail-label">What excites them about AI for Indonesia</div>
                          <div class="detail-value detail-text">{i.whatExcites}</div>
                        </div>
                        <div class="detail-block full">
                          <div class="detail-label">Most ambitious project</div>
                          <div class="detail-value detail-text">{i.ambitiousProject}</div>
                        </div>
                        <div class="detail-block full">
                          <div class="detail-label">AI dream for internship</div>
                          <div class="detail-value detail-text">{i.aiDream}</div>
                        </div>
                      </div>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
        {interns.length > 0 && (
          <div class="table-footer">
            <button class="btn-export" id="export-interns">Export CSV</button>
          </div>
        )}
      </div>

      <!-- ── Startup Builders Tab ── -->
      <div class="tab-panel hidden" id="tab-builders">
        {builders.length === 0 ? (
          <div class="empty-state">No builder profiles yet.</div>
        ) : (
          <div class="table-scroll">
            <table class="admin-table">
              <thead>
                <tr>
                  <th>#</th>
                  <th>Name</th>
                  <th>Email</th>
                  <th>Area</th>
                  <th>Lang</th>
                  <th>Builder</th>
                  <th>Loyalty</th>
                  <th>SJT</th>
                  <th>Money</th>
                  <th>LinkedIn</th>
                  <th>Submitted</th>
                  <th></th>
                </tr>
              </thead>
              <tbody>
                {builders.map(b => {
                  const ts = JSON.parse(b.traitScores ?? '{}');
                  const dv = JSON.parse(b.drivers ?? '{}');
                  const money = b.moneyOrientation;
                  const moneyClass = money == null ? '' : money >= 75 ? 'flag-high' : money >= 55 ? 'flag-mid' : 'flag-low';
                  return (
                  <>
                  <tr class="app-row" data-id={b.id}>
                    <td class="td-id">{b.id}</td>
                    <td class="td-name">
                      <div class="name-cell">
                        {b.photo
                          ? <img src={b.photo} alt="" class="name-photo" />
                          : <span class="name-initials">{b.firstName[0]}{b.lastName[0]}</span>}
                        <span>{b.firstName} {b.lastName}</span>
                      </div>
                    </td>
                    <td><a href={`mailto:${b.email}`} class="td-link">{b.email}</a></td>
                    <td><span class="role-badge">{b.area.replace(/-/g, ' ')}</span></td>
                    <td class="td-mono">{LANG_LABELS[b.interviewLanguage] ?? b.interviewLanguage}</td>
                    <td>
                      <div class={`score-cell score-${Math.round((b.builderScore ?? 0) / 25)}`}>
                        {b.builderScore ?? '—'}{b.builderScore != null ? '%' : ''}
                      </div>
                    </td>
                    <td class="td-mono">{b.loyaltyScore != null ? b.loyaltyScore + '%' : '—'}</td>
                    <td class="td-mono">{b.sjtScore != null ? b.sjtScore + '%' : '—'}</td>
                    <td>
                      {money != null
                        ? <span class={`money-flag ${moneyClass}`}>{money}%</span>
                        : <span class="td-muted">—</span>}
                    </td>
                    <td>
                      {b.linkedin
                        ? <a href={b.linkedin.startsWith('http') ? b.linkedin : `https://${b.linkedin}`}
                            target="_blank" rel="noopener" class="td-link">View ↗</a>
                        : <span class="td-muted">—</span>}
                    </td>
                    <td class="td-mono td-date">{new Date(b.createdAt).toLocaleDateString('en-GB', { day:'2-digit', month:'short', year:'numeric' })}</td>
                    <td>
                      <button class="btn-expand" data-builder-id={b.id}>
                        <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 5l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                      </button>
                    </td>
                  </tr>
                  <tr class="detail-row hidden" id={`builder-detail-${b.id}`}>
                    <td colspan="13">
                      <div class="detail-panel">
                        <div class="detail-block full">
                          <div class="detail-label">Trait signal</div>
                          <div class="trait-grid">
                            {Object.entries(TRAIT_LABELS).map(([key, label]) => (
                              <div class="trait-mini">
                                <div class="trait-mini-head">
                                  <span title={TRAIT_GUIDE[key]}>{label}</span>
                                  <span class="td-mono">{Math.round(ts[key] ?? 0)}%</span>
                                </div>
                                <div class="trait-mini-track"><div class="trait-mini-fill" style={`width:${Math.round(ts[key] ?? 0)}%`}></div></div>
                              </div>
                            ))}
                          </div>
                          <div class="trait-guide-toggle" id={`guide-toggle-${b.id}`} style="margin-top:0.75rem;cursor:pointer;font-size:0.8rem;color:var(--text-muted);text-decoration:underline;">+ Show trait guide</div>
                          <div class="trait-guide-panel hidden" id={`guide-panel-${b.id}`} style="margin-top:1rem;padding:1rem;background:rgba(255,255,255,0.04);border-radius:6px;border-left:3px solid var(--cyan);">
                            {Object.entries(TRAIT_LABELS).map(([key, label]) => (
                              <div style="margin-bottom:0.75rem;font-size:0.8rem;">
                                <strong style="color:var(--text-primary);">{label}</strong>
                                <p style="margin:0.25rem 0 0 0;color:var(--text-muted);">{TRAIT_GUIDE[key]}</p>
                              </div>
                            ))}
                          </div>
                        </div>
                        <div class="detail-block full">
                          <div class="detail-label">Loyalty &amp; money signal (admin only)</div>
                          <div class="detail-grid">
                            <div class="detail-block">
                              <div class="detail-label">Loyalty index</div>
                              <div class="detail-value td-mono">{b.loyaltyScore != null ? b.loyaltyScore + '%' : '—'}</div>
                            </div>
                            <div class="detail-block">
                              <div class="detail-label">Money orientation</div>
                              <div class="detail-value">
                                {money != null
                                  ? <span class={`money-flag ${moneyClass}`}>{money}% {money >= 75 ? '· money-primary' : money >= 55 ? '· mixed' : '· mission-leaning'}</span>
                                  : '—'}
                              </div>
                            </div>
                            <div class="detail-block">
                              <div class="detail-label">Drives them MOST</div>
                              <div class="detail-value">{dv.most ? (DRIVER_LABELS[dv.most] ?? dv.most) : '—'}</div>
                            </div>
                            <div class="detail-block">
                              <div class="detail-label">Drives them LEAST</div>
                              <div class="detail-value">{dv.least ? (DRIVER_LABELS[dv.least] ?? dv.least) : '—'}</div>
                            </div>
                          </div>
                        </div>
                        <div class="detail-grid">
                          {b.portfolio && (
                            <div class="detail-block">
                              <div class="detail-label">Portfolio</div>
                              <a href={b.portfolio.startsWith('http') ? b.portfolio : `https://${b.portfolio}`}
                                target="_blank" rel="noopener" class="td-link detail-value">{b.portfolio}</a>
                            </div>
                          )}
                          {b.phone && (
                            <div class="detail-block">
                              <div class="detail-label">WhatsApp</div>
                              <a href={`https://wa.me/${b.phone.replace(/[^0-9]/g, '')}`} target="_blank" rel="noopener" class="td-link detail-value">{b.phone} ↗</a>
                            </div>
                          )}
                          <div class="detail-block">
                            <div class="detail-label">City</div>
                            <div class="detail-value">{b.city}</div>
                          </div>
                        </div>
                        <div class="detail-block full">
                          <div class="detail-label">First 72 hours (work sample)</div>
                          <div class="detail-value detail-text">{b.workSample}</div>
                        </div>
                        <div class="detail-block full">
                          <div class="detail-label">Learning under fire</div>
                          <div class="detail-value detail-text">{b.storyLearning}</div>
                        </div>
                        <div class="detail-block full">
                          <div class="detail-label">Where they're headed (vision + drive)</div>
                          <div class="detail-value detail-text">{b.vision}</div>
                        </div>
                        {b.noMoneyStory && (
                          <div class="detail-block full">
                            <div class="detail-label">Worked hard with little / no money</div>
                            <div class="detail-value detail-text">{b.noMoneyStory}</div>
                          </div>
                        )}
                      </div>
                    </td>
                  </tr>
                  </>
                )})}
              </tbody>
            </table>
          </div>
        )}
        {builders.length > 0 && (
          <div class="table-footer">
            <button class="btn-export" id="export-builders">Export CSV</button>
          </div>
        )}
      </div>

    </div>
  </main>
</Layout>

<style>
  :global(body) { background: #080101; }

  #admin-main {
    min-height: 100vh;
    padding: 2rem 1.5rem 4rem;
    font-family: var(--font-sans);
  }

  .admin-container { max-width: 1300px; margin: 0 auto; }

  .admin-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
  }

  .admin-logo {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text-primary);
    font-family: var(--font-mono);
  }

  .admin-logo-dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--cyan);
    animation: pulse-dot 1.8s ease-in-out infinite;
  }
  @keyframes pulse-dot {
    0%,100%{opacity:1;transform:scale(1)}
    50%{opacity:.7;transform:scale(1.2)}
  }

  .admin-meta { display: flex; gap: 0.5rem; }

  .admin-badge {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    background: rgba(232,25,44,0.08);
    border: 1px solid rgba(232,25,44,0.2);
    color: var(--cyan);
    border-radius: 100px;
    padding: 0.25rem 0.75rem;
  }

  /* Tabs */
  .admin-tabs {
    display: flex;
    gap: 0;
    border-bottom: 1px solid var(--border);
    margin-bottom: 1.5rem;
  }

  .admin-tab {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.25rem;
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    color: var(--text-muted);
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    transition: color 0.2s, border-color 0.2s;
    margin-bottom: -1px;
  }

  .admin-tab:hover { color: var(--text-secondary); }

  .admin-tab.active {
    color: var(--text-primary);
    border-bottom-color: var(--cyan);
  }

  .tab-count {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    background: rgba(255,255,255,0.06);
    border-radius: 100px;
    padding: 0.1rem 0.45rem;
    color: var(--text-muted);
  }

  .admin-tab.active .tab-count {
    background: rgba(232,25,44,0.12);
    color: var(--cyan);
  }

  /* Tab panels */
  .tab-panel { }
  .tab-panel.hidden { display: none; }

  .empty-state {
    text-align: center;
    padding: 4rem;
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 0.85rem;
  }

  /* Table */
  .table-scroll { overflow-x: auto; border-radius: 10px; border: 1px solid var(--border); }

  .admin-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.82rem;
  }

  .admin-table thead tr {
    background: rgba(255,255,255,0.03);
    border-bottom: 1px solid var(--border);
  }

  .admin-table th {
    padding: 0.75rem 1rem;
    text-align: left;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 500;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    white-space: nowrap;
  }

  .admin-table td {
    padding: 0.875rem 1rem;
    border-bottom: 1px solid rgba(255,255,255,0.04);
    color: var(--text-secondary);
    vertical-align: middle;
  }

  .app-row:hover td { background: rgba(255,255,255,0.015); }

  .td-id {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-muted);
    width: 36px;
  }

  .name-cell {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--text-primary);
    font-weight: 500;
    white-space: nowrap;
  }

  .name-initials {
    width: 28px; height: 28px;
    border-radius: 50%;
    background: rgba(232,25,44,0.15);
    border: 1px solid rgba(232,25,44,0.25);
    display: flex; align-items: center; justify-content: center;
    font-size: 0.65rem;
    font-weight: 700;
    color: var(--cyan);
    flex-shrink: 0;
    font-family: var(--font-mono);
  }

  .name-photo {
    width: 28px; height: 28px;
    border-radius: 50%;
    object-fit: cover;
    border: 1px solid rgba(232,25,44,0.35);
    flex-shrink: 0;
  }

  .td-link {
    color: var(--cyan);
    text-decoration: none;
    font-size: 0.8rem;
  }
  .td-link:hover { text-decoration: underline; }

  .td-mono { font-family: var(--font-mono); font-size: 0.75rem; }
  .td-muted { color: var(--text-muted); }
  .td-date  { white-space: nowrap; color: var(--text-muted); font-size: 0.75rem; }

  .role-badge {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.2rem 0.55rem;
    border-radius: 4px;
    background: rgba(232,25,44,0.1);
    border: 1px solid rgba(232,25,44,0.2);
    color: var(--cyan);
    white-space: nowrap;
  }

  .td-skills { display: flex; flex-wrap: wrap; gap: 0.3rem; max-width: 220px; }

  .skill-tag {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 3px;
    padding: 0.15rem 0.4rem;
    color: var(--text-muted);
    white-space: nowrap;
  }

  .score-cell {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 700;
    text-align: center;
  }
  .score-cell.score-0, .score-cell.score-1 { color: var(--text-muted); }
  .score-cell.score-2 { color: #FF7043; }
  .score-cell.score-3 { color: #FF5252; }
  .score-cell.score-4 { color: var(--cyan); }

  /* Expand button */
  .btn-expand {
    background: none;
    border: 1px solid var(--border);
    border-radius: 6px;
    color: var(--text-muted);
    cursor: pointer;
    padding: 0.3rem 0.4rem;
    transition: all 0.2s;
    display: flex; align-items: center;
  }
  .btn-expand:hover { border-color: var(--cyan); color: var(--cyan); }
  .btn-expand.open svg { transform: rotate(180deg); }
  .btn-expand svg { transition: transform 0.2s; }

  /* Detail row */
  .detail-row td { padding: 0; background: rgba(232,25,44,0.02); }
  .detail-row.hidden { display: none; }

  .detail-panel {
    padding: 1.5rem 1.5rem 1.5rem 4rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    border-top: 1px solid rgba(232,25,44,0.1);
  }

  .detail-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
  }

  .detail-block { display: flex; flex-direction: column; gap: 0.3rem; }
  .detail-block.full { width: 100%; }

  .detail-label {
    font-family: var(--font-mono);
    font-size: 0.63rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
  }

  .detail-value {
    font-size: 0.82rem;
    color: var(--text-secondary);
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }

  .detail-text {
    line-height: 1.7;
    max-width: 760px;
    display: block;
    color: var(--text-secondary);
    font-size: 0.85rem;
  }

  /* Footer */
  .table-footer {
    display: flex;
    justify-content: flex-end;
    padding: 1rem 0 0;
  }

  .btn-export {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    padding: 0.45rem 1rem;
    background: rgba(255,255,255,0.04);
    border: 1px solid var(--border);
    border-radius: 6px;
    color: var(--text-secondary);
    cursor: pointer;
    transition: all 0.2s;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .btn-export:hover { border-color: var(--cyan); color: var(--cyan); }

  /* Builder trait mini-bars */
  .trait-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.75rem 1.5rem; max-width: 720px; }
  .trait-mini { display: flex; flex-direction: column; gap: 0.3rem; }
  .trait-mini-head { display: flex; justify-content: space-between; font-size: 0.74rem; color: var(--text-secondary); }
  .trait-mini-track { height: 5px; background: rgba(255,255,255,0.06); border-radius: 3px; overflow: hidden; }
  .trait-mini-fill { height: 100%; background: linear-gradient(90deg, var(--cyan), var(--purple)); border-radius: 3px; }
  @media (max-width: 640px) { .trait-grid { grid-template-columns: 1fr 1fr; } }

  /* Money-orientation flag */
  .money-flag {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 700;
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    white-space: nowrap;
  }
  .money-flag.flag-low  { color: #10b981; background: rgba(16,185,129,0.12); border: 1px solid rgba(16,185,129,0.25); }
  .money-flag.flag-mid  { color: #FFB74D; background: rgba(255,167,77,0.12); border: 1px solid rgba(255,167,77,0.25); }
  .money-flag.flag-high { color: #FF5252; background: rgba(255,82,82,0.12); border: 1px solid rgba(255,82,82,0.28); }
  /* Trait guide toggle & panel */
  .trait-guide-toggle { transition: color 0.2s ease; }
  .trait-guide-toggle:hover { color: var(--text-primary); }
  .trait-guide-panel { animation: slideDown 0.25s ease; }
  .trait-guide-panel.hidden { display: none; }
  @keyframes slideDown { from { opacity: 0; transform: translateY(-8px); } to { opacity: 1; transform: translateY(0); } }
</style>

<script>
  // ── Tabs ────────────────────────────────────────────────────────────────
  document.querySelectorAll('.admin-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.admin-tab').forEach(t => t.classList.remove('active'));
      document.querySelectorAll('.tab-panel').forEach(p => p.classList.add('hidden'));
      tab.classList.add('active');
      const panelId = 'tab-' + tab.dataset.tab;
      document.getElementById(panelId)?.classList.remove('hidden');
    });
  });

  // ── Expand rows ─────────────────────────────────────────────────────────
  document.querySelectorAll('.btn-expand').forEach(btn => {
    btn.addEventListener('click', () => {
      const appId     = btn.dataset.appId;
      const internId  = btn.dataset.internId;
      const builderId = btn.dataset.builderId;
      const detailId  = appId ? `app-detail-${appId}`
                      : internId ? `intern-detail-${internId}`
                      : `builder-detail-${builderId}`;
      const row = document.getElementById(detailId);
      if (!row) return;
      row.classList.toggle('hidden');
      btn.classList.toggle('open');
    });
  });

  // ── CSV export ───────────────────────────────────────────────────────────
  function tableToCSV(tableEl) {
    const rows = [];
    tableEl.querySelectorAll('tr').forEach(tr => {
      if (tr.classList.contains('detail-row')) return;
      const cells = [...tr.querySelectorAll('th, td')].slice(0, -1); // skip expand col
      rows.push(cells.map(c => `"${c.textContent.trim().replace(/"/g, '""')}"`).join(','));
    });
    return rows.join('\n');
  }

  function downloadCSV(csv, filename) {
    const blob = new Blob([csv], { type: 'text/csv' });
    const a = Object.assign(document.createElement('a'), {
      href: URL.createObjectURL(blob),
      download: filename,
    });
    a.click();
    URL.revokeObjectURL(a.href);
  }

  document.getElementById('export-apps')?.addEventListener('click', () => {
    const table = document.querySelector('#tab-applications .admin-table');
    if (table) downloadCSV(tableToCSV(table), 'applications.csv');
  });

  document.getElementById('export-interns')?.addEventListener('click', () => {
    const table = document.querySelector('#tab-internships .admin-table');
    if (table) downloadCSV(tableToCSV(table), 'internships.csv');
  });

  document.getElementById('export-builders')?.addEventListener('click', () => {
    const table = document.querySelector('#tab-builders .admin-table');
    if (table) downloadCSV(tableToCSV(table), 'startup-builders.csv');
  });

  // ── Trait guide toggle ────────────────────────────────────────────────
  document.querySelectorAll('[id^="guide-toggle-"]').forEach(toggle => {
    toggle.addEventListener('click', () => {
      const builderId = toggle.id.replace('guide-toggle-', '');
      const panel = document.getElementById(`guide-panel-${builderId}`);
      if (panel) {
        panel.classList.toggle('hidden');
        toggle.textContent = panel.classList.contains('hidden') ? '+ Show trait guide' : '− Hide trait guide';
      }
    });
  });
</script>
