    font-family: var(--font-mono);
    font-size: 0.63rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
  }

  .detail-value {
    font-size: 0.82rem;
    color: var(--text-secondary);
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }

  .detail-text {
    line-height: 1.7;
    max-width: 760px;
    display: block;
    color: var(--text-secondary);
    font-size: 0.85rem;
  }

  /* Footer */
  .table-footer {
    display: flex;
    justify-content: flex-end;
    padding: 1rem 0 0;
  }

  .btn-export {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    padding: 0.45rem 1rem;
    background: rgba(255,255,255,0.04);
    border: 1px solid var(--border);
    border-radius: 6px;
    color: var(--text-secondary);
    cursor: pointer;
    transition: all 0.2s;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .btn-export:hover { border-color: var(--cyan); color: var(--cyan); }

  /* Builder trait mini-bars */
  .trait-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.75rem 1.5rem; max-width: 720px; }
  .trait-mini { display: flex; flex-direction: column; gap: 0.3rem; }
  .trait-mini-head { display: flex; justify-content: space-between; font-size: 0.74rem; color: var(--text-secondary); }
  .trait-mini-track { height: 5px; background: rgba(255,255,255,0.06); border-radius: 3px; overflow: hidden; }
  .trait-mini-fill { height: 100%; background: linear-gradient(90deg, var(--cyan), var(--purple)); border-radius: 3px; }
  @media (max-width: 640px) { .trait-grid { grid-template-columns: 1fr 1fr; } }

  /* Money-orientation flag */
  .money-flag {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 700;
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    white-space: nowrap;
  }
  .money-flag.flag-low  { color: #10b981; background: rgba(16,185,129,0.12); border: 1px solid rgba(16,185,129,0.25); }
  .money-flag.flag-mid  { color: #FFB74D; background: rgba(255,167,77,0.12); border: 1px solid rgba(255,167,77,0.25); }
  .money-flag.flag-high { color: #FF5252; background: rgba(255,82,82,0.12); border: 1px solid rgba(255,82,82,0.28); }

  /* Stage 1 screen control: pass / hold / reject */
  .screen-control { display: flex; gap: 0.25rem; }
  .screen-btn {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    font-weight: 700;
    padding: 0.2rem 0.45rem;
    border-radius: 4px;
    cursor: pointer;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.1);
    color: var(--text-muted);
    transition: all 0.15s ease;
    white-space: nowrap;
  }
  .screen-btn:hover { color: var(--text-primary); border-color: rgba(255,255,255,0.25); }
  .screen-btn.screen-pass.active   { color: #10b981; background: rgba(16,185,129,0.14); border-color: rgba(16,185,129,0.35); }
  .screen-btn.screen-hold.active   { color: #FFB74D; background: rgba(255,167,77,0.14); border-color: rgba(255,167,77,0.35); }
  .screen-btn.screen-reject.active { color: #FF5252; background: rgba(255,82,82,0.14); border-color: rgba(255,82,82,0.35); }

  /* Stage 3 interviewer score entry (1/3/5 anchored) + Stage 5 mechanical roll-up */
  .iscore-control { display: flex; gap: 0.25rem; margin-left: auto; }
  .iscore-btn {
    font-family: var(--font-mono); font-size: 0.68rem; font-weight: 700;
    width: 22px; height: 22px; border-radius: 4px; cursor: pointer;
    background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.1);
    color: var(--text-muted); transition: all 0.15s ease;
  }
  .iscore-btn:hover { color: var(--text-primary); border-color: rgba(255,255,255,0.25); }
  .iscore-btn.active { color: var(--cyan); background: rgba(232,25,44,0.14); border-color: rgba(232,25,44,0.4); }
  .td-overall { font-weight: 700; }
  .th-sortable { cursor: pointer; user-select: none; }
  .th-sortable:hover { color: var(--cyan); }

  /* Stage 6 calibration tab */
  .calibration-intro { font-size: 0.85rem; color: var(--text-muted); line-height: 1.6; margin-bottom: 1.25rem; max-width: 760px; }
  .calib-review { display: flex; gap: 0.4rem; align-items: center; }
  .calib-actual-input {
    width: 64px; background: rgba(255,255,255,0.03); border: 1px solid var(--border); border-radius: 6px;
    padding: 0.3rem 0.5rem; font-size: 0.78rem; color: var(--text-primary); font-family: var(--font-mono);
  }
  .calib-hire-btn { margin-top: 0.5rem; }
  .hire-outcome { display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap; }
  .hire-toggle-btn.is-hired { color: #10b981; border-color: rgba(16,185,129,0.4); background: rgba(16,185,129,0.08); }
  .hire-note { font-size: 0.76rem; color: var(--text-muted); }
  /* Hover-tip cues (native title popups: what the number means, good vs bad) */
  .score-breakdown {
    background: rgba(255,255,255,0.025);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 6px;
    padding: 0.9rem 1rem;
    margin-bottom: 1.25rem;
  }
  .score-breakdown-head { display: flex; align-items: baseline; gap: 0.6rem; margin-bottom: 0.7rem; }
  .score-breakdown-total { font-family: var(--font-mono); font-size: 1.1rem; font-weight: 700; color: var(--cyan); }
  .score-breakdown-rows { display: flex; flex-direction: column; gap: 0.4rem; }
  .score-breakdown-row { display: grid; grid-template-columns: 70px 170px 1fr auto; align-items: center; gap: 0.6rem; }
  .score-breakdown-bar { height: 5px; border-radius: 3px; background: rgba(255,255,255,0.06); overflow: hidden; }
  .score-breakdown-fill { height: 100%; background: var(--cyan); border-radius: 3px; }
  .score-breakdown-label { font-size: 0.74rem; color: var(--text-secondary); }
  .score-breakdown-note { font-size: 0.7rem; color: var(--text-muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .score-breakdown-pts { font-size: 0.7rem; color: var(--text-muted); text-align: right; }
  .th-tip, .has-tip { cursor: help; }
  .th-tip { text-decoration: underline dotted rgba(255,255,255,0.3); text-underline-offset: 3px; }
  .trait-mini.has-tip:hover .trait-mini-head span:first-child { color: var(--cyan); }
  /* Large profile photo header in detail panel */
  .builder-photo-large { width: 300px; height: 300px; border-radius: 16px; object-fit: cover; border: 2px solid rgba(255,255,255,0.12); flex-shrink: 0; }
  .builder-photo-placeholder { display: flex; align-items: center; justify-content: center; background: rgba(232,25,44,0.12); color: var(--cyan); font-size: 5rem; font-weight: 700; text-transform: uppercase; }
  .builder-photo-name { font-size: 1.15rem; font-weight: 700; color: var(--text-primary); margin-bottom: 0.2rem; }
  .builder-photo-meta { font-size: 0.78rem; color: var(--text-muted); text-transform: capitalize; margin-bottom: 0.6rem; }
  @media (max-width: 900px) { .builder-photo-large { width: 220px; height: 220px; } }
  @media (max-width: 640px) { .builder-photo-large { width: 160px; height: 160px; } }
  /* Job-application overview (mirrors the builder card: one bordered card, photo left, body fills its height) */
  .app-overview-card { background: rgba(255,255,255,0.025); border: 1px solid rgba(255,255,255,0.08); border-left: 4px solid var(--cyan); border-radius: 10px; padding: 1.25rem; margin-bottom: 1.5rem; }
  .app-overview { display: flex; gap: 1.5rem; align-items: stretch; }
  .app-overview-body { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 1rem; }
  .app-overview-header { display: flex; justify-content: space-between; align-items: flex-start; gap: 1.5rem; }
  .app-photo-info { min-width: 0; }
  .app-photo-overall { flex-shrink: 0; text-align: center; padding: 0.5rem 1rem; border-radius: 10px; background: rgba(0,0,0,0.22); border: 1px solid rgba(255,255,255,0.08); }
  .app-photo-overall-val { display: block; font-size: 1.9rem; font-weight: 800; color: var(--cyan); line-height: 1; }
  .app-photo-overall-label { font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.6px; color: var(--text-muted); }
  /* Inside the card the breakdown is a section, not its own box — divider, no chrome */
  .app-overview-body .score-breakdown { margin: auto 0 0; padding: 1rem 0 0; background: none; border: none; border-top: 1px solid rgba(255,255,255,0.08); border-radius: 0; }
  @media (max-width: 768px) {
    .app-overview { flex-direction: column; align-items: center; text-align: center; }
    .app-overview-header { flex-direction: column; align-items: center; gap: 0.75rem; }
    .app-overview-body .score-breakdown { text-align: left; }
  }
  /* Written answer blocks with question + guidance */
  .answer-block { background: rgba(0,0,0,0.18); border-radius: 8px; padding: 1.1rem 1.25rem; margin-bottom: 1rem; border: 1px solid rgba(255,255,255,0.06); }
  .answer-title { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.6px; color: var(--cyan); font-weight: 700; margin-bottom: 0.5rem; }
  .answer-question { font-size: 0.85rem; color: var(--text-secondary); line-height: 1.5; padding: 0.6rem 0.75rem; background: rgba(255,255,255,0.03); border-radius: 5px; border-left: 2px solid rgba(255,255,255,0.15); margin-bottom: 0.6rem; }
  .answer-look { font-size: 0.82rem; color: var(--text-muted); line-height: 1.5; margin-bottom: 0.6rem; }
  .answer-look strong { color: var(--text-secondary); }
  .answer-examples { display: flex; flex-direction: column; gap: 0.35rem; margin-bottom: 0.75rem; }
  .answer-example { font-size: 0.76rem; line-height: 1.45; color: var(--text-muted); padding: 0.4rem 0.55rem; border-radius: 5px; }
  .answer-good { background: rgba(16,185,129,0.06); }
  .answer-bad { background: rgba(255,82,82,0.06); }
  .answer-tag { display: inline-block; font-size: 0.64rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; padding: 0.08rem 0.4rem; border-radius: 3px; margin-right: 0.4rem; }
  .tag-good { color: #10b981; background: rgba(16,185,129,0.15); }
  .tag-bad { color: #FF5252; background: rgba(255,82,82,0.15); }
  .answer-their-label { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.5px; color: var(--text-muted); margin-bottom: 0.35rem; padding-top: 0.5rem; border-top: 1px solid rgba(255,255,255,0.08); }
  .answer-text { font-size: 0.9rem; color: var(--text-primary); line-height: 1.6; white-space: pre-wrap; }

  /* ── Offline interview guide ── */
  .iguide-intro { font-size: 0.82rem; color: var(--text-muted); line-height: 1.55; margin-top: 0.4rem; }
  .iguide-intro strong { color: var(--text-secondary); text-transform: capitalize; }
  .iguide-item { background: rgba(0,0,0,0.18); border-radius: 8px; padding: 1rem 1.15rem; margin-bottom: 0.9rem; border: 1px solid rgba(255,255,255,0.06); border-left-width: 3px; }
  .ip-border-probe-hard { border-left-color: #ef4444; }
  .ip-border-verify     { border-left-color: #facc15; }
  .ip-border-confirm    { border-left-color: #22c55e; }
  .iguide-head { display: flex; align-items: center; gap: 0.6rem; margin-bottom: 0.4rem; }
  .iguide-attr { font-size: 0.92rem; font-weight: 600; color: var(--text-primary); }
  .iguide-score { font-size: 0.78rem; color: var(--text-muted); margin-left: auto; }
  .ip { font-size: 0.62rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; padding: 0.1rem 0.45rem; border-radius: 3px; }
  .ip-probe-hard, .ip-probe { color: #ef4444; background: rgba(239,68,68,0.14); }
  .ip-verify  { color: #facc15; background: rgba(250,204,21,0.14); }
  .ip-confirm { color: #22c55e; background: rgba(34,197,94,0.14); }
  .iguide-reason { font-size: 0.8rem; color: var(--text-secondary); line-height: 1.5; margin-bottom: 0.7rem; }
  .iguide-q { background: rgba(255,255,255,0.025); border-radius: 6px; padding: 0.75rem 0.85rem; margin-top: 0.6rem; }
  .iguide-q-head { margin-bottom: 0.4rem; }
  .iguide-qtype { font-size: 0.6rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; padding: 0.08rem 0.4rem; border-radius: 3px; color: var(--text-muted); background: rgba(255,255,255,0.07); }
  .qt-behavioral { color: #8ec9ff; background: rgba(56,189,248,0.12); }
  .qt-situational { color: #c4a3ff; background: rgba(167,139,250,0.12); }
  .iguide-q-text { font-size: 0.9rem; color: var(--text-primary); line-height: 1.5; margin-bottom: 0.5rem; }
  .iguide-listen { font-size: 0.8rem; color: var(--text-muted); line-height: 1.5; margin-bottom: 0.5rem; }
  .iguide-listen strong { color: var(--text-secondary); }
  .iguide-tied { font-size: 0.8rem; line-height: 1.5; margin-bottom: 0.5rem; padding: 0.5rem 0.65rem; background: rgba(232,25,44,0.06); border-radius: 5px; border-left: 2px solid var(--cyan-glow); }
  .iguide-tied-label { display: block; font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.4px; color: var(--cyan); font-weight: 700; margin-bottom: 0.2rem; }
  .iguide-tied-text { color: var(--text-secondary); font-style: italic; white-space: pre-wrap; }
  .iguide-probes { font-size: 0.8rem; margin-bottom: 0.6rem; }
  .iguide-probes-label { font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.4px; color: var(--text-muted); font-weight: 700; }
  .iguide-probes ul { margin: 0.25rem 0 0; padding-left: 1.1rem; color: var(--text-muted); line-height: 1.5; }
  .iguide-anchors { display: flex; flex-direction: column; gap: 0.3rem; padding-top: 0.5rem; border-top: 1px solid rgba(255,255,255,0.08); }
  .iguide-anchor { display: flex; gap: 0.5rem; align-items: flex-start; font-size: 0.78rem; line-height: 1.45; color: var(--text-muted); }
  .anchor-num { flex-shrink: 0; width: 18px; height: 18px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.68rem; font-weight: 700; }
  .anchor-1 .anchor-num { color: #ef4444; background: rgba(239,68,68,0.16); }
  .anchor-3 .anchor-num { color: #facc15; background: rgba(250,204,21,0.16); }
  .anchor-5 .anchor-num { color: #22c55e; background: rgba(34,197,94,0.16); }

  /* Name link icon (Results next to name) */
  .name-link-icon { font-size: 0.9rem; color: var(--cyan); opacity: 0; transition: opacity 0.2s ease; text-decoration: none; cursor: pointer; }
  .app-row:hover .name-link-icon { opacity: 1; }
  /* Verdict / assessment card */
  .verdict-card { padding: 1.25rem; border-radius: 10px; margin-bottom: 1.5rem; border: 1px solid rgba(255,255,255,0.1); border-left-width: 4px; }
  .verdict-card.verdict-strong { background: rgba(16,185,129,0.07); border-left-color: #10b981; }
  .verdict-card.verdict-good   { background: rgba(56,189,248,0.07); border-left-color: #38bdf8; }
  .verdict-card.verdict-mixed  { background: rgba(255,167,77,0.07); border-left-color: #FFB74D; }
  .verdict-card.verdict-weak   { background: rgba(255,82,82,0.07); border-left-color: #FF5252; }
  .verdict-main { display: flex; gap: 1.5rem; align-items: stretch; margin-bottom: 1rem; }
  .verdict-body { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 1rem; }
  .verdict-header { display: flex; justify-content: space-between; align-items: flex-start; gap: 1.5rem; }
  .verdict-id { min-width: 0; }
  .verdict-score-block { text-align: center; flex-shrink: 0; padding: 0.6rem 1rem; border-radius: 10px; background: rgba(0,0,0,0.22); border: 1px solid rgba(255,255,255,0.08); }
  .verdict-score { font-size: 2.6rem; font-weight: 800; line-height: 1; }
  .verdict-strong .verdict-score { color: #10b981; }
  .verdict-good   .verdict-score { color: #38bdf8; }
  .verdict-mixed  .verdict-score { color: #FFB74D; }
  .verdict-weak   .verdict-score { color: #FF5252; }
  .verdict-score-label { font-size: 0.62rem; text-transform: uppercase; letter-spacing: 0.6px; color: var(--text-muted); margin-top: 0.3rem; }
  .verdict-headline { font-size: 1.1rem; font-weight: 700; color: var(--text-primary); margin-bottom: 0.35rem; }
  .verdict-why { font-size: 0.85rem; color: var(--text-secondary); line-height: 1.55; }
  .verdict-detail-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-top: auto; padding-top: 1rem; border-top: 1px solid rgba(255,255,255,0.08); }
  .verdict-col-label { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.5px; color: var(--text-muted); margin-bottom: 0.5rem; }
  .verdict-chips { display: flex; flex-wrap: wrap; gap: 0.4rem; }
  .verdict-chip { font-size: 0.74rem; font-weight: 600; padding: 0.2rem 0.55rem; border-radius: 5px; white-space: nowrap; }
  .verdict-chip.chip-strong { color: #10b981; background: rgba(16,185,129,0.12); border: 1px solid rgba(16,185,129,0.25); }
  .verdict-chip.chip-weak { color: #FF5252; background: rgba(255,82,82,0.12); border: 1px solid rgba(255,82,82,0.25); }
  .verdict-none { font-size: 0.8rem; color: var(--text-muted); font-style: italic; }
  .verdict-money { font-size: 0.83rem; color: var(--text-secondary); padding: 0.75rem; background: rgba(0,0,0,0.2); border-radius: 6px; margin-bottom: 0.75rem; line-height: 1.5; }
  .verdict-footer { font-size: 0.78rem; color: var(--text-muted); font-style: italic; line-height: 1.5; }
  @media (max-width: 768px) {
    .verdict-main { flex-direction: column; align-items: center; text-align: center; }
    .verdict-header { flex-direction: column; align-items: center; gap: 0.75rem; }
    .verdict-detail-row { grid-template-columns: 1fr; gap: 1rem; text-align: left; }
    .verdict-chips { justify-content: center; }
  }
  /* Trait guide toggle & panel */
  .trait-guide-toggle { transition: color 0.2s ease; }
  .trait-guide-toggle:hover { color: var(--text-primary); }
  .trait-guide-panel { animation: slideDown 0.25s ease; }
  .trait-guide-panel.hidden { display: none; }
  @keyframes slideDown { from { opacity: 0; transform: translateY(-8px); } to { opacity: 1; transform: translateY(0); } }
</style>

<script>
  // ── Tabs ────────────────────────────────────────────────────────────────
  document.querySelectorAll('.admin-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.admin-tab').forEach(t => t.classList.remove('active'));
      document.querySelectorAll('.tab-panel').forEach(p => p.classList.add('hidden'));
      tab.classList.add('active');
      const panelId = 'tab-' + tab.dataset.tab;
      document.getElementById(panelId)?.classList.remove('hidden');
    });
  });

  // ── Expand rows ─────────────────────────────────────────────────────────
  document.querySelectorAll('.btn-expand').forEach(btn => {
    btn.addEventListener('click', () => {
      const appId     = btn.dataset.appId;
      const internId  = btn.dataset.internId;
      const builderId = btn.dataset.builderId;
      const detailId  = appId ? `app-detail-${appId}`
                      : internId ? `intern-detail-${internId}`
                      : `builder-detail-${builderId}`;
      const row = document.getElementById(detailId);
      if (!row) return;
      row.classList.toggle('hidden');
      btn.classList.toggle('open');
    });
  });

  // ── Stage 1 screen: pass / hold / reject ──────────────────────────────────
  const adminToken = new URLSearchParams(window.location.search).get('token');
  document.querySelectorAll('.screen-control').forEach(ctrl => {
    ctrl.querySelectorAll('.screen-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const track  = ctrl.dataset.track;
        const id     = Number(ctrl.dataset.id);
        const status = btn.classList.contains('active') ? null : btn.dataset.status;
        try {
          const res = await fetch(`/api/screen?token=${encodeURIComponent(adminToken ?? '')}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ track, id, status }),
          });
          if (!res.ok) throw new Error('Request failed');
          ctrl.querySelectorAll('.screen-btn').forEach(b => b.classList.remove('active'));
          if (status) btn.classList.add('active');
        } catch (err) {
          console.error('[admin] screen update failed:', err);
        }
      });
    });
  });

  // ── Stage 3: interviewer score entry (1/3/5 anchored, mechanical roll-up) ──
  // Each candidate's detail panel can hold several .iscore-control blocks (one
  // per scorecard attribute). Clicking a level re-collects every control within
  // the same panel and POSTs the whole scores object, so partial scoring across
  // multiple sessions/interviewers just keeps merging into the same record.
  document.querySelectorAll('.iscore-control').forEach(ctrl => {
    ctrl.querySelectorAll('.iscore-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const track = ctrl.dataset.track;
        const id    = Number(ctrl.dataset.id);
        const panel = ctrl.closest('.detail-panel');
        const wasActive = btn.classList.contains('active');

        ctrl.querySelectorAll('.iscore-btn').forEach(b => b.classList.remove('active'));
        if (!wasActive) btn.classList.add('active');

        const scores = {};
        panel?.querySelectorAll(`.iscore-control[data-track="${track}"][data-id="${id}"]`).forEach(c => {
          const active = c.querySelector('.iscore-btn.active');
          if (active) scores[c.dataset.attr] = Number(active.dataset.level);
        });

        try {
          const res = await fetch(`/api/interview-score?token=${encodeURIComponent(adminToken ?? '')}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ track, id, scores }),
          });
          if (!res.ok) throw new Error('Request failed');
        } catch (err) {
          console.error('[admin] interview score update failed:', err);
        }
      });
    });
  });

  // ── Stage 6: mark hired / unmark ───────────────────────────────────────────
  document.querySelectorAll('.hire-toggle-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const ctrl = btn.closest('.hire-outcome');
      const track = ctrl.dataset.track;
      const id = Number(ctrl.dataset.id);
      const action = btn.classList.contains('is-hired') ? 'unmark-hired' : 'mark-hired';
      try {
        const res = await fetch(`/api/calibration?token=${encodeURIComponent(adminToken ?? '')}`, {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ track, id, action }),
        });
        if (!res.ok) throw new Error('Request failed');
        window.location.reload();
      } catch (err) {
        console.error('[admin] hire toggle failed:', err);
      }
    });
  });

  // ── Stage 6: save actual performance review (Calibration tab) ─────────────
  document.querySelectorAll('.calib-save-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const ctrl = btn.closest('.calib-review');
      const track = ctrl.dataset.track;
      const id = Number(ctrl.dataset.id);
      const actualPerformanceScore = Number(ctrl.querySelector('.calib-actual-input').value);
      const notesInput = document.querySelector(`.calib-notes-input[data-track="${track}"][data-id="${id}"]`);
      const actualPerformanceNotes = notesInput ? notesInput.value : '';
      try {
        const res = await fetch(`/api/calibration?token=${encodeURIComponent(adminToken ?? '')}`, {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ track, id, action: 'review', actualPerformanceScore, actualPerformanceNotes }),
        });
        if (!res.ok) throw new Error('Request failed');
        btn.textContent = 'Saved ✓';
        setTimeout(() => { btn.textContent = 'Save'; }, 1500);
      } catch (err) {
        console.error('[admin] calibration review save failed:', err);
      }
    });
  });

  // ── Stage 5: sort job applications by mechanical Overall roll-up ──────────
  let overallSortDesc = true;
  document.getElementById('sort-apps-overall')?.addEventListener('click', () => {
    const tbody = document.querySelector('#tab-applications tbody');
    if (!tbody) return;
    // Rows come in pairs: the visible row, then its hidden detail row.
    const pairs = [];
    const rows = Array.from(tbody.querySelectorAll('tr.app-row'));
    rows.forEach(row => {
      const detail = row.nextElementSibling;
      const overall = Number(row.querySelector('.td-overall')?.dataset.overall ?? -1);
      pairs.push({ row, detail, overall });
    });
    pairs.sort((a, b) => overallSortDesc ? b.overall - a.overall : a.overall - b.overall);
    pairs.forEach(p => { tbody.appendChild(p.row); if (p.detail) tbody.appendChild(p.detail); });
    overallSortDesc = !overallSortDesc;
  });

  // ── CSV export ───────────────────────────────────────────────────────────
  function tableToCSV(tableEl) {
    const rows = [];
    tableEl.querySelectorAll('tr').forEach(tr => {
      if (tr.classList.contains('detail-row')) return;
      const cells = [...tr.querySelectorAll('th, td')].slice(0, -1); // skip expand col
      rows.push(cells.map(c => `"${c.textContent.trim().replace(/"/g, '""')}"`).join(','));
    });
    return rows.join('\n');
  }

  function downloadCSV(csv, filename) {
    const blob = new Blob([csv], { type: 'text/csv' });
    const a = Object.assign(document.createElement('a'), {
      href: URL.createObjectURL(blob),
      download: filename,
    });
    a.click();
    URL.revokeObjectURL(a.href);
  }

  document.getElementById('export-apps')?.addEventListener('click', () => {
    const table = document.querySelector('#tab-applications .admin-table');
    if (table) downloadCSV(tableToCSV(table), 'applications.csv');
  });

  document.getElementById('export-interns')?.addEventListener('click', () => {
    const table = document.querySelector('#tab-internships .admin-table');
    if (table) downloadCSV(tableToCSV(table), 'internships.csv');
  });

  document.getElementById('export-builders')?.addEventListener('click', () => {
    const table = document.querySelector('#tab-builders .admin-table');
    if (table) downloadCSV(tableToCSV(table), 'startup-builders.csv');
  });

  // ── Trait guide toggle ────────────────────────────────────────────────
  document.querySelectorAll('[id^="guide-toggle-"]').forEach(toggle => {
    toggle.addEventListener('click', () => {
      const builderId = toggle.id.replace('guide-toggle-', '');
      const panel = document.getElementById(`guide-panel-${builderId}`);
      if (panel) {
        panel.classList.toggle('hidden');
        toggle.textContent = panel.classList.contains('hidden') ? '+ Show trait guide' : '− Hide trait guide';
      }
    });
  });
</script>
