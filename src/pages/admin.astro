---
import Layout from '../layouts/Layout.astro';
import { db } from '../db';
import { applications, internships, builderApplications } from '../db/schema';
import { desc } from 'drizzle-orm';
import { scoreBreakdown, computeOverallScore, type SkillEntry } from '../lib/skills';
import { buildBuilderInterviewGuide, buildCapabilityGuide } from '../lib/interview-questions';

// Labels for the builder tab
const TRAIT_LABELS: Record<string, string> = {
  drive: 'Drive', growth: 'Growth', ownership: 'Ownership',
  tolerance: 'Tolerance', ego: 'Low Ego', ambition: 'Ambition', loyalty: 'Loyalty',
};
const LANG_LABELS: Record<string, string> = { id: '🇮🇩 Indonesian', en: '🇬🇧 English' };
const DRIVER_LABELS: Record<string, string> = {
  build: 'Build something lasting', learn: 'Get better fast', own: 'Own big things',
  money: 'Earn well soon', status: 'Title & recognition', comfort: 'Comfort & stability',
};
const TRAIT_GUIDE: Record<string, string> = {
  drive: '▪ What it is: Keeps grinding on hard, unglamorous work without being chased. Real intrinsic motivation, not just pay/status. ▪ Strong (80+): Chooses boring work, describes "worked hard for no money" with specificity & joy. ▪ Weak (0–40): Avoids unglamorous tasks, vague on why they\'d keep going without reward. ▪ Red flags: "I do it because my boss told me to" or "if pay stopped, I\'d leave." ▪ Interview: Ask "Tell me about the most boring work you\'ve done that actually mattered. Why did you finish it?" ▪ In writing: Look for specificity—what was the task, why did it matter, what did they actually do?',
  growth: '▪ What it is: Learns fast & independently. Doesn\'t wait for training courses; runs toward things they can\'t do yet. ▪ Strong (80+): Digs into docs, ships something fast, measures success concretely. ▪ Weak (0–40): Waited for formal training, or doesn\'t have examples of self-directed learning. ▪ Red flags: "I watched YouTube but didn\'t ship anything" or "I waited for proper training." ▪ Interview: Ask "When have you had to learn something hard, fast, because the deadline was real? What did you actually do?" ▪ In writing: Urgency signals real learning. Look for: problem → tried → shipped → measured.',
  ownership: '▪ What it is: Treats problems as theirs even when "not my job." Finds a way instead of waiting for permission. ▪ Strong (80+): Solves problems proactively, moves forward under ambiguity, doesn\'t wait for clarity. ▪ Weak (0–40): Waits for instruction, reports problems and leaves them, "that\'s not my responsibility." ▪ Red flags: "I told my boss and waited" or "I focused on my own work." ▪ Interview: Ask "Tell me about a time you solved a problem that wasn\'t formally yours. Why did you own it?" ▪ In writing: Real ownership means no excuses, no blame-shifting. "I saw X was broken, I fixed it, I told my boss."',
  tolerance: '▪ What it is: Comfortable with ambiguity, changing priorities, limited resources. Doesn\'t crumble. ▪ Strong (80+): Shifts priorities mid-week without resentment, sees constraints as creative problems, focuses on what matters now. ▪ Weak (0–40): Panics when plans change, gets frustrated, assumes perfect conditions. ▪ Red flags: "I hate changing priorities" or answers that assume stable, clear, well-resourced conditions. ▪ Interview: Ask "What happens when the company changes priorities mid-week and kills your project? How do you feel?" Listen for acceptance, not resentment. ▪ In writing: Do they adapt or resist? Do they focus on sunk costs or on what\'s next?',
  ego: '▪ What it is: Takes hard feedback without defending. Credits others. Refuses to ship junk. ▪ Strong (80+): Actively seeks critical feedback, credits collaborators, owns mistakes directly. ▪ Weak (0–40): Defends when criticized, centers themselves, ships without quality bar. ▪ Red flags: "Everyone else was wrong" or "I\'d ship it and fix it later" (without holding a bar). ▪ Interview: Ask "Tell me about a time a junior or peer pointed out a real flaw in your work. How did you respond?" ▪ In writing: Do they credit others? When they describe a mistake, do they own it directly?',
  ambition: '▪ What it is: Finishes what they start. Builds things that last. Not distracted by shiny. Has a real reason they\'re here *now*. ▪ Strong (80+): Specific vision (not generic), has shipped/completed things, why this work not just any startup. ▪ Weak (0–40): "I jump between interests" or "I want to grow and learn" (everyone says that). ▪ Red flags: No track record of follow-through, generic vision, or jumping every year. ▪ Interview: Ask "Where do you want to be in 5 years? Why is this the work you want to do *now*?" Generic answers = weak ambition. ▪ In writing: Concrete ≠ generic. "Ship AI for Indonesia" beats "work on cool projects."',
  loyalty: '▪ What it is: Stays & digs in through hard times, not poached for small raises. Mission/team invested, not just paycheck. ▪ Strong (80+): Chooses loyalty even when competitor+40%, stays in rough quarters, mission/team talk. ▪ Weak (0–40): Takes competitor offer, leaves in downturns, "salary is the main thing." ▪ Red flags: Money is top driver, loyalty scenarios answered money-first, "I go where the best opportunity is." ▪ Interview: Ask "If a competitor offered you 40% more after we\'ve trained you, what would you do?" and "What would make you stay if things got hard?" ▪ In writing: Do they talk mission/team or just pay/title?',
};

// Concise hover tips: what the number means, what's good, when it turns bad.
const METRIC_TIPS: Record<string, string> = {
  builder: 'Builder Score — overall fit (weighted blend of all 7 traits).\n🟢 70+ strong  ·  60–79 worth a trial  ·  40–59 borderline  ·  below 40 likely not a fit.',
  loyalty: 'Loyalty — will they stay through hard times?\n🟢 70+ committed  ·  55–69 ok  ·  below 55 flight risk (may leave for a small raise).',
  sjt: 'SJT — judgment on the hidden-key startup scenarios (can\'t be gamed).\n🟢 65+ good judgment  ·  45–64 mixed  ·  below 45 weak trade-off decisions.',
  money: 'Money Orientation — how money-driven they are (higher = more).\n🟢 below 55 mission-leaning  ·  55–74 mixed  ·  75+ money-primary (expect them to leave if poached).',
};
const TRAIT_TIP: Record<string, string> = {
  drive: 'Drive — keeps going on hard, unglamorous work.\n🟢 70+ self-motivated  ·  below 55 needs external reward to push.',
  growth: 'Growth — learns fast & independently.\n🟢 70+ self-starter  ·  below 55 waits to be taught.',
  ownership: 'Ownership — treats problems as theirs, even outside their role.\n🟢 70+ takes charge  ·  below 55 "not my job" risk.',
  tolerance: 'Tolerance — handles ambiguity & shifting priorities.\n🟢 70+ thrives in chaos  ·  below 55 struggles in a startup.',
  ego: 'Low Ego — takes hard feedback, refuses to ship junk.\n🟢 70+ coachable & high standard  ·  below 55 defensive or sloppy.',
  ambition: 'Ambition — finishes what they start; long-term.\n🟢 70+ committed  ·  below 55 jumps between interests.',
  loyalty: 'Loyalty — stays & digs in; not just a paycheck.\n🟢 70+ loyal  ·  below 55 flight risk.',
};

// The exact prompts candidates were shown, plus what a strong vs weak answer looks like.
const WRITTEN_PROMPTS: Record<string, { title: string; question: string; look: string; good: string; bad: string }> = {
  workSample: {
    title: 'First 72 hours (work sample)',
    question: 'Scenario shown: "A mid-sized Indonesian retailer signs with us Monday. They want \'AI to cut customer-service costs,\' but the data is messy, three teams disagree on priorities, and the CEO expects something real within two weeks." → What would you actually do in your first 72 hours? Be concrete.',
    look: 'Do they understand the messiness? Are they specific (who they\'d talk to, what they\'d look at, what they\'d ship first)? This is the single most predictive answer — it\'s a mini work-sample.',
    good: 'Day-by-day plan: talk to the disagreeing teams to define what "cut costs" means to each, audit data to find the limiting step, ship a small 80% solution on high-confidence data.',
    bad: '"I\'d learn about the business and make a plan." Generic, no specifics, no understanding of the chaos.',
  },
  storyLearning: {
    title: 'Learning under fire',
    question: 'Tell us about a time you taught yourself something hard, fast, because you had to. What did you do, and how did you know it worked?',
    look: 'Self-direction, speed, and a concrete outcome. Urgency signals real learning (vs hobby learning).',
    good: '"Had to learn SQL in a week, built a test DB from our live schema, wrote my first query to pull retention — it worked, we used it for 3 months."',
    bad: '"I took an online course." No urgency, no proof it worked, no shipping.',
  },
  vision: {
    title: 'Where they\'re headed (vision + drive)',
    question: 'Where do you want to be in 3–5 years, and why is this the work you want to be doing now?',
    look: 'Concrete ambition, not vague aspirations. Why THIS work, not just any startup.',
    good: '"Want to ship AI products Indonesia actually uses. Here because TMK builds for real SEA problems. In 5 years, lead product for our retail module."',
    bad: '"I want to grow and learn and work with a good team." Every candidate says this — it means nothing.',
  },
  noMoneyStory: {
    title: 'Worked hard with little / no money',
    question: 'Tell us about a time you worked really hard on something when there was little or no money or reward in it. What was it, and why did you keep going?',
    look: 'Real struggle, real choice, real outcome. Intrinsic motivation — the strongest loyalty/drive signal.',
    good: '"Built a side project to parse Indonesian banking APIs because I was frustrated no open tools existed. 6 months of nights/weekends, never made money, now two startups use it. Did it because the problem was real."',
    bad: '"I volunteer" or "I did unpaid work because I had to." Obligation, not choice. No real struggle described.',
  },
};

// ── Auth: require ?token=ADMIN_TOKEN or Authorization header ──────────────────
const adminToken = import.meta.env.ADMIN_TOKEN;

if (!adminToken) {
  return new Response('ADMIN_TOKEN env var not set.', { status: 500 });
}

const url   = new URL(Astro.request.url);
const token = url.searchParams.get('token')
           ?? Astro.request.headers.get('x-admin-token');

if (token !== adminToken) {
  return new Response('Unauthorized', { status: 401 });
}

// ── Fetch data ────────────────────────────────────────────────────────────────
const apps   = await db.select().from(applications).orderBy(desc(applications.createdAt));
const interns= await db.select().from(internships) .orderBy(desc(internships.createdAt));
const builders = await db.select().from(builderApplications).orderBy(desc(builderApplications.createdAt));

// Keep token in links so navigation stays authenticated
const t = `?token=${encodeURIComponent(adminToken)}`;

// Professional-track interview guide is role-based and identical per candidate
// (no character scores captured for this track yet — see doc/recruitment-funnel.md).
const capabilityGuide = buildCapabilityGuide();

// Stage 6 calibration roster: every hired candidate across all three tracks,
// with predicted score (Overall/character/builder) alongside actual performance
// once reviewed. See doc/recruitment-funnel.md §6 — this is what makes the
// scoring weights trustworthy over time instead of an educated guess.
const calibrationRows = [
  ...apps.filter(a => a.hiredAt).map(a => ({
    track: 'applications' as const, id: a.id, name: `${a.firstName} ${a.lastName}`, role: a.role.replace(/-/g, ' '),
    hiredAt: a.hiredAt,
    predicted: computeOverallScore({
      role: a.role, characterScore: a.characterScore, jobKnowledgeScore: a.jobKnowledgeScore,
      interviewScores: (() => { try { return JSON.parse(a.interviewScores ?? '{}'); } catch { return {}; } })(),
      hasCapabilityLayer: true,
    }),
    actual: a.actualPerformanceScore, notes: a.actualPerformanceNotes, reviewedAt: a.performanceReviewedAt,
  })),
  ...interns.filter(i => i.hiredAt).map(i => ({
    track: 'internships' as const, id: i.id, name: `${i.firstName} ${i.lastName}`, role: i.area.replace(/-/g, ' '),
    hiredAt: i.hiredAt, predicted: i.characterScore,
    actual: i.actualPerformanceScore, notes: i.actualPerformanceNotes, reviewedAt: i.performanceReviewedAt,
  })),
  ...builders.filter(b => b.hiredAt).map(b => ({
    track: 'builder' as const, id: b.id, name: `${b.firstName} ${b.lastName}`, role: b.area.replace(/-/g, ' '),
    hiredAt: b.hiredAt, predicted: b.builderScore,
    actual: b.actualPerformanceScore, notes: b.actualPerformanceNotes, reviewedAt: b.performanceReviewedAt,
  })),
].sort((x, y) => new Date(y.hiredAt!).getTime() - new Date(x.hiredAt!).getTime());
---

<Layout
  title="Admin — Trans Meta Teknologi"
  description="Internal admin dashboard"
>
  <main id="admin-main">
    <div class="admin-container">

      <!-- Header -->
      <div class="admin-header">
        <div class="admin-logo">
          <div class="admin-logo-dot"></div>
          <span>TransMetaTek Admin</span>
        </div>
        <div class="admin-meta">
          <span class="admin-badge">{apps.length} applications</span>
          <span class="admin-badge">{interns.length} internships</span>
          <span class="admin-badge">{builders.length} builders</span>
        </div>
      </div>

      <!-- Tabs -->
      <div class="admin-tabs">
        <button class="admin-tab active" data-tab="applications">
          Job Applications
          <span class="tab-count">{apps.length}</span>
        </button>
        <button class="admin-tab" data-tab="internships">
          Internship Applications
          <span class="tab-count">{interns.length}</span>
        </button>
        <button class="admin-tab" data-tab="builders">
          Startup Builders
          <span class="tab-count">{builders.length}</span>
        </button>
        <button class="admin-tab" data-tab="calibration">
          Calibration
          <span class="tab-count">{calibrationRows.length}</span>
        </button>
      </div>

      <!-- ── Job Applications Tab ── -->
      <div class="tab-panel" id="tab-applications">
        {apps.length === 0 ? (
          <div class="empty-state">No applications yet.</div>
        ) : (
          <div class="table-scroll">
            <table class="admin-table">
              <thead>
                <tr>
                  <th>#</th>
                  <th>Name</th>
                  <th>Email</th>
                  <th>Role</th>
                  <th>Exp</th>
                  <th>Skills</th>
                  <th>Screen</th>
                  <th class="th-sortable" id="sort-apps-overall" title="Mechanical roll-up: w·Character + (1-w)·Capability — click to sort">Overall ↕</th>
                  <th>LinkedIn</th>
                  <th>Submitted</th>
                  <th></th>
                </tr>
              </thead>
              <tbody>
                {apps.map(a => {
                  const breakdown = scoreBreakdown(a);
                  let workHistory: { company: string; position: string; startDate: string; endDate: string; current: boolean; salary?: string; reason?: string; description: string }[] = [];
                  try { workHistory = JSON.parse(a.workHistory ?? '[]'); } catch { workHistory = []; }
                  let currentOrg: { company: string; position: string; startDate: string; endDate: string; current: boolean } | null = null;
                  if (a.currentOrg) {
                    try { currentOrg = JSON.parse(a.currentOrg); } catch { currentOrg = { company: a.currentOrg, position: '', startDate: '', endDate: '', current: false }; }
                  }
                  const aTraitScores = a.assessmentCompletedAt ? (() => { try { return JSON.parse(a.traitScores ?? '{}'); } catch { return {}; } })() : null;
                  const aCharacterGuide = aTraitScores ? buildBuilderInterviewGuide(aTraitScores, a.moneyOrientation) : null;
                  const aMoneyClass = a.moneyOrientation == null ? '' : a.moneyOrientation >= 75 ? 'flag-high' : a.moneyOrientation >= 55 ? 'flag-mid' : 'flag-low';
                  const aInterviewScores = (() => { try { return JSON.parse(a.interviewScores ?? '{}'); } catch { return {}; } })();
                  const aOverall = computeOverallScore({ role: a.role, characterScore: a.characterScore, jobKnowledgeScore: a.jobKnowledgeScore, interviewScores: aInterviewScores, hasCapabilityLayer: true });
                  return (
                  <>
                  <tr class="app-row" data-id={a.id}>
                    <td class="td-id">{a.id}</td>
                    <td class="td-name">
                      <div class="name-cell">
                        {a.photo
                          ? <img src={a.photo} alt="" class="name-photo" />
                          : <span class="name-initials">{a.firstName[0]}{a.lastName[0]}</span>}
                        <span>{a.firstName} {a.lastName}</span>
                      </div>
                    </td>
                    <td><a href={`mailto:${a.email}`} class="td-link">{a.email}</a></td>
                    <td>
                      <span class={`role-badge role-${a.role}`}>
                        {a.role.replace(/-/g, ' ')}
                      </span>
                    </td>
                    <td class="td-mono">{a.experience}</td>
                    <td class="td-skills-wrap">
                      <div class="td-skills">
                        {breakdown.entries.slice(0, 4).map((e: SkillEntry) => (
                          <span class={`skill-tag prof-${e.proficiency}`} title={`${e.proficiency}${e.yearStarted ? ' · since ' + e.yearStarted : ''}`}>{e.skill}</span>
                        ))}
                        {breakdown.entries.length > 4 && <span class="skill-tag-more">+{breakdown.entries.length - 4}</span>}
                      </div>
                    </td>
                    <td>
                      <div class="screen-control" data-track="applications" data-id={a.id}>
                        <button class={`screen-btn screen-pass ${a.screenStatus === 'pass' ? 'active' : ''}`} data-status="pass" title="Pass — proceed to assessment">Pass</button>
                        <button class={`screen-btn screen-hold ${a.screenStatus === 'hold' ? 'active' : ''}`} data-status="hold" title="Hold — needs another look">Hold</button>
                        <button class={`screen-btn screen-reject ${a.screenStatus === 'reject' ? 'active' : ''}`} data-status="reject" title="Reject">Reject</button>
                      </div>
                    </td>
                    <td class="td-mono td-overall" data-overall={aOverall ?? -1}>{aOverall != null ? `${aOverall}%` : '—'}</td>
                    <td>
                      {a.linkedin
                        ? <a href={a.linkedin.startsWith('http') ? a.linkedin : `https://${a.linkedin}`}
                            target="_blank" rel="noopener" class="td-link">View ↗</a>
                        : <span class="td-muted">—</span>
                      }
                    </td>
                    <td class="td-mono td-date">{new Date(a.createdAt).toLocaleDateString('en-GB', { day:'2-digit', month:'short', year:'numeric' })}</td>
                    <td>
                      <button class="btn-expand" data-app-id={a.id}>
                        <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                          <path d="M3 5l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      </button>
                    </td>
                  </tr>
                  <tr class="detail-row hidden" id={`app-detail-${a.id}`}>
                    <td colspan="11">
                      <div class="detail-panel">
                        <div class="app-overview-card">
                          <div class="app-overview">
                            {a.photo
                              ? <img src={a.photo} alt={`${a.firstName} ${a.lastName}`} class="builder-photo-large" />
                              : <div class="builder-photo-large builder-photo-placeholder">{a.firstName[0]}{a.lastName[0]}</div>}
                            <div class="app-overview-body">
                              <div class="app-overview-header">
                                <div class="app-photo-info">
                                  <div class="builder-photo-name">{a.firstName} {a.lastName}</div>
                                  <div class="builder-photo-meta">{a.role.replace(/-/g, ' ')} · {a.city} · {a.experience} yrs exp · {a.email}</div>
                                </div>
                                {aOverall != null && (
                                  <div class="app-photo-overall">
                                    <span class="app-photo-overall-val">{aOverall}%</span>
                                    <span class="app-photo-overall-label">Overall score</span>
                                  </div>
                                )}
                              </div>
                              <div class="score-breakdown">
                                <div class="score-breakdown-head">
                                  <span class="detail-label">Profile completeness (reference only — not a screening decision)</span>
                                </div>
                                <div class="score-breakdown-rows">
                                  {breakdown.rows.map(row => (
                                    <div class="score-breakdown-row">
                                      <div class="score-breakdown-bar"><div class="score-breakdown-fill" style={`width:${row.max ? (row.pts / row.max) * 100 : 0}%`}></div></div>
                                      <span class="score-breakdown-label">{row.label}</span>
                                      <span class="score-breakdown-note">{row.note}</span>
                                      <span class="score-breakdown-pts td-mono">+{row.pts}/{row.max}</span>
                                    </div>
                                  ))}
                                </div>
                              </div>
                            </div>
                          </div>
                        </div>
                        <div class="detail-grid">
                          <div class="detail-block">
                            <div class="detail-label">City</div>
                            <div class="detail-value">{a.city}</div>
                          </div>
                          {a.phone && (
                            <div class="detail-block">
                              <div class="detail-label">Phone</div>
                              <div class="detail-value">{a.phone}</div>
                            </div>
                          )}
                          {currentOrg && (currentOrg.company || currentOrg.position) && (
                            <div class="detail-block">
                              <div class="detail-label">Current / most recent organisation</div>
                              <div class="detail-value">
                                {currentOrg.position || '—'}{currentOrg.company ? ` · ${currentOrg.company}` : ''}
                                <div class="wh-card-dates">
                                  {currentOrg.startDate || '—'} – {currentOrg.current ? 'Present' : (currentOrg.endDate || '—')}
                                </div>
                              </div>
                            </div>
                          )}
                          {a.portfolio && (
                            <div class="detail-block">
                              <div class="detail-label">Portfolio</div>
                              <a href={a.portfolio.startsWith('http') ? a.portfolio : `https://${a.portfolio}`}
                                target="_blank" rel="noopener" class="td-link detail-value">{a.portfolio}</a>
                            </div>
                          )}
                          {a.currentSalary && (
                            <div class="detail-block">
                              <div class="detail-label">Current salary</div>
                              <div class="detail-value">{a.currentSalary}</div>
                            </div>
                          )}
                          {a.expectedSalary && (
                            <div class="detail-block">
                              <div class="detail-label">Expected salary</div>
                              <div class="detail-value">{a.expectedSalary}</div>
                            </div>
                          )}
                        </div>
                        {breakdown.entries.length > 0 && (
                          <div class="detail-block full">
                            <div class="detail-label">All skills</div>
                            <div class="detail-value">
                              {breakdown.entries.map((e: SkillEntry) => (
                                <span class={`skill-tag prof-${e.proficiency}`} title={`${e.proficiency}${e.yearStarted ? ' · since ' + e.yearStarted : ''}`}>{e.skill}</span>
                              ))}
                            </div>
                          </div>
                        )}
                        {workHistory.length > 0 && (
                          <div class="detail-block full">
                            <div class="detail-label">Work history</div>
                            <div class="work-history-cards">
                              {workHistory.map(w => (
                                <div class="wh-card">
                                  <div class="wh-card-head">
                                    <span class="wh-card-position">{w.position || '—'}</span>
                                    {w.company && <span class="wh-card-company">· {w.company}</span>}
                                  </div>
                                  <div class="wh-card-dates">
                                    {w.startDate || '—'} – {w.current ? 'Present' : (w.endDate || '—')}
                                    {w.salary && ` · Rp. ${w.salary}`}
                                  </div>
                                  {w.reason && <div class="wh-card-reason"><strong>Reason for leaving:</strong> {w.reason}</div>}
                                  {w.description && <div class="wh-card-desc">{w.description}</div>}
                                </div>
                              ))}
                            </div>
                          </div>
                        )}
                        <div class="detail-block full">
                          <div class="detail-label">Why TransMetaTek</div>
                          <div class="detail-value detail-text">{a.whyTmk}</div>
                        </div>
                        <div class="detail-block full">
                          <div class="detail-label">AI Project</div>
                          <div class="detail-value detail-text">{a.aiProject}</div>
                        </div>
                        <div class="detail-block full">
                          <div class="detail-label">Role Question</div>
                          <div class="detail-value detail-text">{a.roleQuestion}</div>
                        </div>
                        {a.workSample && (
                          <div class="detail-block full">
                            <div class="detail-label">First 72 hours (work scenario)</div>
                            <div class="detail-value detail-text">{a.workSample}</div>
                          </div>
                        )}
                        {a.storyLearning && (
                          <div class="detail-block full">
                            <div class="detail-label">Learning under fire</div>
                            <div class="detail-value detail-text">{a.storyLearning}</div>
                          </div>
                        )}
                        {a.vision && (
                          <div class="detail-block full">
                            <div class="detail-label">Where they're headed</div>
                            <div class="detail-value detail-text">{a.vision}</div>
                          </div>
                        )}
                        {a.noMoneyStory && (
                          <div class="detail-block full">
                            <div class="detail-label">Hard work, no reward</div>
                            <div class="detail-value detail-text">{a.noMoneyStory}</div>
                          </div>
                        )}

                        {aTraitScores ? (
                          <div class="detail-block full">
                            <div class="detail-label">Character assessment</div>
                            <div class="trait-grid">
                              {Object.entries(TRAIT_LABELS).map(([key, label]) => (
                                <div class="trait-mini has-tip" title={TRAIT_TIP[key]}>
                                  <div class="trait-mini-head">
                                    <span>{label}</span>
                                    <span class="td-mono">{Math.round(aTraitScores[key] ?? 0)}%</span>
                                  </div>
