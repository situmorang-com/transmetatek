                  const strengths = traitEntries.filter(t => t.val >= 70).slice(0, 3);
                  const weaknesses = traitEntries.filter(t => t.val < 55).slice(-3).reverse();

                  // Overall verdict
                  let verdict = '', verdictClass = '', verdictWhy = '';
                  if (score >= 80) {
                    verdict = 'Strong candidate — invite to paid trial';
                    verdictClass = 'verdict-strong';
                    verdictWhy = 'Strong builder signals across the board. Read the written answers to confirm depth, then move to a paid trial.';
