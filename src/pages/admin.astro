                        : <span class="td-muted">—</span>}
                    </td>
                    <td class="td-mono td-date">
                      <div>{new Date(b.createdAt).toLocaleDateString('en-GB', { day:'2-digit', month:'short', year:'numeric' })}</div>
                      <div style="font-size:0.75rem;color:var(--text-muted);">{new Date(b.createdAt).toLocaleTimeString('en-GB', { hour:'2-digit', minute:'2-digit' })}</div>
                    </td>
                    <td>
                      <button class="btn-expand" data-builder-id={b.id}>
                        <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 5l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                      </button>
                    </td>
                  </tr>
                  <tr class="detail-row hidden" id={`builder-detail-${b.id}`}>
                    <td colspan="14">
                      <div class="detail-panel">
                        <div class={`verdict-card ${verdictClass}`}>
                          <div class="verdict-main">
                            {b.photo
                              ? <img src={b.photo} alt={`${b.firstName} ${b.lastName}`} class="builder-photo-large" />
                              : <div class="builder-photo-large builder-photo-placeholder">{b.firstName[0]}{b.lastName[0]}</div>}
                            <div class="verdict-body">
                              <div class="verdict-header">
                                <div class="verdict-id">
                                  <div class="builder-photo-name">{b.firstName} {b.lastName}</div>
                                  <div class="builder-photo-meta">{b.area.replace(/-/g, ' ')} · {b.city} · {LANG_LABELS[b.interviewLanguage] ?? b.interviewLanguage} · {b.email}</div>
                                </div>
                                <div class="verdict-score-block">
                                  <div class="verdict-score">{score}%</div>
                                  <div class="verdict-score-label">Builder Score</div>
                                </div>
                              </div>
                              <div class="verdict-verdict">
                                <div class="verdict-headline">{verdict}</div>
                                <div class="verdict-why">{verdictWhy}</div>
                              </div>
                              <div class="verdict-detail-row">
                                <div class="verdict-col">
                                  <div class="verdict-col-label">✅ Strengths (70%+)</div>
                                  {strengths.length > 0
                                    ? <div class="verdict-chips">{strengths.map(s => <span class="verdict-chip chip-strong">{s.label} {s.val}%</span>)}</div>
                                    : <div class="verdict-none">No standout strengths above 70%.</div>}
                                </div>
                                <div class="verdict-col">
                                  <div class="verdict-col-label">⚠ Watch areas (below 55%)</div>
                                  {weaknesses.length > 0
                                    ? <div class="verdict-chips">{weaknesses.map(w => <span class="verdict-chip chip-weak">{w.label} {w.val}%</span>)}</div>
                                    : <div class="verdict-none">No traits below 55% — well-rounded.</div>}
                                </div>
                              </div>
                            </div>
                          </div>
                          {moneyNote && <div class="verdict-money">{moneyNote}</div>}
                          <div class="verdict-footer">The score ranks and flags — it does not decide. Read the written answers below; they are your real tiebreaker. Every builder is reviewed by a person.</div>
                        </div>
                        <div class="detail-block full">
                          <div class="detail-label">Hiring outcome (Stage 6 calibration)</div>
                          <div class="hire-outcome" data-track="builder" data-id={b.id}>
                            <button type="button" class={`btn-outline hire-toggle-btn ${b.hiredAt ? 'is-hired' : ''}`} style="padding:0.35rem 0.8rem;font-size:0.78rem;">
                              {b.hiredAt ? `Hired ${new Date(b.hiredAt).toLocaleDateString('en-GB', { day:'2-digit', month:'short', year:'numeric' })} — click to unmark` : 'Mark as Hired'}
                            </button>
                            {b.hiredAt && <span class="hire-note">Review actual performance in the Calibration tab once 3–6 months have passed.</span>}
                          </div>
                        </div>
                        <div class="detail-block full">
                          <div class="detail-label">Trait signal</div>
                          <div class="trait-grid">
                            {Object.entries(TRAIT_LABELS).map(([key, label]) => (
                              <div class="trait-mini has-tip" title={TRAIT_TIP[key]}>
                                <div class="trait-mini-head">
                                  <span>{label}</span>
                                  <span class="td-mono">{Math.round(ts[key] ?? 0)}%</span>
                                </div>
                                <div class="trait-mini-track"><div class="trait-mini-fill" style={`width:${Math.round(ts[key] ?? 0)}%`}></div></div>
                              </div>
                            ))}
                          </div>
                          <div class="trait-guide-toggle" id={`guide-toggle-${b.id}`} style="margin-top:0.75rem;cursor:pointer;font-size:0.8rem;color:var(--text-muted);text-decoration:underline;">+ Show trait guide</div>
                          <div class="trait-guide-panel hidden" id={`guide-panel-${b.id}`} style="margin-top:1rem;padding:1rem;background:rgba(255,255,255,0.04);border-radius:6px;border-left:3px solid var(--cyan);">
                            {Object.entries(TRAIT_LABELS).map(([key, label]) => (
                              <div style="margin-bottom:0.75rem;font-size:0.8rem;">
                                <strong style="color:var(--text-primary);">{label}</strong>
                                <p style="margin:0.25rem 0 0 0;color:var(--text-muted);">{TRAIT_GUIDE[key]}</p>
                              </div>
                            ))}
                          </div>
                        </div>
                        <div class="detail-block full">
                          <div class="detail-label">Loyalty &amp; money signal (admin only)</div>
                          <div class="detail-grid">
                            <div class="detail-block">
                              <div class="detail-label">Loyalty index</div>
                              <div class="detail-value td-mono">{b.loyaltyScore != null ? b.loyaltyScore + '%' : '—'}</div>
                            </div>
                            <div class="detail-block">
                              <div class="detail-label">Money orientation</div>
                              <div class="detail-value">
                                {money != null
                                  ? <span class={`money-flag ${moneyClass}`}>{money}% {money >= 75 ? '· money-primary' : money >= 55 ? '· mixed' : '· mission-leaning'}</span>
                                  : '—'}
                              </div>
                            </div>
                            <div class="detail-block">
                              <div class="detail-label">Drives them MOST</div>
                              <div class="detail-value">{dv.most ? (DRIVER_LABELS[dv.most] ?? dv.most) : '—'}</div>
                            </div>
                            <div class="detail-block">
                              <div class="detail-label">Drives them LEAST</div>
                              <div class="detail-value">{dv.least ? (DRIVER_LABELS[dv.least] ?? dv.least) : '—'}</div>
                            </div>
                          </div>
                        </div>
                        <div class="detail-grid">
                          {b.portfolio && (
                            <div class="detail-block">
                              <div class="detail-label">Portfolio</div>
                              <a href={b.portfolio.startsWith('http') ? b.portfolio : `https://${b.portfolio}`}
                                target="_blank" rel="noopener" class="td-link detail-value">{b.portfolio}</a>
                            </div>
                          )}
                          {b.phone && (
                            <div class="detail-block">
                              <div class="detail-label">WhatsApp</div>
                              <a href={`https://wa.me/${b.phone.replace(/[^0-9]/g, '')}`} target="_blank" rel="noopener" class="td-link detail-value">{b.phone} ↗</a>
                            </div>
                          )}
                          <div class="detail-block">
                            <div class="detail-label">City</div>
                            <div class="detail-value">{b.city}</div>
                          </div>
                        </div>
                        <div class="detail-block full">
                          <div class="detail-label">Written answers — read these to decide</div>
                        </div>
                        {([['workSample', b.workSample], ['storyLearning', b.storyLearning], ['vision', b.vision], ['noMoneyStory', b.noMoneyStory]] as const).map(([key, answer]) => {
                          const p = WRITTEN_PROMPTS[key];
                          if (!answer) return null;
                          return (
                            <div class="answer-block">
                              <div class="answer-title">{p.title}</div>
                              <div class="answer-question">{p.question}</div>
                              <div class="answer-look"><strong>What to look for:</strong> {p.look}</div>
                              <div class="answer-examples">
                                <div class="answer-example answer-good"><span class="answer-tag tag-good">Strong</span> {p.good}</div>
                                <div class="answer-example answer-bad"><span class="answer-tag tag-bad">Weak</span> {p.bad}</div>
                              </div>
                              <div class="answer-their-label">Their answer ({(answer.trim().split(/\s+/).length)} words):</div>
                              <div class="answer-text">{answer}</div>
                            </div>
                          );
                        })}

                        <div class="detail-block full">
                          <div class="detail-label">Offline interview guide — tailored to this candidate</div>
                          <div class="iguide-intro">Ordered by priority. Spend your time on the <span class="ip ip-probe">probe hard</span> items — those are where the assessment flags risk. Score each answer 1 / 3 / 5 against the anchors.</div>
                        </div>
                        {interviewGuide.map(item => (
                          <div class={`iguide-item ip-border-${item.priority}`}>
                            <div class="iguide-head">
                              <span class="iguide-attr">{item.label}</span>
                              <span class={`ip ip-${item.priority}`}>{item.priority === 'probe-hard' ? 'probe hard' : item.priority}</span>
                              {item.score != null && <span class="iguide-score td-mono">{item.score}%</span>}
                              <div class="iscore-control" data-track="builder" data-id={b.id} data-attr={item.attribute}>
                                {[1, 3, 5].map(lvl => (
                                  <button type="button" class={`iscore-btn ${bInterviewScores[item.attribute] === lvl ? 'active' : ''}`} data-level={lvl}>{lvl}</button>
                                ))}
                              </div>
                            </div>
                            <div class="iguide-reason">{item.reason}</div>
                            {item.questions.map(q => {
                              const tied = q.tiesTo ? writtenFor[q.tiesTo] : null;
                              return (
                                <div class="iguide-q">
                                  <div class="iguide-q-head"><span class={`iguide-qtype qt-${q.type}`}>{q.type}</span></div>
                                  <div class="iguide-q-text">{q.question}</div>
                                  <div class="iguide-listen"><strong>Listen for:</strong> {q.listenFor}</div>
                                  {tied && (
                                    <div class="iguide-tied">
                                      <span class="iguide-tied-label">Make them defend what they wrote:</span>
                                      <span class="iguide-tied-text">{tied}</span>
                                    </div>
                                  )}
                                  <div class="iguide-probes">
                                    <span class="iguide-probes-label">Follow-ups:</span>
                                    <ul>{q.probes.map(p => <li>{p}</li>)}</ul>
                                  </div>
                                  <div class="iguide-anchors">
                                    {q.anchors.map(a => (
                                      <div class={`iguide-anchor anchor-${a.level}`}>
                                        <span class="anchor-num">{a.level}</span>
                                        <span class="anchor-text">{a.text}</span>
                                      </div>
                                    ))}
                                  </div>
                                </div>
                              );
                            })}
                          </div>
                        ))}
                      </div>
                    </td>
                  </tr>
                  </>
                )})}
              </tbody>
            </table>
          </div>
        )}
        {builders.length > 0 && (
          <div class="table-footer">
            <button class="btn-export" id="export-builders">Export CSV</button>
          </div>
        )}
      </div>

      <!-- ── Calibration Tab (Stage 6: predicted vs actual) ── -->
      <div class="tab-panel hidden" id="tab-calibration">
        <div class="calibration-intro">
          Every hire's predicted score (Overall / Character / Builder) next to their actual on-the-job
          performance, reviewed by a person at 3–6 months. This is the only honest check on whether the
          funnel's weights track reality — without it, the scoring is an educated guess.
        </div>
        {calibrationRows.length === 0 ? (
          <div class="empty-state">No hires marked yet. Mark a candidate as "Hired" from their detail panel in the other tabs to start tracking calibration.</div>
        ) : (
          <div class="table-scroll">
            <table class="admin-table">
              <thead>
                <tr>
                  <th>Name</th>
                  <th>Track</th>
                  <th>Role / Area</th>
                  <th>Hired</th>
                  <th>Predicted</th>
                  <th>Actual performance</th>
                  <th>Reviewed</th>
                  <th>Notes</th>
                </tr>
              </thead>
              <tbody>
                {calibrationRows.map(row => (
                  <tr>
                    <td class="td-name">{row.name}</td>
                    <td><span class="role-badge">{row.track === 'applications' ? 'Job' : row.track === 'internships' ? 'Internship' : 'Builder'}</span></td>
                    <td>{row.role}</td>
                    <td class="td-mono td-date">{new Date(row.hiredAt!).toLocaleDateString('en-GB', { day:'2-digit', month:'short', year:'numeric' })}</td>
                    <td class="td-mono">{row.predicted != null ? `${row.predicted}%` : '—'}</td>
                    <td>
                      <div class="calib-review" data-track={row.track} data-id={row.id}>
                        <input type="number" min="0" max="100" class="calib-actual-input" placeholder="0-100" value={row.actual ?? ''} />
                        <button type="button" class="btn-outline calib-save-btn" style="padding:0.3rem 0.7rem;font-size:0.75rem;">Save</button>
                      </div>
                    </td>
                    <td class="td-mono td-date">{row.reviewedAt ? new Date(row.reviewedAt).toLocaleDateString('en-GB', { day:'2-digit', month:'short', year:'numeric' }) : '—'}</td>
                    <td>
                      <input type="text" class="calib-notes-input" data-track={row.track} data-id={row.id} placeholder="Notes..." value={row.notes ?? ''} style="background:rgba(255,255,255,0.03);border:1px solid var(--border);border-radius:6px;padding:0.3rem 0.5rem;font-size:0.78rem;color:var(--text-primary);width:160px;" />
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
      </div>

    </div>
  </main>
</Layout>

