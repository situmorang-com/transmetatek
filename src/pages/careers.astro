<script>
  // ── Internship form ────────────────────────────────────────────────────
  function wordCount(str) {
    return str.trim().split(/\s+/).filter(w => w.length > 0).length;
  }

  function wireWordCount(textareaId, countId, fillId) {
    const ta   = document.getElementById(textareaId);
    const cnt  = document.getElementById(countId);
    const fill = document.getElementById(fillId);
    if (!ta) return;
    ta.addEventListener('input', () => {
      const w = wordCount(ta.value);
      if (cnt)  cnt.textContent = w + (w === 1 ? ' word' : ' words');
      if (fill) fill.style.width = Math.min(w * 1.5, 100) + '%';
    });
  }

  wireWordCount('i-excites', 'i-excites-count', 'i-excites-fill');
  wireWordCount('i-project', 'i-project-count', 'i-project-fill');
  wireWordCount('i-dream',   'i-dream-count',   'i-dream-fill');

  // shake helper
  function shake(el) {
    if (!el) return;
    el.classList.add('invalid');
    el.style.animation = 'none';
    requestAnimationFrame(() => {
      el.style.animation = 'ishake 0.4s ease';
    });
    setTimeout(() => { el.classList.remove('invalid'); el.style.animation = ''; }, 2000);
  }

  // inject shake keyframe
  const sty = document.createElement('style');
  sty.textContent = '@keyframes ishake{0%,100%{transform:translateX(0)}20%{transform:translateX(-6px)}40%{transform:translateX(6px)}60%{transform:translateX(-4px)}80%{transform:translateX(4px)}}';
  document.head.appendChild(sty);

  // ── Photo preview for internship ──────────────────────────────────────
  document.getElementById('i-photo')?.addEventListener('change', (e) => {
    const file = e.target.files?.[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = (evt) => {
      const previewEl = document.getElementById('i-photo-preview');
      const imgEl = document.getElementById('i-photo-img');
      if (previewEl && imgEl) {
        imgEl.src = evt.target?.result;
        previewEl.style.display = 'block';
      }
    };
    reader.readAsDataURL(file);
  });

  // ── CV filename display ──────────────────────────────────────────────────
  document.getElementById('i-cv')?.addEventListener('change', (e) => {
    const file = e.target.files?.[0];
    const nameEl = document.getElementById('i-cv-name');
    const filenameEl = document.getElementById('i-cv-filename');
    if (!file || !nameEl || !filenameEl) return;
    filenameEl.textContent = file.name;
    nameEl.style.display = 'block';
  });

  // ── Submit ──────────────────────────────────────────────────────────────
  document.getElementById('intern-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const get  = (id) => document.getElementById(id);
    const val  = (id) => get(id)?.value?.trim() ?? '';
    const photoFile = get('i-photo')?.files?.[0];
    const cvFile = get('i-cv')?.files?.[0];

    // Validate required fields
    const required = [
      { id: 'i-fname',    v: val('i-fname') },
      { id: 'i-lname',   v: val('i-lname') },
      { id: 'i-email',   v: val('i-email') },
      { id: 'i-phone',   v: val('i-phone') },
      { id: 'i-photo',   v: photoFile ? 'file' : null },
      { id: 'i-cv',      v: cvFile ? 'file' : null },
      { id: 'i-uni',     v: val('i-uni') },
      { id: 'i-course',  v: val('i-course') },
      { id: 'i-year',    v: val('i-year') },
      { id: 'i-area',    v: val('i-area') },
      { id: 'i-duration',v: val('i-duration') },
      { id: 'i-avail',   v: val('i-avail') },
      { id: 'i-excites', v: val('i-excites') },
      { id: 'i-project', v: val('i-project') },
      { id: 'i-dream',   v: val('i-dream') },
    ];

    const failed = required.find(f => !f.v);
    if (failed) {
      shake(get(failed.id));
      get(failed.id)?.focus();
      return;
    }

    if (wordCount(val('i-excites')) < 20) { shake(get('i-excites')); return; }
    if (wordCount(val('i-project')) < 20) { shake(get('i-project')); return; }
    if (wordCount(val('i-dream'))   < 20) { shake(get('i-dream'));   return; }

    const skills = Array.from(
      document.querySelectorAll('input[name="intern-skill"]:checked')
    ).map(cb => cb.value);

    // Read photo as data URL
    let photoDataUrl = null;
    if (photoFile) {
      photoDataUrl = await new Promise((resolve) => {
        const reader = new FileReader();
        reader.onload = (e) => resolve(e.target?.result);
        reader.readAsDataURL(photoFile);
      });
    }

    // Read CV as data URL
    let cvDataUrl = null;
    if (cvFile) {
      cvDataUrl = await new Promise((resolve) => {
        const reader = new FileReader();
        reader.onload = (e) => resolve(e.target?.result);
        reader.readAsDataURL(cvFile);
      });
    }

    const btn   = document.getElementById('intern-submit-btn');
    const label = document.getElementById('intern-btn-label');
    const icon  = document.getElementById('intern-btn-icon');
    const hint  = document.getElementById('iform-hint');

    // Loading state
    if (btn)   btn.disabled = true;
    if (label) label.textContent = 'Sending...';
    if (icon)  icon.style.display = 'none';
    if (hint)  hint.textContent = 'Submitting your application...';

    try {
      const res = await fetch('/api/internship', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          firstName:        val('i-fname'),
          lastName:         val('i-lname'),
          email:            val('i-email'),
          phone:            val('i-phone'),
          photo:            photoDataUrl,
          cv:               cvDataUrl,
          university:       val('i-uni'),
          course:           val('i-course'),
          yearOfStudy:      val('i-year'),
          area:             val('i-area'),
          duration:         val('i-duration'),
          availability:     val('i-avail'),
          skills,
          linkedin:         val('i-linkedin') || null,
          github:           val('i-github')   || null,
          whatExcites:      val('i-excites'),
          ambitiousProject: val('i-project'),
          aiDream:          val('i-dream'),
        }),
      });

      if (res.ok) {
        const json = await res.json();
        // Identity/profile already captured — route straight into the shared
        // character assessment (Stage 2) instead of a terminal success screen.
        if (json && json.ok && json.id) {
          window.location.href = `/startup-builder?track=internship&id=${json.id}`;
          return;
        }
        const form    = document.getElementById('intern-form');
        const success = document.getElementById('intern-success');
        if (form)    form.style.display = 'none';
        if (success) success.classList.remove('hidden');
        document.getElementById('internship')?.scrollIntoView({ behavior: 'smooth', block: 'center' });
      } else {
        if (hint)  hint.textContent = 'Something went wrong. Please try again.';
        if (btn)   btn.disabled = false;
        if (label) label.textContent = 'Send Application';
        if (icon)  icon.style.display = '';
      }
    } catch {
      if (hint)  hint.textContent = 'Network error. Please try again.';
      if (btn)   btn.disabled = false;
      if (label) label.textContent = 'Send Application';
      if (icon)  icon.style.display = '';
    }
  });
</script>
